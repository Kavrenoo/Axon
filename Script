			Axon.UI.Tween(iconCircle, { BackgroundTransparency = 0 }, 0.15)
			Axon.UI.Tween(iconStroke, { Transparency = 1 }, 0.15)
			Axon.UI.Tween(label,      { TextColor3 = Axon.UI.Colors.TextPrimary }, 0.15)
			Axon.UI.Tween(accentBar,  { BackgroundTransparency = 0 }, 0.15)
		else
			Axon.UI.Tween(btn,        { BackgroundTransparency = 1 }, 0.15)
			Axon.UI.Tween(iconCircle, { BackgroundTransparency = 1 }, 0.15)
			Axon.UI.Tween(iconStroke, { Transparency = 0 }, 0.15)
			Axon.UI.Tween(label,      { TextColor3 = Axon.UI.Colors.TextSecondary }, 0.15)
			Axon.UI.Tween(accentBar,  { BackgroundTransparency = 1 }, 0.15)
		end
	end

	btn.MouseEnter:Connect(function()
		if Axon.UI.ActiveButton ~= btn then
			Axon.UI.Tween(btn,        { BackgroundColor3 = Axon.UI.Colors.HoverItem, BackgroundTransparency = 0 }, 0.12)
			Axon.UI.Tween(iconCircle, { BackgroundTransparency = 0.4 }, 0.12)
			Axon.UI.Tween(label,      { TextColor3 = Axon.UI.Colors.TextPrimary }, 0.12)
		end
	end)
	btn.MouseLeave:Connect(function()
		if Axon.UI.ActiveButton ~= btn then
			Axon.UI.Tween(btn,        { BackgroundTransparency = 1 }, 0.12)
			Axon.UI.Tween(iconCircle, { BackgroundTransparency = 1 }, 0.12)
			Axon.UI.Tween(label,      { TextColor3 = Axon.UI.Colors.TextSecondary }, 0.12)
		end
	end)

	if cfg.isMinimize then
		btn.MouseButton1Click:Connect(Axon.UI.ToggleSidebar)
	else
		btn.MouseButton1Click:Connect(function()
			-- Close global search overlay whenever a page is selected
			if Axon.Search and Axon.Search._open then
				Axon.Search._savedNav = nil  -- don't restore old nav, we're picking a new one
				Axon.Search.Close()
			end
			if Axon.UI.ActiveButton and Axon.UI.ActiveButton ~= btn then
				local prev = Axon.UI.ActiveButton
				-- Deactivate previous via its stored setActive closure
				for _, nb in pairs(Axon.UI.NavButtons) do
					if nb.btn == prev then nb.setActive(false); break end
				end
			end
			Axon.UI.ActiveButton = btn
			SetActive(true)
			Axon.Pages.Show(cfg.name)
		end)
	end

	return btn, SetActive
end

Axon.Components._dropdownClosers = {}

Axon.Components.Dropdown = function(parent, cfg)
    local options  = cfg.options or {}
    local selected = cfg.default or options[1] or ""

    local ITEM_H   = 32
    local CLOSED_H = 52
    local isOpen   = false

    local row = Axon.UI.New("Frame", {
        Size             = UDim2.new(1, 0, 0, CLOSED_H),
        BackgroundColor3 = Axon.UI.Colors.Section,
        BorderSizePixel  = 0,
        LayoutOrder      = cfg.order or 0,
        ClipsDescendants = true,
    }, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Border, 1) })
    row.Parent = parent

    Axon.UI.New("TextLabel", {
        Size                   = UDim2.new(1, -120, 0, 20),
        Position               = UDim2.new(0, 12, 0, 16),
        BackgroundTransparency = 1,
        Text                   = cfg.label or "Dropdown",
        TextColor3             = Axon.UI.Colors.TextPrimary,
        Font                   = Enum.Font.GothamSemibold,
        TextSize               = 13,
        TextXAlignment         = Enum.TextXAlignment.Left,
        Parent                 = row,
    })

    local pillW = cfg.pillWidth or 90

    local pill = Axon.UI.New("TextButton", {
        Size             = UDim2.new(0, pillW, 0, 28),
        Position         = UDim2.new(1, -(pillW + 12), 0, 12),
        BackgroundColor3 = Axon.UI.Colors.ButtonBg,
        Text             = selected,
        TextColor3       = Axon.UI.Colors.Accent,
        Font             = Enum.Font.GothamSemibold,
        TextSize         = 12,
        TextScaled       = true,
        BorderSizePixel  = 0,
        AutoButtonColor  = false,
        ZIndex           = 3,
    }, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Border, 1) })
    pill.Parent = row
    local _tsc = Instance.new("UITextSizeConstraint")
    _tsc.MinTextSize = 8; _tsc.MaxTextSize = 12; _tsc.Parent = pill

    pill.MouseEnter:Connect(function() Axon.UI.Tween(pill, { BackgroundColor3 = Axon.UI.Colors.ButtonHover }, 0.1) end)
    pill.MouseLeave:Connect(function() Axon.UI.Tween(pill, { BackgroundColor3 = Axon.UI.Colors.ButtonBg    }, 0.1) end)

    local divider = Axon.UI.New("Frame", {
        Size             = UDim2.new(1, -24, 0, 1),
        Position         = UDim2.new(0, 12, 0, CLOSED_H - 1),
        BackgroundColor3 = Axon.UI.Colors.Border,
        BorderSizePixel  = 0,
        Visible          = false,
        ZIndex           = 2,
        Parent           = row,
    })

    local OPEN_H   = CLOSED_H + #options * ITEM_H + 10
    local itemFrames = {}

    local function SetOpen(v)
        isOpen = v
        divider.Visible = isOpen
        for _, entry in ipairs(itemFrames) do
            entry.frame.Visible = isOpen
        end
        Axon.UI.Tween(row, { Size = UDim2.new(1, 0, 0, isOpen and OPEN_H or CLOSED_H) }, 0.15)
    end

    for i, option in ipairs(options) do
        local yPos     = CLOSED_H + (i - 1) * ITEM_H + 6
        local isSel    = option == selected

        local item = Axon.UI.New("TextButton", {
            Size             = UDim2.new(1, -24, 0, ITEM_H - 4),
            Position         = UDim2.new(0, 12, 0, yPos),
            BackgroundColor3 = isSel and Axon.UI.Colors.ActiveItem or Axon.UI.Colors.ButtonBg,
            Text             = option,
            TextColor3       = isSel and Axon.UI.Colors.Accent or Axon.UI.Colors.TextSecondary,
            Font             = Enum.Font.GothamSemibold,
            TextSize         = 12,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            Visible          = false,
            ZIndex           = 4,
        }, { Axon.UI.Corner(6) })
        item.Parent = row
        itemFrames[i] = { frame = item, option = option }

        item.MouseEnter:Connect(function()
            if option ~= selected then
                Axon.UI.Tween(item, { BackgroundColor3 = Axon.UI.Colors.HoverItem }, 0.1)
            end
        end)
        item.MouseLeave:Connect(function()
            if option ~= selected then
                Axon.UI.Tween(item, { BackgroundColor3 = Axon.UI.Colors.ButtonBg }, 0.1)
            end
        end)

        item.MouseButton1Click:Connect(function()
            selected = option
            pill.Text = selected
            for _, entry in ipairs(itemFrames) do
                local s = entry.option == selected
                entry.frame.BackgroundColor3 = s and Axon.UI.Colors.ActiveItem or Axon.UI.Colors.ButtonBg
                entry.frame.TextColor3       = s and Axon.UI.Colors.Accent     or Axon.UI.Colors.TextSecondary
            end
            if cfg.onChange then cfg.onChange(selected) end
            SetOpen(false)
        end)
    end

    pill.MouseButton1Click:Connect(function() SetOpen(not isOpen) end)

    local closerId = tostring(row)
    Axon.Components._dropdownClosers[closerId] = function() SetOpen(false) end
    row.AncestryChanged:Connect(function()
        if not row.Parent then
            Axon.Components._dropdownClosers[closerId] = nil
        end
    end)

    return row
end

