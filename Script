	local function VisPill(label, desc, order, defaultOn, onChange, saveKey)
		local savedValueLoaded = false
		if saveKey and Axon.Settings.Data[saveKey] ~= nil then
			defaultOn = Axon.Settings.Data[saveKey]
			savedValueLoaded = true
		end
		local row = Axon.UI.New("Frame", {
			Size = UDim2.new(1, 0, 0, 52), BackgroundColor3 = Axon.UI.Colors.Section,
			BorderSizePixel = 0, LayoutOrder = order,
		}, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Border, 1) })
		row.Parent = sVis
		Axon.UI.New("TextLabel", {
			Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 12, 0, 8),
			BackgroundTransparency = 1, Text = label,
			TextColor3 = Axon.UI.Colors.TextPrimary, Font = Enum.Font.GothamSemibold,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
		})
		if desc then
			Axon.UI.New("TextLabel", {
				Size = UDim2.new(1, -80, 0, 16), Position = UDim2.new(0, 12, 0, 30),
				BackgroundTransparency = 1, Text = desc,
				TextColor3 = Axon.UI.Colors.TextDim, Font = Enum.Font.Gotham,
				TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
			})
		end
		local pill = Axon.UI.New("Frame", {
			Size = UDim2.new(0, 40, 0, 22), Position = UDim2.new(1, -52, 0.5, -11),
			BackgroundColor3 = defaultOn and Axon.UI.Colors.ToggleOn or Axon.UI.Colors.ToggleOff,
			BorderSizePixel = 0,
