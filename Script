	local function MakeLine(name, zIndex)
		local f = Instance.new("Frame"); f.Name=name; f.BackgroundColor3=CH.color
		f.BorderSizePixel=0; f.AnchorPoint=Vector2.new(0.5,0.5)
		f.ZIndex=zIndex or 2; f.Visible=false; f.Parent=crossGui; return f
	end

	local lineT=MakeLine("Top"); local lineB=MakeLine("Bottom")
	local lineL=MakeLine("Left"); local lineR=MakeLine("Right"); local dotPart=MakeLine("Dot")
	local outT=MakeLine("OutT",1); local outB=MakeLine("OutB",1)
	local outL=MakeLine("OutL",1); local outR=MakeLine("OutR",1); local outD=MakeLine("OutD",1)
	for _, f in ipairs({outT,outB,outL,outR,outD}) do f.BackgroundColor3=Color3.new(0,0,0) end

	local function SetAllVisible(v)
		for _, f in ipairs({lineT,lineB,lineL,lineR}) do f.Visible=v end
		dotPart.Visible = v and CH.dot
		local ov = v and CH.outline
		for _, f in ipairs({outT,outB,outL,outR}) do f.Visible=ov end
		outD.Visible = ov and CH.dot
	end

	local function DrawCrosshair(cx, cy)
		local s=CH.size; local th=CH.thickness; local g=CH.gap; local a=1-CH.opacity; local c=CH.color
		lineT.Size=UDim2.new(0,th,0,s); lineT.Position=UDim2.new(0,cx,0,cy-g-(s/2)); lineT.BackgroundColor3=c; lineT.BackgroundTransparency=a
		lineB.Size=UDim2.new(0,th,0,s); lineB.Position=UDim2.new(0,cx,0,cy+g+(s/2)); lineB.BackgroundColor3=c; lineB.BackgroundTransparency=a
		lineL.Size=UDim2.new(0,s,0,th); lineL.Position=UDim2.new(0,cx-g-(s/2),0,cy); lineL.BackgroundColor3=c; lineL.BackgroundTransparency=a
		lineR.Size=UDim2.new(0,s,0,th); lineR.Position=UDim2.new(0,cx+g+(s/2),0,cy); lineR.BackgroundColor3=c; lineR.BackgroundTransparency=a
		dotPart.Size=UDim2.new(0,th,0,th); dotPart.Position=UDim2.new(0,cx,0,cy); dotPart.BackgroundColor3=c; dotPart.BackgroundTransparency=a
		dotPart.Visible=CH.enabled and CH.dot
		local pad=1
		outT.Size=UDim2.new(0,th+pad*2,0,s+pad*2);  outT.Position=UDim2.new(0,cx,0,cy-g-(s/2));  outT.BackgroundTransparency=a
		outB.Size=UDim2.new(0,th+pad*2,0,s+pad*2);  outB.Position=UDim2.new(0,cx,0,cy+g+(s/2));  outB.BackgroundTransparency=a
		outL.Size=UDim2.new(0,s+pad*2,0,th+pad*2);  outL.Position=UDim2.new(0,cx-g-(s/2),0,cy);  outL.BackgroundTransparency=a
		outR.Size=UDim2.new(0,s+pad*2,0,th+pad*2);  outR.Position=UDim2.new(0,cx+g+(s/2),0,cy);  outR.BackgroundTransparency=a
		outD.Size=UDim2.new(0,th+pad*2,0,th+pad*2); outD.Position=UDim2.new(0,cx,0,cy);           outD.BackgroundTransparency=a
		local ov=CH.enabled and CH.outline
		for _, f in ipairs({outT,outB,outL,outR}) do f.Visible=ov end; outD.Visible=ov and CH.dot
	end

	local function GetCrosshairPos()
		if CH.replaceCursor then local mp=Axon.Services.UserInputService:GetMouseLocation(); return mp.X, mp.Y end
		local vp=workspace.CurrentCamera.ViewportSize; return vp.X/2, vp.Y/2
	end

	local function ApplyCursor()
		if CH.enabled and CH.replaceCursor then Axon.Services.UserInputService.MouseIconEnabled=false
		else Axon.Services.UserInputService.MouseIconEnabled=true end
	end

	local function StartRender()
		if CH.renderConn then CH.renderConn:Disconnect(); CH.renderConn=nil end
		CH.renderConn = Axon.Services.RunService.RenderStepped:Connect(function()
			if not CH.enabled then return end
			local isShiftLock = Axon.Services.UserInputService.MouseBehavior == Enum.MouseBehavior.LockCenter
			if CH.shiftLockOnly then
				if not isShiftLock then
					SetAllVisible(false); Axon.Services.UserInputService.MouseIconEnabled=true; return
				else
					for _, gui in ipairs(Axon.Services.PlayerGui:GetChildren()) do
						if gui.Name=="RbxGui" or gui.Name=="TouchGui" then
							local lockIcon=gui:FindFirstChild("ShiftLockIndicator",true); if lockIcon then lockIcon.Visible=false end
						end
					end
					Axon.Services.UserInputService.MouseIconEnabled=false
				end
			end
			SetAllVisible(true)
			local cx, cy = GetCrosshairPos(); DrawCrosshair(cx, cy)
		end)
	end

	local function StopRender()
		if CH.renderConn then CH.renderConn:Disconnect(); CH.renderConn=nil end
	end

