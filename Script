    -- (Emote Walk ported from UGC_Emotes: Action-priority looped track approach)
    local moveEmoteWalkConn  = nil   -- CharacterAdded connection (re-hooks on respawn)
    local moveEmotePriConn   = nil   -- AnimationPlayed connection on current char
    local currentEmoteTrack  = nil   -- the Action-priority looped emote track
    local emotesWalkEnabled  = false -- master flag (mirrors the toggle state)

    -- Strip rbxassetid:// / legacy URL prefix → bare numeric ID string
    local function urlToId(id)
        id = id:gsub("http://www%.roblox%.com/asset/%?id=", "")
        id = id:gsub("rbxassetid://", "")
        return id
    end

    -- Returns true when animTrack is an emote (its ID is NOT present in any
    -- locomotion folder of the character's Animate script).
    local function isDancing(char, animTrack)
        local animate = char:FindFirstChild("Animate")
        if not animate then return false end
        local animId = urlToId(animTrack.Animation.AnimationId)
        for _, holder in ipairs(animate:GetChildren()) do
            if holder:IsA("StringValue") then
                for _, animObj in ipairs(holder:GetChildren()) do
                    if animObj:IsA("Animation") and urlToId(animObj.AnimationId) == animId then
                        return false  -- it's a loco animation, not an emote
                    end
                end
            end
        end
        return true
    end

    -- Stop and clear the currently held Action-priority emote track.
    local function StopCurrentEmote()
        if currentEmoteTrack then
            pcall(function() currentEmoteTrack:Stop() end)
            currentEmoteTrack = nil
        end
    end

    -- Load the emote at Action priority (looped) so it persists while walking.
    local function PlayEmoteWalk(hum, emoteId)
        StopCurrentEmote()
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. emoteId
        local ok, track = pcall(function() return hum.Animator:LoadAnimation(anim) end)
        if ok and track then
            currentEmoteTrack          = track
            currentEmoteTrack.Priority = Enum.AnimationPriority.Action
            currentEmoteTrack.Looped   = true
            task.wait(0.1)
            currentEmoteTrack:Play()
        end
    end

    -- Hook a character's Animator so every new emote played while the toggle
    -- is ON gets a persistent Action-priority twin track.
    local function HookEmoteWalk(char)
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        local animator = hum:FindFirstChildOfClass("Animator")
        if not animator then return end

        if moveEmotePriConn then moveEmotePriConn:Disconnect(); moveEmotePriConn = nil end

        moveEmotePriConn = animator.AnimationPlayed:Connect(function(animTrack)
            if not emotesWalkEnabled then return end
            if not isDancing(char, animTrack) then return end

            local playedId = urlToId(animTrack.Animation.AnimationId)
            if currentEmoteTrack then
                local curId = urlToId(currentEmoteTrack.Animation.AnimationId)
                if curId == playedId then return end  -- already playing this emote
                StopCurrentEmote()
            end
            PlayEmoteWalk(hum, playedId)
        end)

        hum.Died:Connect(function()
            emotesWalkEnabled = false
            StopCurrentEmote()
        end)
    end

