	fbKeyBindBtn.MouseButton1Click:Connect(function()
		FBKey.capturing = true
		if FBKey.globalConn  then FBKey.globalConn:Disconnect();  FBKey.globalConn  = nil end
		if FBKey.captureConn then FBKey.captureConn:Disconnect() end
		fbKeyBindBtn.Text = "Press Key…"; fbKeyBindBtn.TextColor3 = Col.Accent
		FBKey.captureConn = Axon.Services.UserInputService.InputBegan:Connect(function(input, gpe)
			if gpe or not FBKey.capturing then return end
			if input.UserInputType == Enum.UserInputType.Keyboard then
				FBKey.capturing = false
				FBKey.captureConn:Disconnect(); FBKey.captureConn = nil
				fbKeyBindBtn.TextColor3 = Col.TextSecondary
				if input.KeyCode == Enum.KeyCode.Backspace then
					FBKey.key = nil
					Axon.Settings.Data.targetFBKey = ""; Axon.Settings.Save()
				else
					FBKey.key = input.KeyCode
					Axon.Settings.Data.targetFBKey = FBKey.key.Name; Axon.Settings.Save()
					task.defer(FBKeyEnableGlobal)
				end
