    -- ── Fire the leave callback for whichever page we're leaving ─────────
    if Axon.Pages.Current and Axon.Pages.Current ~= name then
        local cb = Axon.Pages.OnLeave[Axon.Pages.Current]
        if cb then pcall(cb) end
    end

    for _, closer in pairs(Axon.Components._dropdownClosers) do
