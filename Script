	local Lighting = game:GetService("Lighting")

	-- Track all shader-created instances so we can clean them up
	local ShaderInstances = {}
	local function GetOrCreate(className, name)
		local existing = ShaderInstances[name]
		if existing and existing.Parent then return existing end
		-- Remove any stale one first
		local old = Lighting:FindFirstChild(name)
		if old then old:Destroy() end
		local inst = Instance.new(className)
		inst.Name = name
		inst.Parent = Lighting
		ShaderInstances[name] = inst
		return inst
	end
	local function RemoveShaderInst(name)
		local inst = ShaderInstances[name]
		if inst and inst.Parent then inst:Destroy() end
		ShaderInstances[name] = nil
		local lingering = Lighting:FindFirstChild(name)
		if lingering then lingering:Destroy() end
	end

