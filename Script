	local function DoLoadInventory(plr)
		-- Collect Tool instances from backpack and character
		local items = {}
		local bp = plr:FindFirstChildOfClass("Backpack")
		if bp then
			for _, v in ipairs(bp:GetChildren()) do
				if v:IsA("Tool") then
					table.insert(items, { name = v.Name, equipped = false })
				end
			end
		end
		local char = plr.Character
		if char then
			for _, v in ipairs(char:GetChildren()) do
				if v:IsA("Tool") then
					table.insert(items, { name = v.Name, equipped = true })
				end
			end
		end

		if #items == 0 then
			invNoDataLbl.Text    = "No items found in inventory"
			invNoDataLbl.Visible = true
			invUnloadBtn.Visible = true
			return
		end

		-- Sort: equipped first, then alphabetically
		table.sort(items, function(a, b)
			if a.equipped ~= b.equipped then return a.equipped end
			return a.name:lower() < b.name:lower()
		end)

		-- Clear any stale rows
		for _, child in ipairs(invListHolder:GetChildren()) do
			if child:IsA("GuiObject")
				and not child:IsA("UIListLayout")
				and not child:IsA("UIPadding")
			then
				child:Destroy()
			end
		end

		for i, item in ipairs(items) do
			local row = UI.New("Frame", {
				Size = UDim2.new(1, 0, 0, 40),
				BackgroundColor3 = Col.Section, BorderSizePixel = 0,
				LayoutOrder = i, Parent = invListHolder,
			}, { UI.Corner(6), UI.Stroke(Col.Border, 1) })

			-- Icon
			UI.New("TextLabel", {
				Size = UDim2.new(0, 40, 1, 0), Position = UDim2.new(0, 0, 0, 0),
				BackgroundTransparency = 1,
				Text = item.equipped and "🤚" or "🎒",
				TextSize = 15, Font = Enum.Font.GothamBold,
				TextColor3 = item.equipped and Col.Accent or Col.TextDim,
				Parent = row,
			})

			-- Item name
			UI.New("TextLabel", {
				Size = UDim2.new(1, -80, 1, 0), Position = UDim2.new(0, 44, 0, 0),
				BackgroundTransparency = 1, Text = item.name,
				TextColor3 = Col.TextPrimary, Font = Enum.Font.GothamSemibold,
				TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left,
				TextTruncate = Enum.TextTruncate.AtEnd, Parent = row,
