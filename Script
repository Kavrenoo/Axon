		StartFly = function()
			local h, r = GetHR(); if not r then return end
			-- Silently pause CFrame walk style so it doesn't fight fly's BodyVelocity/BodyGyro
			if Char.walkSpeedStyle == "CFrame" and Char.walkCFrameConn then
				Char._flyPausedCFrameWalk = true
				if Char.walkCFrameConn then Char.walkCFrameConn:Disconnect(); Char.walkCFrameConn = nil end
				local hh = GetHR(); if hh then hh.WalkSpeed = Char.walkSpeed; hh.AutoRotate = true end
			end
			local char = Axon.Services.Player.Character
			if h then h.PlatformStand = false; h.Sit = false; h.AutoRotate = true end
			local animScript = char and char:FindFirstChild("Animate")
			if animScript then animScript.Disabled = true end
			if h then for _, tr in ipairs(h:GetPlayingAnimationTracks()) do tr:Stop(0) end end
			task.wait()
			if char then
				for _, m in ipairs(char:GetDescendants()) do
					if m:IsA("Motor6D") then m.Transform = CFrame.new() end
				end
			end
			if animScript then animScript.Disabled = false end
			local _, r2 = GetHR(); if not r2 then return end
			local lv = r2.CFrame.LookVector
			local flat = Vector3.new(lv.X, 0, lv.Z)
			if flat.Magnitude > 0.01 then
				r2.CFrame = CFrame.new(r2.Position, r2.Position + flat)
			end
			local h2 = GetHR()
			if h2 then h2.PlatformStand = true end
			local runSound = r2 and r2:FindFirstChild("Running")
			if runSound then runSound.Volume = 0 end
			local UIS = Axon.Services.UserInputService

			-- Load fly idle animation (R15 only)
			do
				local h3 = GetHR()
				local _isR6fly = h3 and h3.RigType == Enum.HumanoidRigType.R6
				if h3 and not _isR6fly then
					local idleAnim = Instance.new("Animation")
					idleAnim.AnimationId = "rbxassetid://132783162476851"
					local ok, track = pcall(function() return h3:LoadAnimation(idleAnim) end)
					if ok and track then
						Char.flyIdleTrack = track
						track.Looped = true
						track:Play(0.3)
					end
				end
			end

			-- Default fly: BodyVelocity + BodyGyro
			local bg = Instance.new("BodyGyro"); bg.Name = "AxonFlyBG"
			bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
			bg.P = 2e4   -- lower = softer rotation response (was 9e4)
			bg.D = 800   -- damping so it eases to a stop instead of snapping
			bg.CFrame = r2.CFrame; bg.Parent = r2
			local bv = Instance.new("BodyVelocity"); bv.Name = "AxonFlyBV"
			bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
			bv.Velocity = Vector3.zero; bv.Parent = r2
			Char.flyConn = Axon.Services.RunService.RenderStepped:Connect(function()
				local _, root2 = GetHR()
				local bv2 = root2 and root2:FindFirstChild("AxonFlyBV")
				local bg2 = root2 and root2:FindFirstChild("AxonFlyBG")
				if not bv2 or not bg2 then return end
				local cam = workspace.CurrentCamera
				local dir = Vector3.zero
				local spd = Char.flySpeed
				if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
				if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
				if Char.flyQE then
					if UIS:IsKeyDown(Enum.KeyCode.E) then dir = dir + Vector3.new(0, 1, 0) end
					if UIS:IsKeyDown(Enum.KeyCode.Q) then dir = dir - Vector3.new(0, 1, 0) end
				end
				bv2.Velocity = dir.Magnitude > 0 and dir.Unit * spd or Vector3.zero
				-- Smoothly ease the body toward the camera look direction instead of snapping
				local camTarget = CFrame.new(root2.Position) * CFrame.fromEulerAnglesYXZ(cam.CFrame:ToEulerAnglesYXZ())
				bg2.CFrame = bg2.CFrame:Lerp(camTarget, 0.12)
				-- Always play idle animation for all movement directions
				if Char.flyIdleTrack then
					if not Char.flyIdleTrack.IsPlaying then Char.flyIdleTrack:Play(0.2) end
				end
				-- Keep camera offset for R15 only
				local h3 = GetHR()
				if h3 and h3.RigType ~= Enum.HumanoidRigType.R6 then
					local targetOffset = Vector3.new(0, 1.5, 0)
					if (h3.CameraOffset - targetOffset).Magnitude > 0.05 then
