-- ══════════════════════════════════════════════════════════
-- Axon.Loader  –  splash / progress screen
-- ══════════════════════════════════════════════════════════

do
	local _TW  = game:GetService("TweenService")
	local _HS  = game:GetService("HttpService")
	local _PG  = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")

	-- ── Read saved accent color and GUI scale before anything else runs ────
	local SAVE_FILE   = "axon_save.json"
	local DEFAULT_ACC = Color3.fromRGB(88, 166, 255)
	local accent      = DEFAULT_ACC
	local savedScale  = 1
	if readfile then
		pcall(function()
			local data = _HS:JSONDecode(readfile(SAVE_FILE))
			local ac = data and data.accentColor
			if type(ac) == "table" and ac[1] and ac[2] and ac[3] then
				accent = Color3.fromRGB(ac[1], ac[2], ac[3])
			end
			local gs = data and data.guiScale
			if type(gs) == "number" then
				savedScale = math.clamp(math.floor(gs * 10 + 0.5) / 10, 0.5, 2)
			end
		end)
	end

	-- Dimensions mirror Axon.Config (duplicated here so loader exists before Config)
	local WIN_W  = 650
	local WIN_H  = 50 + (9 * 40) + (8 * 2) + (8 * 2)
	local CORNER = 10

	-- Own ScreenGui so it cleanly layers above everything
	local loaderGui = Instance.new("ScreenGui")
	loaderGui.Name           = "AxonLoader"
	loaderGui.ResetOnSpawn   = false
	loaderGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	loaderGui.IgnoreGuiInset = true
	loaderGui.DisplayOrder   = 999
	loaderGui.Parent         = _PG

	-- Card — matches the main window exactly in size and position
	local card = Instance.new("Frame")
	card.Name             = "LoaderCard"
	card.Size             = UDim2.new(0, WIN_W, 0, WIN_H)
	card.Position         = UDim2.new(0.5, 0, 0.5, 0)
	card.AnchorPoint      = Vector2.new(0.5, 0.5)
	card.BackgroundColor3 = Color3.fromRGB(13, 17, 23)
	card.BorderSizePixel  = 0
	card.Parent           = loaderGui
	do
		local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, CORNER); c.Parent = card
		local s = Instance.new("UIStroke"); s.Color = Color3.fromRGB(30, 36, 48); s.Thickness = 1; s.Parent = card
		local sc = Instance.new("UIScale"); sc.Scale = savedScale; sc.Parent = card
	end

	-- Logo text
	local logo = Instance.new("TextLabel")
	logo.Size                   = UDim2.new(1, 0, 0, 54)
	logo.Position               = UDim2.new(0, 0, 0.5, -72)
	logo.BackgroundTransparency = 1
	logo.Text                   = "AXON"
	logo.TextColor3             = Color3.fromRGB(230, 237, 243)
	logo.Font                   = Enum.Font.GothamBold
	logo.TextSize               = 36
	logo.Parent                 = card

	-- Tagline
	local tagline = Instance.new("TextLabel")
	tagline.Size                   = UDim2.new(1, 0, 0, 20)
	tagline.Position               = UDim2.new(0, 0, 0.5, -20)
	tagline.BackgroundTransparency = 1
	tagline.Text                   = "Loading, please wait…"
	tagline.TextColor3             = Color3.fromRGB(90, 105, 125)
	tagline.Font                   = Enum.Font.Gotham
	tagline.TextSize               = 12
	tagline.Parent                 = card

	-- Status label (above progress bar)
	local statusLbl = Instance.new("TextLabel")
	statusLbl.Size                   = UDim2.new(1, -112, 0, 16)
	statusLbl.Position               = UDim2.new(0, 28, 1, -52)
	statusLbl.BackgroundTransparency = 1
	statusLbl.Text                   = "Initializing…"
	statusLbl.TextColor3             = Color3.fromRGB(90, 105, 125)
	statusLbl.Font                   = Enum.Font.Gotham
	statusLbl.TextSize               = 11
	statusLbl.TextXAlignment         = Enum.TextXAlignment.Left
	statusLbl.Parent                 = card

	-- Percent label (right side, accent colored) — right edge aligned with track right edge (card - 28)
	local pctLbl = Instance.new("TextLabel")
	pctLbl.Size                   = UDim2.new(0, 44, 0, 16)
	pctLbl.Position               = UDim2.new(1, -72, 1, -52)
	pctLbl.BackgroundTransparency = 1
	pctLbl.Text                   = "0%"
	pctLbl.TextColor3             = accent
	pctLbl.Font                   = Enum.Font.GothamBold
	pctLbl.TextSize               = 11
	pctLbl.TextXAlignment         = Enum.TextXAlignment.Right
	pctLbl.Parent                 = card

	-- Progress track
	local track = Instance.new("Frame")
	track.Size             = UDim2.new(1, -56, 0, 3)
	track.Position         = UDim2.new(0, 28, 1, -30)
	track.BackgroundColor3 = Color3.fromRGB(30, 36, 48)
	track.BorderSizePixel  = 0
	track.ClipsDescendants = true
	track.Parent           = card
	do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 2); c.Parent = track end

	-- Progress fill (accent colored)
	local fill = Instance.new("Frame")
	fill.Size             = UDim2.new(0, 0, 1, 0)
	fill.BackgroundColor3 = accent
	fill.BorderSizePixel  = 0
	fill.Parent           = track
	do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 2); c.Parent = fill end

	Axon._loading = true
	Axon._postLoadFns = {}   -- functions queued here run after the loading screen fully dismisses
	local _cur = 0

	Axon.SetLoadProgress = function(pct, label)
		_cur = math.clamp(pct, 0, 1)
		_TW:Create(fill,
			TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
			{ Size = UDim2.new(_cur, 0, 1, 0) }
		):Play()
		pctLbl.Text  = math.round(_cur * 100) .. "%"
		if label then statusLbl.Text = label end
	end

	Axon.DismissLoader = function()
		Axon._loading = false
		Axon.SetLoadProgress(1, "Ready!")
		task.wait(0.25)
		local fadeInfo = TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
		_TW:Create(card, fadeInfo, { BackgroundTransparency = 1 }):Play()
		for _, d in ipairs(card:GetDescendants()) do
			pcall(function()
				if d:IsA("TextLabel") then
					_TW:Create(d, TweenInfo.new(0.3), { TextTransparency = 1 }):Play()
				end
				if d:IsA("Frame") or d:IsA("ImageLabel") then
					_TW:Create(d, TweenInfo.new(0.3), { BackgroundTransparency = 1 }):Play()
				end
				if d:IsA("UIStroke") then
					_TW:Create(d, TweenInfo.new(0.3), { Transparency = 1 }):Play()
				end
			end)
		end
		task.delay(0.45, function()
			pcall(function() loaderGui:Destroy() end)
		end)
	end

	-- ══════════════════════════════════════════════════════════
	-- Axon Key System + Whitelist
	-- ══════════════════════════════════════════════════════════

	-- ── Whitelisted Roblox Player IDs (skip key check entirely) ─
	local WHITELIST = {
		5712636024,  -- add Player IDs here
	}

	-- ── Valid keys ────────────────────────────────────────────
	local VALID_KEYS = {
		"AXON-N3XQ-7VRM-WL48",
	}
	-- ─────────────────────────────────────────────────────────

	local KEY_FILE   = "axon_key.txt"

	local _localPlayer = game:GetService("Players").LocalPlayer

	-- Validation helper (case-insensitive, strips whitespace)
	local function isValidKey(raw)
		local k = (raw or ""):upper():gsub("%s+", "")
		for _, v in ipairs(VALID_KEYS) do
			if v:upper() == k then return true end
		end
		return false
	end

	-- Check whitelist by UserId
	local _isWhitelisted = false
	for _, id in ipairs(WHITELIST) do
		if id == _localPlayer.UserId then
			_isWhitelisted = true
			break
		end
	end

	-- Try loading a previously saved key from disk
	local _savedKeyValid = false
	if not _isWhitelisted and readfile then
		pcall(function()
			local saved = readfile(KEY_FILE)
			if isValidKey(saved) then
				_savedKeyValid = true
			end
		end)
	end

	if _isWhitelisted then
		-- Whitelisted player — skip key screen
		statusLbl.Text = "Whitelisted — loading…"
		task.wait(0.6)

	elseif _savedKeyValid then
		-- Saved key on disk is valid — skip key screen silently
		statusLbl.Text = "Key verified — loading…"
		task.wait(0.4)

	else
		-- ── No valid saved key — show key entry UI ────────────

		-- Hide the percent label so it doesn't show as a stray coloured dash
		pctLbl.Visible = false

		-- Centered key entry container — compact, stacked vertically
		local keyFrame = Instance.new("Frame")
		keyFrame.Name                   = "KeyFrame"
		keyFrame.Size                   = UDim2.new(0, 220, 0, 66)
		keyFrame.Position               = UDim2.new(0.5, 0, 0.5, 10)
		keyFrame.AnchorPoint            = Vector2.new(0.5, 0)
		keyFrame.BackgroundTransparency = 1
		keyFrame.Visible                = false
		keyFrame.Parent                 = card

		-- Input box — centered, key-format style placeholder
		local keyBox = Instance.new("TextBox")
		keyBox.Size              = UDim2.new(1, 0, 0, 26)
		keyBox.Position          = UDim2.new(0, 0, 0, 0)
		keyBox.BackgroundColor3  = Color3.fromRGB(22, 27, 34)
		keyBox.BorderSizePixel   = 0
		keyBox.PlaceholderText   = "XXXX-XXXX-XXXX-XXXX"
		keyBox.PlaceholderColor3 = Color3.fromRGB(60, 72, 90)
		keyBox.Text              = ""
		keyBox.TextColor3        = Color3.fromRGB(230, 237, 243)
		keyBox.Font              = Enum.Font.GothamBold
		keyBox.TextSize          = 11
		keyBox.TextXAlignment    = Enum.TextXAlignment.Center
		keyBox.ClearTextOnFocus  = true
		keyBox.Parent            = keyFrame
		do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 5); c.Parent = keyBox end
		do local s = Instance.new("UIStroke"); s.Color = Color3.fromRGB(38, 46, 60); s.Thickness = 1; s.Parent = keyBox end

		-- Submit button — full width, below input
		local submitBtn = Instance.new("TextButton")
		submitBtn.Size             = UDim2.new(1, 0, 0, 24)
		submitBtn.Position         = UDim2.new(0, 0, 0, 28)
		submitBtn.BackgroundColor3 = accent
		submitBtn.BorderSizePixel  = 0
		submitBtn.Text             = "Submit"
		submitBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
		submitBtn.Font             = Enum.Font.GothamSemibold
		submitBtn.TextSize         = 11
		submitBtn.AutoButtonColor  = false
		submitBtn.Parent           = keyFrame
		do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, 5); c.Parent = submitBtn end
		submitBtn.MouseEnter:Connect(function()
			_TW:Create(submitBtn, TweenInfo.new(0.12), { BackgroundColor3 = accent:Lerp(Color3.new(1,1,1), 0.15) }):Play()
		end)
		submitBtn.MouseLeave:Connect(function()
			_TW:Create(submitBtn, TweenInfo.new(0.12), { BackgroundColor3 = accent }):Play()
		end)

		-- Feedback label — centered below button
		local keyMsgLbl = Instance.new("TextLabel")
		keyMsgLbl.Size                   = UDim2.new(1, 0, 0, 14)
		keyMsgLbl.Position               = UDim2.new(0, 0, 0, 56)
		keyMsgLbl.BackgroundTransparency = 1
		keyMsgLbl.Text                   = ""
		keyMsgLbl.TextColor3             = Color3.fromRGB(220, 60, 60)
		keyMsgLbl.Font                   = Enum.Font.Gotham
		keyMsgLbl.TextSize               = 10
		keyMsgLbl.TextXAlignment         = Enum.TextXAlignment.Center
		keyMsgLbl.Parent                 = keyFrame

		local _keyValid = false

		-- Submit handler (shared so Enter key can call it too)
		local function DoSubmit()
			if _keyValid then return end
			keyMsgLbl.TextColor3 = Color3.fromRGB(90, 105, 125)
			keyMsgLbl.Text = "Checking…"
			task.wait(0.55)
			if isValidKey(keyBox.Text) then
				_keyValid            = true
				keyMsgLbl.TextColor3 = Color3.fromRGB(60, 220, 100)
				keyMsgLbl.Text       = "✓ Key accepted!"
				tagline.Text         = "Key accepted — loading…"
				-- Save the key to disk so it's remembered next time
				pcall(function()
					if writefile then
						writefile(KEY_FILE, keyBox.Text:upper():gsub("%s+", ""))
					end
				end)
				task.delay(0.5, function() keyFrame.Visible = false end)
			else
				keyMsgLbl.TextColor3 = Color3.fromRGB(220, 60, 60)
				keyMsgLbl.Text       = "Invalid key."
			end
		end
		submitBtn.MouseButton1Click:Connect(DoSubmit)

		-- Allow Enter to submit
		keyBox.FocusLost:Connect(function(enterPressed)
			if enterPressed then task.spawn(DoSubmit) end
		end)

		-- Show key screen and freeze until valid
		tagline.Text     = "Enter your key to continue."
		statusLbl.Text   = ""
		keyFrame.Visible = true

		repeat task.wait(0.05) until _keyValid

		-- Restore percent label for normal loading
		pctLbl.Visible = true
	end

	-- Restore normal loading UI
	tagline.Text   = "Loading, please wait…"
	pctLbl.Text    = "0%"
	statusLbl.Text = "Initializing…"

	-- ══════════════════════════════════════════════════════════
end

-- shared tool registry: { on=bool, enabledAt=number, give=fn, remove=fn }
Axon._tools     = {}
Axon._toolClock = 0

-- call after any tool toggle to persist the current ordered list
local function SaveToolOrder()
	local ordered = {}
	for name, t in pairs(Axon._tools) do
		if t.on then
			table.insert(ordered, { name = name, at = t.enabledAt })
		end
	end
	table.sort(ordered, function(a, b) return a.at < b.at end)
	local names = {}
	for _, e in ipairs(ordered) do table.insert(names, e.name) end
	Axon.Settings.Data.toolOrder = names
	Axon.Settings.Save()
end

