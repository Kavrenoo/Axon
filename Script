			if Char.noclipConn then Char.noclipConn:Disconnect(); Char.noclipConn = nil end
			if v then
				Char.noclipSnapshot = {}
				local char = Axon.Services.Player.Character
				if char then
					for _, part in ipairs(char:GetDescendants()) do
						if part:IsA("BasePart") then
							Char.noclipSnapshot[part] = part.CanCollide
						end
					end
				end
				Char.noclipConn = Axon.Services.RunService.Stepped:Connect(function()
					local c = Axon.Services.Player.Character
					if not c then return end
					for _, part in ipairs(c:GetDescendants()) do
						if part:IsA("BasePart") then part.CanCollide = false end
					end
				end)
			else
				local h = GetHR()
				if h then h.PlatformStand = false end
				local snapshot = Char.noclipSnapshot or {}
				local char = Axon.Services.Player.Character
				if char then
					for _, part in ipairs(char:GetDescendants()) do
						if part:IsA("BasePart") then
							pcall(function()
								if snapshot[part] ~= nil then
									part.CanCollide = snapshot[part]
								end
							end)
						end
