-- ══════════════════════════════════════════════════════════
-- Axon.Notify  –  stacking slide-in notifications
-- ══════════════════════════════════════════════════════════

Axon.Notify = {}

do
	local NOTIF_W     = 280
	local NOTIF_H     = 72
	local NOTIF_GAP   = 10
	local NOTIF_MAX   = 3
	local ANIM_TIME   = 0.25

	Axon.Notify._active = {}
	local _evicting = false  -- true while an eviction tween is in-flight

	local notifGui = Instance.new("ScreenGui")
	notifGui.Name           = "AxonNotifications"
	notifGui.ResetOnSpawn   = false
	notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	notifGui.Parent         = Axon.Services.PlayerGui

	local function SlotY(i)
		return 20 + (i - 1) * (NOTIF_H + NOTIF_GAP)
	end

	local function Restack()
		for i, frame in ipairs(Axon.Notify._active) do
			if frame and frame.Parent then
				frame:TweenPosition(
					UDim2.new(1, -NOTIF_W - 16, 0, SlotY(i)),
					Enum.EasingDirection.Out,
					Enum.EasingStyle.Quart,
					ANIM_TIME,
					true
				)
			end
		end
	end

	local SpawnCard  -- forward declare so Dismiss can reference it

	local function Dismiss(frame, onDone)
		if frame:GetAttribute("Removing") then return end
		frame:SetAttribute("Removing", true)

		for i, f in ipairs(Axon.Notify._active) do
			if f == frame then table.remove(Axon.Notify._active, i); break end
		end

		frame:TweenPosition(
			UDim2.new(1, 20, 0, frame.Position.Y.Offset),
			Enum.EasingDirection.In,
			Enum.EasingStyle.Quart,
			ANIM_TIME,
			true,
			function()
				pcall(function() frame:Destroy() end)
				Restack()
				if onDone then
					task.wait() -- one frame gap so restack tween has started
					onDone()
				end
			end
		)
	end

	SpawnCard = function(title, msg, dur)
		local Col  = Axon.UI.Colors
		local slot = #Axon.Notify._active + 1

		local frame = Instance.new("Frame")
		frame.Name             = "AxonNotif"
		frame.Size             = UDim2.new(0, NOTIF_W, 0, NOTIF_H)
		frame.Position         = UDim2.new(1, 20, 0, SlotY(slot))
		frame.BackgroundColor3 = Col.Section
		frame.BorderSizePixel  = 0
		frame.Active           = true
		frame.Parent           = notifGui

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 8)
		corner.Parent = frame

		local stroke = Instance.new("UIStroke")
		stroke.Color     = Col.Border
		stroke.Thickness = 1
		stroke.Parent    = frame

		local titleLbl = Instance.new("TextLabel")
		titleLbl.Size                   = UDim2.new(1, -20, 0, 18)
		titleLbl.Position               = UDim2.new(0, 10, 0, 10)
		titleLbl.BackgroundTransparency = 1
		titleLbl.Text                   = title
		titleLbl.TextColor3             = Col.TextPrimary
		titleLbl.Font                   = Enum.Font.GothamBold
		titleLbl.TextSize               = 12
		titleLbl.TextXAlignment         = Enum.TextXAlignment.Left
		titleLbl.Parent                 = frame

		local msgLbl = Instance.new("TextLabel")
		msgLbl.Size                   = UDim2.new(1, -20, 0, 26)
		msgLbl.Position               = UDim2.new(0, 10, 0, 29)
		msgLbl.BackgroundTransparency = 1
		msgLbl.Text                   = msg
		msgLbl.TextColor3             = Col.TextSecondary
		msgLbl.Font                   = Enum.Font.Gotham
		msgLbl.TextSize               = 11
		msgLbl.TextWrapped            = true
		msgLbl.TextXAlignment         = Enum.TextXAlignment.Left
		msgLbl.TextYAlignment         = Enum.TextYAlignment.Top
		msgLbl.Parent                 = frame

		local progBg = Instance.new("Frame")
		progBg.Size             = UDim2.new(1, -20, 0, 2)
		progBg.Position         = UDim2.new(0, 10, 1, -6)
		progBg.BackgroundColor3 = Col.Border
		progBg.BorderSizePixel  = 0
		progBg.Parent           = frame
		Instance.new("UICorner", progBg).CornerRadius = UDim.new(0, 1)

		local progFill = Instance.new("Frame")
		progFill.Size             = UDim2.new(1, 0, 1, 0)
		progFill.BackgroundColor3 = Col.Accent
		progFill.BorderSizePixel  = 0
		progFill.Parent           = progBg
		Instance.new("UICorner", progFill).CornerRadius = UDim.new(0, 1)

		frame.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				Dismiss(frame)
			end
		end)

		table.insert(Axon.Notify._active, frame)

		frame:TweenPosition(
			UDim2.new(1, -NOTIF_W - 16, 0, SlotY(slot)),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quart,
			ANIM_TIME,
			true
		)

		Axon.UI.Tween(progFill, { Size = UDim2.new(0, 0, 1, 0) }, dur, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)

		task.delay(dur, function()
			if frame and frame.Parent then Dismiss(frame) end
		end)
	end

	Axon.Notify.Send = function(opts)
		pcall(function()
			if Axon.Settings.Data.notifDisabled then return end
			opts = opts or {}
			local title    = opts.title    or "Notification"
			local msg      = opts.message  or ""
			local dur      = opts.duration or (Axon.Settings.Data.notifDuration or 5)
			local maxSlots = Axon.Settings.Data.notifMax or NOTIF_MAX

			if #Axon.Notify._active < maxSlots and not _evicting then
				SpawnCard(title, msg, dur)
			elseif #Axon.Notify._active >= maxSlots and not _evicting then
				_evicting = true
				Dismiss(Axon.Notify._active[1], function()
					_evicting = false
					SpawnCard(title, msg, dur)
				end)
			end
			-- if _evicting is true, drop silently — tween still in progress
		end)
	end

	table.insert(Axon._cleanupFns, function()
		pcall(function()
			if notifGui and notifGui.Parent then
				notifGui:Destroy()
			end
		end)
		Axon.Notify._active = {}
	end)
end

