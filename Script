			if Axon.Settings.Data.miscNoSit then
				h:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
			end
		end

		-- ── AutoRotate (Backpack / Orbit / Fling / FaceBang set it false) ─
		if (wasBackpacking or wasOrbiting or wasFlinging or wasFaceBanging) and h then
			h.AutoRotate = true
		end

		-- ── PlatformStand (Orbit / Fling / FaceBang set it true) ─
		if (wasOrbiting or wasFlinging or wasFaceBanging) and h then
			h.PlatformStand = false
