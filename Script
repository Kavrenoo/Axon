	local function RefreshFriendSearch()
		local raw   = friendSearchBox.Text:lower():gsub("^@", "")
		local count = 0
		for _, child in ipairs(friendListHolder:GetChildren()) do
			if child:IsA("Frame") then
				local labels = {}
				for _, lbl in ipairs(child:GetChildren()) do
					if lbl:IsA("TextLabel") then table.insert(labels, lbl.Text:lower()) end
				end
				local visible = raw == "" or (function()
					for _, t in ipairs(labels) do
						if t:find(raw, 1, true) then return true end
					end
				end)()
				child.Visible = visible ~= nil and visible ~= false
				if child.Visible then count = count + 1 end
			end
		end
		if count > 0 then
			friendListScroll.Size = UDim2.new(1, -6, 0, math.min(count, 5) * 48 - 4 + 8)
