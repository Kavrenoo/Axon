				invisBindBtn.Text = "Bind Key"
			end
		end
		UpdateInvisDesc()

		invisHit.MouseButton1Click:Connect(function()
			if Char.invisOn then EndInvis(); SetInvisVisual(false)
			else BeginInvis(); SetInvisVisual(true) end
		end)
		Char.guiToggleInvis = function()
			if Char.invisOn then EndInvis(); SetInvisVisual(false)
			else BeginInvis(); SetInvisVisual(true) end
		end

		invisBindBtn.MouseButton1Click:Connect(function()
			if Char.invisCaptureConn then Char.invisCaptureConn:Disconnect(); Char.invisCaptureConn = nil end
			if Char.invisKeyConn     then Char.invisKeyConn:Disconnect();     Char.invisKeyConn     = nil end
			Char.invisCapturing = true
			invisBindBtn.Text = "Press Key..."; invisBindBtn.TextColor3 = Axon.UI.Colors.Accent
			Char.invisCaptureConn = Axon.Services.UserInputService.InputBegan:Connect(function(input, gpe)
				if gpe or not Char.invisCapturing then return end
				if input.UserInputType == Enum.UserInputType.Keyboard then
					Char.invisCapturing = false
					Char.invisCaptureConn:Disconnect(); Char.invisCaptureConn = nil
					invisBindBtn.TextColor3 = Axon.UI.Colors.TextSecondary
					if input.KeyCode == Enum.KeyCode.Backspace then
						Char.invisKey = nil
						Axon.Settings.Data.charInvisKey = ""; Axon.Settings.Save()
					else
						Char.invisKey = input.KeyCode
						Axon.Settings.Data.charInvisKey = Char.invisKey.Name; Axon.Settings.Save()
						EnableInvisKeyListener()
					end
					UpdateInvisDesc()
				elseif input.UserInputType == Enum.UserInputType.MouseButton1
					or input.UserInputType == Enum.UserInputType.MouseButton2
					or input.UserInputType == Enum.UserInputType.MouseButton3 then
					Char.invisKey = nil; Char.invisCapturing = false
					Char.invisCaptureConn:Disconnect(); Char.invisCaptureConn = nil
					invisBindBtn.TextColor3 = Axon.UI.Colors.TextSecondary
					Axon.Settings.Data.charInvisKey = ""; Axon.Settings.Save()
					UpdateInvisDesc()
				end
			end)
		end)

		-- Cleanup on unload
		table.insert(Axon._cleanupFns, function()
			pcall(EndInvis)
			if Char.invisKeyConn     then pcall(function() Char.invisKeyConn:Disconnect()     end); Char.invisKeyConn     = nil end
			if Char.invisCaptureConn then pcall(function() Char.invisCaptureConn:Disconnect() end); Char.invisCaptureConn = nil end
		end)
		-- Register with global search
		Axon.Search.Register({ label="Invisibility", desc="Turn your character invisible — bind a key to toggle", page="Character", section="Character", row=invisRow })
	end

