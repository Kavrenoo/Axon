	local function StopAll(keepTool)
		-- Snapshot which actions were active BEFORE we clear the flags,
		-- so each cleanup block only runs for things that were actually on.
		local wasViewing      = T.Viewing
		local wasFocusing     = T.Focusing
		local wasHeadsitting  = T.Headsitting
		local wasBackpacking  = T.Backpacking
		local wasOrbiting     = T.Orbiting
		local wasFlinging     = T.Flinging
		local wasFaceBanging  = T.FaceBanging
		local wasStanding     = T.Standing
		local wasDogging      = T.Dogging
		local wasDragging     = T.Dragging
		local wasBanging      = T.Banging
		local hadAnimTrack    = T._animTrack ~= nil
		local flingCF         = T._flingOldCF

		-- ── Disconnect all heartbeat connections ──────────────────
		for _, key in ipairs({
			"_viewConn","_focusConn","_headsitConn","_backConn","_orbitConn",
			"_flingConn","_faceBangConn","_standConn","_dogConn","_dragConn",
			"_bangConn"
		}) do
			if T[key] then T[key]:Disconnect(); T[key] = nil end
		end

		-- ── Clear state flags ─────────────────────────────────────
		T.Viewing = false; T.Focusing = false; T.Headsitting = false
		T.Backpacking = false; T.Orbiting = false; T.Flinging = false
		T.FaceBanging = false; T.Standing = false; T.Dogging = false
		T.Dragging = false; T.Banging = false
		T._flingOldCF = nil

		-- ── Stop keybind face-bang loop if it was running ─────────
		if FBKey and FBKey.active then StopFBKey() end

		-- ── Dim all action buttons ────────────────────────────────
		for key in pairs(ActionBtns) do SetBtnActive(key, false) end

		local char = PLR.Character
		local h    = char and char:FindFirstChildOfClass("Humanoid")
		local root = MyRoot()

		-- ── Animation track (Standing / Dogging / Dragging / Banging / direct plays) ─
		if hadAnimTrack and T._animTrack then
			pcall(function() T._animTrack:Stop() end)
			T._animTrack = nil
		end

		-- ── Animate script re-enable (Orbit / FaceBang / Stand / Doggy / Drag disabled it) ─
		if wasOrbiting or wasFaceBanging or wasStanding or wasDogging or wasDragging then
			local animScript = char and char:FindFirstChild("Animate")
			if animScript then animScript.Disabled = false end
		end

		-- ── BodyVelocity used to pin root (Headsit / Backpack / Fling) ──
		if wasHeadsitting or wasBackpacking or wasFlinging then
			RemoveBV(root)
		end

		-- ── PoseBV used for positional lock (Stand / Doggy / Drag / Bang) ─
		if wasStanding or wasDogging or wasDragging or wasBanging then
			RemovePoseBV(root)
		end

		-- ── FaceBang's own separate BV ("AxonFBVel") ─────────────
		if wasFaceBanging and root then
			local bv = root:FindFirstChild("AxonFBVel")
			if bv then bv:Destroy() end
		end

		-- ── Sit state (Headsit / Backpack both force h.Sit = true) ─
