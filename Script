	-- ── Face Bang Keybind functions (defined after MakeSlider so GetFBDist/GetFBSpeed exist) ──
	GetNearestPlayer = function()
		local myRoot = MyRoot(); if not myRoot then return nil end
		local nearest, nearDist = nil, math.huge
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= PLR then
				local root = GetRoot(plr)
				if root then
					local dist = (root.Position - myRoot.Position).Magnitude
					if dist < nearDist then nearDist = dist; nearest = plr end
				end
			end
		end
		return nearest
	end

	StopFBKey = function()
		FBKey.active = false
		if FBKey.conn then FBKey.conn:Disconnect(); FBKey.conn = nil end
		-- clean up BV immediately rather than waiting for the loop to wind down
		local r = MyRoot()
		if r then local bv = r:FindFirstChild("AxonFBKeyVel"); if bv then bv:Destroy() end end
		local myChar = PLR.Character
		if myChar then
			local mh = myChar:FindFirstChildOfClass("Humanoid")
			if mh then mh.AutoRotate = true; mh.PlatformStand = false end
			local as = myChar:FindFirstChild("Animate")
			if as then as.Disabled = false end
		end
	end

	StartFBKey = function()
		if FBKey.active then return end
		local nearPlr = GetNearestPlayer(); if not nearPlr then return end
		local char = PLR.Character; if not char then return end
		local h = char:FindFirstChildOfClass("Humanoid")
		local myRoot = MyRoot()
		if not h or not myRoot then return end
		FBKey.active = true
		h.AutoRotate = false; h.PlatformStand = true
		local animScript = char:FindFirstChild("Animate")
		if animScript then animScript.Disabled = true end
		for _, track in ipairs(h:GetPlayingAnimationTracks()) do track:Stop() end
		FBKey.conn = RS.Heartbeat:Connect(function() end)
		task.spawn(function()
			local t = 0
			while FBKey.active do
				pcall(function()
					local r = MyRoot(); if not r then return end
					local bv = r:FindFirstChild("AxonFBKeyVel")
					if not bv then
						bv = Instance.new("BodyVelocity")
						bv.Name = "AxonFBKeyVel"; bv.MaxForce = Vector3.new(1e9, 1e9, 1e9)
						bv.Velocity = Vector3.zero; bv.Parent = r
					end
					local tChar = nearPlr.Character
					local head  = tChar and tChar:FindFirstChild("Head")
					if head then
						local dist    = GetFBDist()
						local offsetZ = math.sin(t * GetFBSpeed()) * dist
						r.CFrame = head.CFrame
							* CFrame.new(0, 1, -(dist + 0.7) + offsetZ)
							* CFrame.Angles(0, math.rad(180), 0)
						r.AssemblyLinearVelocity = Vector3.zero
					end
				end)
				t = t + task.wait()
			end
			if FBKey.conn then FBKey.conn:Disconnect(); FBKey.conn = nil end
			local r = MyRoot()
			if r then local bv = r:FindFirstChild("AxonFBKeyVel"); if bv then bv:Destroy() end end
			local myChar = PLR.Character
			if myChar then
				local mh = myChar:FindFirstChildOfClass("Humanoid")
				if mh then mh.AutoRotate = true; mh.PlatformStand = false end
				local as = myChar:FindFirstChild("Animate")
				if as then as.Disabled = false end
			end
		end)
	end

	FBKeyEnableGlobal = function()
		if FBKey.globalConn then return end
		FBKey.globalConn = Axon.Services.UserInputService.InputBegan:Connect(function(input, gpe)
			if Axon._loading then return end
			if gpe or FBKey.capturing then return end
			if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
			if input.KeyCode ~= FBKey.key then return end
			if FBKey.style == "Toggle" then
				if FBKey.active then StopFBKey() else StartFBKey() end
			else
				FBKey.keyHeld = true
				if not FBKey.active then StartFBKey() end
			end
		end)
		if FBKey.globalEndConn then FBKey.globalEndConn:Disconnect(); FBKey.globalEndConn = nil end
		FBKey.globalEndConn = Axon.Services.UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Keyboard
				and input.KeyCode == FBKey.key
			then
				FBKey.keyHeld = false
				if FBKey.style == "Hold" then StopFBKey() end
			end
		end)
	end

