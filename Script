	-- ── Slider factory ────────────────────────────────────────
	local function MakeSlider(parent, label, layoutOrder, vMin, vMax, vDef, isFloat, saveKey)
		local savedVal   = saveKey and Axon.Settings.Data[saveKey]
		local currentVal = (type(savedVal) == "number") and savedVal or vDef

		local row = UI.New("Frame", {
			Size = UDim2.new(1, 0, 0, 62), BackgroundColor3 = Col.Section,
			BorderSizePixel = 0, LayoutOrder = layoutOrder, Parent = parent,
		}, { UI.Corner(6), UI.Stroke(Col.Border, 1) })
		UI.New("TextLabel", {
			Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 12, 0, 8),
			BackgroundTransparency = 1, Text = label,
			TextColor3 = Col.TextPrimary, Font = Enum.Font.GothamSemibold,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
		})
		local valLbl = UI.New("TextLabel", {
			Size = UDim2.new(0, 70, 0, 20), Position = UDim2.new(1, -82, 0, 8),
			BackgroundTransparency = 1,
			Text = isFloat and string.format("%.1f", currentVal) or tostring(currentVal),
			TextColor3 = Col.Accent, Font = Enum.Font.GothamBold,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right, Parent = row,
		})
		local track = UI.New("Frame", {
			Size = UDim2.new(1, -24, 0, 4), Position = UDim2.new(0, 12, 0, 40),
			BackgroundColor3 = Col.SliderTrack, BorderSizePixel = 0, Parent = row,
		}, { UI.Corner(2) })
		local initRatio = math.clamp((currentVal - vMin) / (vMax - vMin), 0, 1)
		local fill = UI.New("Frame", {
			Size = UDim2.new(initRatio, 0, 1, 0),
			BackgroundColor3 = Col.SliderFill, BorderSizePixel = 0, Parent = track,
		}, { UI.Corner(2) })
		local knob = UI.New("Frame", {
			Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(initRatio, -6, 0.5, -6),
			BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0, ZIndex = 2, Parent = track,
		}, { UI.Corner(6) })

		local function SetVal(v, isReset, skipSave)
			if isFloat then
				v = math.clamp(math.round(v * 10) / 10, vMin, vMax)
			else
				v = math.clamp(math.round(v), vMin, vMax)
			end
			currentVal = v
			local ratio   = (v - vMin) / (vMax - vMin)
			fill.Size     = UDim2.new(ratio, 0, 1, 0)
			knob.Position = UDim2.new(ratio, -6, 0.5, -6)
			valLbl.Text   = isFloat and string.format("%.1f", v) or tostring(v)
			if saveKey and not skipSave then Axon.Settings.Data[saveKey] = v; Axon.Settings.Save() end
			if isReset then
				fill.BackgroundColor3 = Color3.new(1, 1, 1)
				task.delay(0.12, function() UI.Tween(fill, { BackgroundColor3 = Col.SliderFill }, 0.2) end)
			end
		end
		SetVal(currentVal, false, true)

		local dragging  = false
		local lastClick = 0
		local hit = UI.New("TextButton", {
			Size = UDim2.new(1, -24, 0, 28), Position = UDim2.new(0, 12, 0, 28),
			BackgroundTransparency = 1, Text = "", ZIndex = 5, Parent = row,
		})
		hit.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				local now = tick()
				if now - lastClick < 0.35 then SetVal(vDef, true); lastClick = 0; dragging = false; return end
				lastClick = now; dragging = true
				local ratio = math.clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				SetVal(vMin + (vMax - vMin) * ratio)
			end
		end)
		local _msChangedConn = Axon.Services.UserInputService.InputChanged:Connect(function(inp)
			if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
				local ratio = math.clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				SetVal(vMin + (vMax - vMin) * ratio)
			end
		end)
		local _msEndedConn = Axon.Services.UserInputService.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
		end)
		table.insert(Axon._cleanupFns, function()
			if _msChangedConn then _msChangedConn:Disconnect(); _msChangedConn = nil end
			if _msEndedConn   then _msEndedConn:Disconnect();   _msEndedConn   = nil end
		end)

		local inputOpen = false
		local function OpenInput()
			if inputOpen then return end; inputOpen = true
			Axon.UI.Tween(row, { BackgroundColor3 = Col.ActiveItem }, 0.1)
			local overlay = UI.New("Frame", {
				Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Col.Section,
				BorderSizePixel = 0, ZIndex = 20,
			}, { UI.Corner(6) })
			overlay.Parent = row
			local rangeStr = isFloat
				and (tostring(vMin) .. " – " .. tostring(vMax))
				or  (tostring(math.floor(vMin)) .. " – " .. tostring(math.floor(vMax)))
			UI.New("TextLabel", {
				Size = UDim2.new(1, -120, 1, 0), Position = UDim2.new(0, 12, 0, 0),
				BackgroundTransparency = 1, Text = label .. "  (" .. rangeStr .. ")",
				TextColor3 = Col.TextSecondary, Font = Enum.Font.Gotham,
				TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left,
				ZIndex = 21, Parent = overlay,
			})
			local box = UI.New("TextBox", {
				Size = UDim2.new(0, 90, 0, 26), Position = UDim2.new(1, -104, 0.5, -13),
				BackgroundColor3 = Col.SliderTrack,
				Text = isFloat and string.format("%.1f", currentVal) or tostring(currentVal),
				TextColor3 = Col.TextPrimary, Font = Enum.Font.GothamBold, TextSize = 13,
				ClearTextOnFocus = true, BorderSizePixel = 0, ZIndex = 21,
			}, { UI.Corner(6), UI.Stroke(Col.Accent, 1) })
			box.Parent = overlay
			local confirmed = false; task.wait(); box:CaptureFocus()
			local function Confirm()
				if confirmed then return end; confirmed = true
				local num = tonumber(box.Text)
				if num then SetVal(num) else SetVal(vDef, true) end
				if overlay.Parent then overlay:Destroy() end
				Axon.UI.Tween(row, { BackgroundColor3 = Col.Section }, 0.1)
				inputOpen = false
			end
			box.FocusLost:Connect(Confirm); task.wait(); task.wait()
			local outsideConn
			outsideConn = Axon.Services.UserInputService.InputBegan:Connect(function(inp)
				if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				local mouse = Axon.Services.UserInputService:GetMouseLocation()
				local abs   = overlay.AbsolutePosition
				local size  = overlay.AbsoluteSize
				if not (mouse.X >= abs.X and mouse.X <= abs.X + size.X
					and mouse.Y >= abs.Y and mouse.Y <= abs.Y + size.Y) then
					outsideConn:Disconnect(); box:ReleaseFocus(); Confirm()
				end
			end)
		end
		hit.MouseButton2Click:Connect(OpenInput)
		return function() return currentVal end
	end

