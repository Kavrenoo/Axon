	local function AssignLayoutOrders()
		local sorted = {}
		for uid, data in pairs(playerCache) do
			if data.player and data.player.Parent then
				table.insert(sorted, data)
			end
		end
		table.sort(sorted, function(a, b)
			local aF = a.isFriend == true
			local bF = b.isFriend == true
			if aF ~= bF then return aF end
			return a.player.Name:lower() < b.player.Name:lower()
		end)
		for order, data in ipairs(sorted) do
			local row = playerBtns[data.player.UserId]
			if row then row.LayoutOrder = order end
		end
	end

	local function UpdateListSize()
		if not listScroll then return end
		local count = 0
		for _, row in pairs(playerBtns) do
			if row and row.Parent and row.Visible then count = count + 1 end
		end
		if count == 0 then
			listScroll.Size = UDim2.new(1, -6, 0, 0)
		else
			listScroll.Size = UDim2.new(1, -6, 0, math.min(count, MAX_ROWS) * (ROW_H + 4) - 4 + 4)
		end
	end

