			Axon._origVoidY = nil
		end
		-- Remove walk-on-air platform if still present
		local wap = workspace:FindFirstChild("AxonWalkAirPlatform")
		if wap then pcall(function() wap:Destroy() end) end
		-- Restore humanoid
		local playerChar = Axon.Services.Player.Character
		if playerChar then
			local h   = playerChar:FindFirstChildOfClass("Humanoid")
			local root = playerChar:FindFirstChild("HumanoidRootPart")
			if h then
				pcall(function()
					h.WalkSpeed     = WALK_DEF
					h.JumpPower     = JUMP_DEF
					h.UseJumpPower  = true
					h.PlatformStand = false
					h.AutoRotate    = true
					h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,     true)
					h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
				end)
			end
			if root then
				pcall(function()
					for _, name in ipairs({"AxonFlyBG","AxonFlyBV","AxonTargBV","AxonPoseBV","AxonSpin"}) do
						local obj = root:FindFirstChild(name)
						if obj then obj:Destroy() end
					end
					local runSound = root:FindFirstChild("Running")
					if runSound then runSound.Volume = 0.5 end
				end)
			end
			-- Re-enable CanCollide on all parts if noclip was active
			if Axon.Settings.Data.charNoclip then
				for _, part in ipairs(playerChar:GetDescendants()) do
					if part:IsA("BasePart") then pcall(function() part.CanCollide = true end) end
				end
			end
		end
		-- Restore FOV and gravity to their pre-script values
		pcall(function() workspace.CurrentCamera.FieldOfView = FOV_DEF end)
		pcall(function() workspace.Gravity = GRAV_DEF end)
		-- Remove all registered tools (teleport, jerk, target, etc.)
		for _, t in pairs(Axon._tools) do
			if t.on and t.remove then
				pcall(t.remove)
				t.on        = false
				t.enabledAt = 0
			end
		end
	end)
	Axon._char = Char
end

