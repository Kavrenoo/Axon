-- ── Accent color applicator ───────────────────────────────

Axon.UI.SetAccentColor = function(newAccent)
	local Col = Axon.UI.Colors
	local oldAccent     = Col.Accent
	local oldAccentDark = Col.AccentDark

	local newDark = Color3.new(
		newAccent.R * 0.45,
		newAccent.G * 0.45,
		newAccent.B * 0.55
	)

	Col.Accent     = newAccent
	Col.AccentDark = newDark
	Col.ToggleOn   = newAccent
	Col.SliderFill = newAccent

	local function Match(c1, c2)
		return math.abs(c1.R - c2.R) < 0.012
			and math.abs(c1.G - c2.G) < 0.012
			and math.abs(c1.B - c2.B) < 0.012
	end

	for _, inst in ipairs(Axon.UI.ScreenGui:GetDescendants()) do
		if not inst:GetAttribute("_noRecolor") then
			pcall(function()
				if inst.BackgroundColor3 ~= nil then
					if Match(inst.BackgroundColor3, oldAccent) then
						inst.BackgroundColor3 = newAccent
					elseif Match(inst.BackgroundColor3, oldAccentDark) then
						inst.BackgroundColor3 = newDark
					end
				end
			end)
			pcall(function()
				if inst.TextColor3 ~= nil then
					if Match(inst.TextColor3, oldAccent) then
						inst.TextColor3 = newAccent
					elseif Match(inst.TextColor3, oldAccentDark) then
						inst.TextColor3 = newDark
					end
				end
			end)
			pcall(function()
				if inst.ScrollBarImageColor3 ~= nil then
					if Match(inst.ScrollBarImageColor3, oldAccent) then
						inst.ScrollBarImageColor3 = newAccent
					end
				end
			end)
			pcall(function()
				if inst:IsA("UIStroke") and Match(inst.Color, oldAccent) then
					inst.Color = newAccent
				end
			end)
		end
	end

	Axon.Settings.Data.accentColor = {
		math.round(newAccent.R * 255),
		math.round(newAccent.G * 255),
		math.round(newAccent.B * 255),
	}
	Axon.Settings.Save()
end

