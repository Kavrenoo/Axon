-- ── Auto-register every labelled component ────────────────

local function _wrapSearchReg(fn)
	return function(parent, cfg)
		local results = table.pack(fn(parent, cfg))
		local row = results[1]
		if row and cfg and cfg.label and Axon.Search._curPage then
			Axon.Search.Register({
				label   = cfg.label,
				desc    = cfg.desc or "",
				page    = Axon.Search._curPage,
				section = Axon.Search._curSection or "",
				row     = row,
			})
		end
		return table.unpack(results, 1, results.n)
	end
end

