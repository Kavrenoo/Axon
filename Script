	local WOA = { enabled = false, platform = nil, baseY = 0, up = false, down = false, renderConn = nil }
	local function WOA_Destroy()
		if WOA.renderConn then WOA.renderConn:Disconnect(); WOA.renderConn = nil end
		if WOA.platform then WOA.platform:Destroy(); WOA.platform = nil end
		WOA.enabled = false; WOA.up = false; WOA.down = false
	end
	local function WOA_Create()
		local h, root = GetHR(); if not root then return end
		local hipH = h and h.HipHeight or 2.3
		local isR6 = h and h.RigType == Enum.HumanoidRigType.R6
		-- platform top = WOA.baseY + 0.5 (part Size.Y=5, center = WOA.baseY - 2), player HRP = top + hipH
