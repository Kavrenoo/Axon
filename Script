	}, { Axon.UI.Corner(11) })
	pill.Parent = row
	local knob = Axon.UI.New("Frame", {
		Size = UDim2.new(0, 16, 0, 16),
		Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
		BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0,
	}, { Axon.UI.Corner(8) })
