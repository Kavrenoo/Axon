-- ── Local Mute chat commands ──────────────────────────────
-- Commands: 'mute <name>  'unmute <name|all>  'muteall
-- All mutes are purely client-side (AudioEmitter.Volume = 0 on HumanoidRootPart).
do
	local C = Axon.ChatCommands
	if C then
		local _mutedPlayers = {}  -- [userId] = AudioEmitter | true

		-- AudioDeviceInput sits directly on the Player instance (not the character)
		local function FindAudioInput(player)
			return player:FindFirstChildOfClass("AudioDeviceInput")
		end

		-- Partial, case-insensitive name match (excludes local player)
		local function FindPlayer(namePart)
			namePart = namePart:lower()
			for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
				if p ~= Axon.Services.Player and (p.Name:lower():find(namePart, 1, true) or p.DisplayName:lower():find(namePart, 1, true)) then
					return p
				end
			end
			return nil
		end

		-- Re-applies mute after a player respawns with a fresh character
		local function HookRespawn(player)
			player.CharacterAdded:Connect(function()
				if _mutedPlayers[player.UserId] then
					local adi = FindAudioInput(player)
					if adi then
						adi.Muted = true
						_mutedPlayers[player.UserId] = adi
					end
				end
			end)
		end

		-- Hook all players currently in the server
		for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
			if p ~= Axon.Services.Player then HookRespawn(p) end
		end
		-- Hook players who join later
		local _muteJoinConn = Axon.Services.Players.PlayerAdded:Connect(function(p)
			HookRespawn(p)
		end)

		-- 'mute <name>  /  'm <name>
		C["mute"] = function(args)
			local name = args[1]
			if not name then
				Axon.Notify.Send({ title = "Mute", message = "Usage: 'mute <playername>", duration = 4 })
				return
			end
			local target = FindPlayer(name)
			if not target then
				Axon.Notify.Send({ title = "Mute", message = "Player not found: " .. name, duration = 4 })
				return
			end
			if _mutedPlayers[target.UserId] then
				Axon.Notify.Send({ title = "Mute", message = target.Name .. " is already muted", duration = 3 })
				return
			end
			Axon._VoiceMute(target)
			Axon.Notify.Send({ title = "Mute", message = "Muted " .. target.Name, duration = 4 })
		end
		C["m"] = C["mute"]

		-- 'unmute <name|all>  /  'um <name|all>
		C["unmute"] = function(args)
			local name = args[1]
			if not name then
				Axon.Notify.Send({ title = "Unmute", message = "Usage: 'unmute <playername> or 'unmute all", duration = 4 })
				return
			end
			if name:lower() == "all" then
				local count = 0
				for _, adi in pairs(_mutedPlayers) do
					if type(adi) ~= "boolean" then
						pcall(function() adi.Muted = false end)
					end
					count = count + 1
				end
				_mutedPlayers = {}
				if Axon._VoiceRefreshMuteBtn then
					for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
						Axon._VoiceRefreshMuteBtn(p)
					end
				end
				Axon.Notify.Send({ title = "Unmute", message = "Unmuted " .. count .. " player(s)", duration = 4 })
				return
			end
			local target = FindPlayer(name)
			if not target then
				Axon.Notify.Send({ title = "Unmute", message = "Player not found: " .. name, duration = 4 })
				return
			end
			if not _mutedPlayers[target.UserId] then
				Axon.Notify.Send({ title = "Unmute", message = target.Name .. " is not muted", duration = 4 })
				return
			end
			Axon._VoiceUnmute(target)
			Axon.Notify.Send({ title = "Unmute", message = "Unmuted " .. target.Name, duration = 4 })
		end
		C["um"] = C["unmute"]

		-- 'muteall  /  'ma
		C["muteall"] = function()
			local count = 0
			for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
				if p ~= Axon.Services.Player and not _mutedPlayers[p.UserId] then
					Axon._VoiceMute(p)
					count = count + 1
				end
			end
			Axon.Notify.Send({ title = "Mute All", message = "Muted " .. count .. " player(s)", duration = 4 })
		end
		C["ma"] = C["muteall"]

		-- Expose mute API so the Target page button can reach it
		Axon._VoiceIsMuted = function(userId)
			return _mutedPlayers[userId] ~= nil
		end

		Axon._VoiceMute = function(player)
			if not player or _mutedPlayers[player.UserId] then return end
			local adi = player:FindFirstChildOfClass("AudioDeviceInput")
			if adi then
				pcall(function() adi.Muted = true end)
				_mutedPlayers[player.UserId] = adi
			else
				_mutedPlayers[player.UserId] = true
			end
		end

		Axon._VoiceUnmute = function(player)
			if not player then return end
			local adi = _mutedPlayers[player.UserId]
			if not adi then return end
			if type(adi) ~= "boolean" then
				pcall(function() adi.Muted = false end)
			else
				local live = player:FindFirstChildOfClass("AudioDeviceInput")
				if live then pcall(function() live.Muted = false end) end
			end
			_mutedPlayers[player.UserId] = nil
			if Axon._VoiceRefreshMuteBtn then Axon._VoiceRefreshMuteBtn(player) end
		end

		-- Cleanup: restore all mutes and disconnect hooks on unload
		table.insert(Axon._cleanupFns, function()
			for _, adi in pairs(_mutedPlayers) do
				if type(adi) ~= "boolean" then
					pcall(function() adi.Muted = false end)
				end
			end
			_mutedPlayers = {}
			pcall(function() _muteJoinConn:Disconnect() end)
		end)
	end
end

-- ── Local Hide chat commands ───────────────────────────────
-- Commands: 'hide <name>  'unhide <name|all>  'hideall
-- Hides a player's voice audio, overhead name/display, particles, and audio emitters.
-- All changes are purely client-side.
do
	local C = Axon.ChatCommands
	if C then
		local _hiddenPlayers = {}  -- [userId] = { charConn, cleanup }

		-- Partial, case-insensitive name match (excludes local player)
		local function FindPlayer(namePart)
			namePart = namePart:lower()
			for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
				if p ~= Axon.Services.Player and (p.Name:lower():find(namePart, 1, true) or p.DisplayName:lower():find(namePart, 1, true)) then
					return p
				end
			end
			return nil
		end

		-- Per-userId saved state
		local _savedState = {}  -- [userId] = { transparency, sounds, lights, hum }

		-- Helper: is a descendant part of a given character?
		local function IsInChar(inst, char)
			local p = inst
			while p do
				if p == char then return true end
				p = p.Parent
			end
			return false
		end

		-- Apply all hiding effects to a character model
		local function ApplyHideToCharacter(char, userId)
			if not char then return end

			-- 1) Save + suppress overhead name & health bar
			local hum = char:FindFirstChildOfClass("Humanoid")
			local savedHum = {}
			if hum then
				pcall(function()
					savedHum.displayDistType  = hum.DisplayDistanceType
					savedHum.healthDist       = hum.HealthDisplayDistance
					savedHum.nameDist         = hum.NameDisplayDistance
					hum.DisplayDistanceType   = Enum.HumanoidDisplayDistanceType.None
					hum.HealthDisplayDistance = 0
					hum.NameDisplayDistance   = 0
				end)
			end

			-- 2) Hide BillboardGuis on the character (custom name tags etc.)
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("BillboardGui") then
					pcall(function() desc.Enabled = false end)
				end
			end

			-- 3) Disable particle-type effects: ParticleEmitter, Fire, Sparkles, Smoke
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("ParticleEmitter") or desc:IsA("Fire")
					or desc:IsA("Sparkles") or desc:IsA("Smoke") then
					pcall(function() desc.Enabled = false end)
				end
			end

			-- 4) Disable Beam and Trail (wings, jewelry, movement trails)
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("Beam") or desc:IsA("Trail") then
					pcall(function() desc.Enabled = false end)
				end
			end

			-- 5) Save + zero all Lights (PointLight, SpotLight, SurfaceLight)
			local savedLights = {}
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("PointLight") or desc:IsA("SpotLight") or desc:IsA("SurfaceLight") then
					pcall(function()
						savedLights[desc] = desc.Brightness
						desc.Brightness = 0
					end)
				end
			end

			-- 6) Silence AudioEmitters
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("AudioEmitter") then
					pcall(function() desc.Volume = 0 end)
				end
			end

			-- 7) Save + silence all Sound objects (footsteps, Witch's Brew, accessory sfx)
			local savedSounds = {}
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("Sound") then
					pcall(function()
						savedSounds[desc] = desc.Volume
						desc.Volume = 0
					end)
				end
			end

			-- 8) Save + make all BaseParts, Decals and Textures fully transparent
			local savedT = {}
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("BasePart") or desc:IsA("Decal") or desc:IsA("Texture") then
					pcall(function()
						savedT[desc] = desc.Transparency
						desc.Transparency = 1
					end)
				end
			end

			if userId then
				_savedState[userId] = {
					transparency = savedT,
					sounds       = savedSounds,
					lights       = savedLights,
					hum          = savedHum,
				}
			end
		end

		-- Restore all effects on a character model
		local function RestoreCharacter(char, userId)
			if not char then return end
			local state = userId and _savedState[userId]

			-- 1) Restore humanoid display settings
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then
				pcall(function()
					local h = state and state.hum
					hum.DisplayDistanceType   = (h and h.displayDistType) or Enum.HumanoidDisplayDistanceType -- REMOVED .Automatic OR SOMETHING LIKE THAT DUE TO NOT WORKING WITH VELOCITY
					hum.HealthDisplayDistance = (h and h.healthDist)      or 100
					hum.NameDisplayDistance   = (h and h.nameDist)        or 100
				end)
			end

			-- 2) Re-enable BillboardGuis
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("BillboardGui") then
					pcall(function() desc.Enabled = true end)
				end
			end

			-- 3) Re-enable particle-type effects
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("ParticleEmitter") or desc:IsA("Fire")
					or desc:IsA("Sparkles") or desc:IsA("Smoke") then
					pcall(function() desc.Enabled = true end)
				end
			end

			-- 4) Re-enable Beam and Trail
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("Beam") or desc:IsA("Trail") then
					pcall(function() desc.Enabled = true end)
				end
			end

			-- 5) Restore light brightness
			local savedLights = state and state.lights
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("PointLight") or desc:IsA("SpotLight") or desc:IsA("SurfaceLight") then
					pcall(function()
						desc.Brightness = (savedLights and savedLights[desc] ~= nil) and savedLights[desc] or 1
					end)
				end
			end

			-- 6) Restore AudioEmitter volumes
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("AudioEmitter") then
					pcall(function() desc.Volume = 1 end)
				end
			end

			-- 7) Restore Sound volumes
			local savedSounds = state and state.sounds
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("Sound") then
					pcall(function()
						desc.Volume = (savedSounds and savedSounds[desc] ~= nil) and savedSounds[desc] or 1
					end)
				end
			end

			-- 8) Restore part/decal transparencies
			local savedT = state and state.transparency
			for _, desc in ipairs(char:GetDescendants()) do
				if desc:IsA("BasePart") or desc:IsA("Decal") or desc:IsA("Texture") then
					pcall(function()
						desc.Transparency = (savedT and savedT[desc] ~= nil) and savedT[desc] or 0
					end)
				end
			end

			if userId then _savedState[userId] = nil end
		end

		-- CoreGui bubble-chat watcher: hides chat bubbles that Roblox renders outside the character
		local function HookBubbleChat(char, uid)
			local CoreGui = game:GetService("CoreGui")
			return CoreGui.DescendantAdded:Connect(function(desc)
				if not _hiddenPlayers[uid] then return end
				pcall(function()
					if desc:IsA("BillboardGui") then
						-- Bubble chat BillboardGuis are adornee'd to a part in the character
						if desc.Adornee and IsInChar(desc.Adornee, char) then
							desc.Enabled = false
						end
					end
				end)
			end)
		end

		-- Also hide any bubble BillboardGuis already present in CoreGui at hide-time
		local function SuppressExistingBubbles(char)
			local CoreGui = game:GetService("CoreGui")
			pcall(function()
				for _, desc in ipairs(CoreGui:GetDescendants()) do
					if desc:IsA("BillboardGui") and desc.Adornee and IsInChar(desc.Adornee, char) then
						desc.Enabled = false
					end
				end
			end)
		end

		-- Restore any bubble BillboardGuis in CoreGui for this character
		local function RestoreBubbles(char)
			local CoreGui = game:GetService("CoreGui")
			pcall(function()
				for _, desc in ipairs(CoreGui:GetDescendants()) do
					if desc:IsA("BillboardGui") and desc.Adornee and IsInChar(desc.Adornee, char) then
						desc.Enabled = true
					end
				end
			end)
		end

		-- Watch a character for late-added effects (equipped accessories, streaming)
		local function HookDescendantAdded(char, uid)
			return char.DescendantAdded:Connect(function(desc)
				if not _hiddenPlayers[uid] then return end
				pcall(function()
					if desc:IsA("ParticleEmitter") or desc:IsA("Fire")
						or desc:IsA("Sparkles") or desc:IsA("Smoke") then
						desc.Enabled = false
					elseif desc:IsA("Beam") or desc:IsA("Trail") then
						desc.Enabled = false
					elseif desc:IsA("PointLight") or desc:IsA("SpotLight") or desc:IsA("SurfaceLight") then
						local state = _savedState[uid]
						if state then state.lights[desc] = desc.Brightness end
						desc.Brightness = 0
					elseif desc:IsA("AudioEmitter") then
						desc.Volume = 0
					elseif desc:IsA("Sound") then
						local state = _savedState[uid]
						if state then state.sounds[desc] = desc.Volume end
						desc.Volume = 0
					elseif desc:IsA("BasePart") or desc:IsA("Decal") or desc:IsA("Texture") then
						local state = _savedState[uid]
						if state then state.transparency[desc] = desc.Transparency end
						desc.Transparency = 1
					elseif desc:IsA("BillboardGui") then
						desc.Enabled = false
					end
				end)
			end)
		end

		-- Full hide: voice mute + visual/audio suppression
		local function DoHide(player)
			if not player or _hiddenPlayers[player.UserId] then return end
			local uid = player.UserId
			if Axon._VoiceMute then Axon._VoiceMute(player) end
			local function SetupChar(char)
				if not char then return end
				ApplyHideToCharacter(char, uid)
				SuppressExistingBubbles(char)
				local descConn   = HookDescendantAdded(char, uid)
				local bubbleConn = HookBubbleChat(char, uid)
				if _hiddenPlayers[uid] then
					if _hiddenPlayers[uid].descConn   then pcall(function() _hiddenPlayers[uid].descConn:Disconnect()   end) end
					if _hiddenPlayers[uid].bubbleConn then pcall(function() _hiddenPlayers[uid].bubbleConn:Disconnect() end) end
					_hiddenPlayers[uid].descConn   = descConn
					_hiddenPlayers[uid].bubbleConn = bubbleConn
				end
			end
			_hiddenPlayers[uid] = {}
			SetupChar(player.Character)
			local charConn = player.CharacterAdded:Connect(function(char)
				if not _hiddenPlayers[uid] then return end
				task.wait(0.1)
				SetupChar(char)
			end)
			_hiddenPlayers[uid].charConn = charConn
		end

		-- Undo all hide effects for a player
		local function DoUnhide(player)
			if not player then return end
			local uid = player.UserId
			local entry = _hiddenPlayers[uid]
			if not entry then return end
			if Axon._VoiceUnmute then Axon._VoiceUnmute(player) end
			RestoreCharacter(player.Character, uid)
			RestoreBubbles(player.Character)
			if entry.charConn   then pcall(function() entry.charConn:Disconnect()   end) end
			if entry.descConn   then pcall(function() entry.descConn:Disconnect()   end) end
			if entry.bubbleConn then pcall(function() entry.bubbleConn:Disconnect() end) end
			_hiddenPlayers[uid] = nil
			if Axon._HideRefreshBtn then Axon._HideRefreshBtn(player) end
		end

		-- Hook players who join after the script loads so they get auto-hidden if needed
		local _hideJoinConn = Axon.Services.Players.PlayerAdded:Connect(function(p)
			-- Nothing to do on join; will be applied if 'hideall is used
		end)

		-- 'hide <name>  /  'h <name>
		C["hide"] = function(args)
			local name = args[1]
			if not name then
				Axon.Notify.Send({ title = "Hide", message = "Usage: 'hide <playername>", duration = 4 })
				return
			end
			local target = FindPlayer(name)
			if not target then
				Axon.Notify.Send({ title = "Hide", message = "Player not found: " .. name, duration = 4 })
				return
			end
			if _hiddenPlayers[target.UserId] then
				Axon.Notify.Send({ title = "Hide", message = target.Name .. " is already hidden", duration = 3 })
				return
			end
			DoHide(target)
			Axon.Notify.Send({ title = "Hide", message = "Hiding " .. target.Name, duration = 4 })
			if Axon._HideRefreshBtn then Axon._HideRefreshBtn(target) end
			if Axon._VoiceRefreshMuteBtn then Axon._VoiceRefreshMuteBtn(target) end
		end
		C["h"] = C["hide"]

		-- 'unhide <name|all>  /  'uh <name|all>
		C["unhide"] = function(args)
			local name = args[1]
			if not name then
				Axon.Notify.Send({ title = "Unhide", message = "Usage: 'unhide <playername> or 'unhide all", duration = 4 })
				return
			end
			if name:lower() == "all" then
				local count = 0
				local toUnhide = {}
				for uid, _ in pairs(_hiddenPlayers) do
					table.insert(toUnhide, uid)
					count = count + 1
				end
				for _, uid in ipairs(toUnhide) do
					for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
						if p.UserId == uid then DoUnhide(p); break end
					end
				end
				Axon.Notify.Send({ title = "Unhide", message = "Unhid " .. count .. " player(s)", duration = 4 })
				return
			end
			local target = FindPlayer(name)
			if not target then
				Axon.Notify.Send({ title = "Unhide", message = "Player not found: " .. name, duration = 4 })
				return
			end
			if not _hiddenPlayers[target.UserId] then
				Axon.Notify.Send({ title = "Unhide", message = target.Name .. " is not hidden", duration = 4 })
				return
			end
			DoUnhide(target)
			Axon.Notify.Send({ title = "Unhide", message = "Unhid " .. target.Name, duration = 4 })
		end
		C["uh"] = C["unhide"]

		-- 'hideall  /  'ha
		C["hideall"] = function()
			local count = 0
			for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
				if p ~= Axon.Services.Player and not _hiddenPlayers[p.UserId] then
					DoHide(p)
					count = count + 1
				end
			end
			Axon.Notify.Send({ title = "Hide All", message = "Hiding " .. count .. " player(s)", duration = 4 })
		end
		C["ha"] = C["hideall"]

		-- Expose hide API so the Target page button can reach it
		Axon._IsHidden = function(userId)
			return _hiddenPlayers[userId] ~= nil
		end

		Axon._HidePlayer = function(player)
			if not player or _hiddenPlayers[player.UserId] then return end
			DoHide(player)
		end

		Axon._UnhidePlayer = function(player)
			DoUnhide(player)
		end

		-- Cleanup: restore all hidden players and disconnect hooks on unload
		table.insert(Axon._cleanupFns, function()
			local toUnhide = {}
			for uid, _ in pairs(_hiddenPlayers) do table.insert(toUnhide, uid) end
			for _, uid in ipairs(toUnhide) do
				for _, p in ipairs(Axon.Services.Players:GetPlayers()) do
					if p.UserId == uid then DoUnhide(p); break end
				end
			end
			_hiddenPlayers = {}
			_savedState = {}
			pcall(function() _hideJoinConn:Disconnect() end)
		end)
	end
end

