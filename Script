	-- ── ADMIN CHECK ──────────────────────────────────────────

	-- Returns (isPrivileged: bool, role: string) for a given player.
	-- Works universally:
	--   • User-owned game  → flags the creator as "Owner"
	--   • Group-owned game → flags rank 255 as "Group Owner",
	--                        rank 200-254 as "Admin"
	local function IsPrivilegedPlayer(player)
		if game.CreatorType == Enum.CreatorType.User then
			if player.UserId == game.CreatorId then
				return true, "Owner"
			end
		elseif game.CreatorType == Enum.CreatorType.Group then
			local ok, rank = pcall(function()
				return player:GetRankInGroup(game.CreatorId)
			end)
			if ok and type(rank) == "number" then
				if rank == 255 then return true, "Group Owner" end
				if rank >= 200 then return true, "Admin" end
			end
		end
		return false, nil
	end

	-- Shared server-hop logic reused by the auto-hop feature
	local function DoServerHop()
		local ok, result = pcall(function()
			return Axon.Services.HttpService:JSONDecode(
				game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
			)
		end)
		if ok and result and result.data then
			for _, server in ipairs(result.data) do
				if server.id ~= game.JobId and server.playing < server.maxPlayers then
					Axon.Services.TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, Axon.Services.Player)
					return true
				end
			end
		end
		return false
	end

	-- Shared kick (disconnect) logic
	local function DoKick(role)
		local r = role or "Admin"
		Axon.Services.Player:Kick(r .. " detected auto kicked for safety.")
	end

	-- Central handler called whenever a privileged player is detected joining.
	-- Fires notification first, then reacts based on which auto options are on.
	local function OnAdminJoin(plr, role)
		Axon.Notify.Send({
			title    = role .. " Joined",
			message  = plr.Name .. " (" .. role .. ") joined the server!",
			duration = 8,
		})
		-- Auto Kick takes priority over Auto Hop
		if Axon.Settings.Data.miscAdminAutoKick then
			Axon.Notify.Send({
				title   = "Auto Kick",
				message = role .. " detected, auto kicking in 3 seconds.",
				duration = 3,
			})
			task.wait(3)
			DoKick(role)
		elseif Axon.Settings.Data.miscAdminAutoHop then
			Axon.Notify.Send({
				title   = "Auto Hop",
				message = role .. " detected, server hopping in 3 seconds.",
				duration = 3,
			})
			task.wait(3)
			local hopped = DoServerHop()
			if not hopped then
				Axon.Notify.Send({
					title   = "Server Hop Failed",
					message = "No available servers found to hop to.",
					duration = 5,
				})
			end
		end
	end

