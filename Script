			Char.infJumpConn = Axon.Services.UserInputService.JumpRequest:Connect(function()
				if Axon._loading then return end
				local h = GetHR(); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
			end)
		end
		-- Anti Void
		if SD.charAntiVoid == true then
			if Char.antiVoidConn then Char.antiVoidConn:Disconnect(); Char.antiVoidConn = nil end
			Char.antiVoidConn = Axon.Services.RunService.Heartbeat:Connect(function()
				if Axon._intentionalBelowVoid then return end
				local _, root = GetHR(); if not root then return end
				local refY = Char.origVoidY or workspace.FallenPartsDestroyHeight
				if root.Position.Y < refY + 50 then root.AssemblyLinearVelocity = Vector3.new(0, 500, 0) end
			end)
		end
		-- Void Destroy
		if SD.charVoidDestroy == true then
			if Char.voidDestroyConn then Char.voidDestroyConn:Disconnect(); Char.voidDestroyConn = nil end
			Char.origVoidY = workspace.FallenPartsDestroyHeight
			Axon._origVoidY = Char.origVoidY
			Char.voidDestroyConn = Axon.Services.RunService.Heartbeat:Connect(function() workspace.FallenPartsDestroyHeight = -99999 end)
		end
		-- Anti Ragdoll
		if SD.charAntiRagdoll == true then
			pcall(function()
				local h = GetHR()
				if h then
					h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
					h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
				end
			end)
			-- Also re-apply on every future respawn
			if Char._antiRagdollRespawnConn then Char._antiRagdollRespawnConn:Disconnect(); Char._antiRagdollRespawnConn = nil end
			Char._antiRagdollRespawnConn = Axon.Services.Player.CharacterAdded:Connect(function(newChar)
				if not Axon.Settings.Data.charAntiRagdoll then
					if Char._antiRagdollRespawnConn then Char._antiRagdollRespawnConn:Disconnect(); Char._antiRagdollRespawnConn = nil end
					return
				end
				local hNew = newChar:WaitForChild("Humanoid", 10)
				if hNew then
					pcall(function()
						hNew:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
						hNew:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
					end)
				end
			end)
		end
