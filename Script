			for sound, vol in pairs(HB.soundVols) do
				pcall(function() sound.Volume = vol end)
			end
			HB.soundVols = {}
			-- Restore all other part collisions
			for part, orig in pairs(HB.partCollide) do
				pcall(function() part.CanCollide = orig end)
			end
			HB.partCollide = {}
			-- Restore humanoid
			if h then h.PlatformStand = false end
