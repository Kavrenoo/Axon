		local _cmdConn = Axon.Services.Player.Chatted:Connect(function(msg)
			if Axon._loading then return end
			if msg:sub(1, #PREFIX) ~= PREFIX then return end
			local body  = msg:sub(#PREFIX + 1):match("^%s*(.-)%s*$")
			local parts = {}
			for tok in body:gmatch("%S+") do table.insert(parts, tok) end
			if #parts == 0 then return end
			local cmd  = parts[1]:lower()
			local args = {}
			for i = 2, #parts do table.insert(args, parts[i]) end
			local handler = COMMANDS[cmd]
			if handler then pcall(handler, args) end
		end)

		table.insert(Axon._cleanupFns, function()
			if _cmdConn then _cmdConn:Disconnect(); _cmdConn = nil end
		end)

