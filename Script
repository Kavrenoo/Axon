	-- ═════════════════════════════════════════════════════════════════
	-- HITBOX EXPANDER
	-- ═════════════════════════════════════════════════════════════════
	--
	-- Approach: directly resize the actual character parts in a RenderStepped
	-- loop. This is the standard technique used by all working universal HBEs.
	-- Because we're modifying the real parts (Head, HRP, etc.) that the game's
	-- hit-detection pipeline already knows about, hits on the expanded area
	-- register correctly. The loop re-applies every ~20ms so any server-side
	-- revert attempt is overwritten immediately. part.Changed watchers catch
	-- same-frame reversions before the next loop tick.
	-- ─────────────────────────────────────────────────────────────────

	local sHB = C.Section(p, "Hitbox Expander", 4)

	-- ── Part group definitions (R6 + R15 names) ───────────────────────
	local HB_GROUPS = {
		{ id = "Head",        label = "Head",        parts = { "Head" } },
		{ id = "Humanoid Root Part", label = "Humanoid Root Part", parts = { "HumanoidRootPart" } },
		{ id = "Upper Torso", label = "Upper Torso", parts = { "UpperTorso", "Torso" } },
		{ id = "All Limbs",   label = "All Limbs",   parts = {
			"Head", "HumanoidRootPart",
			"UpperTorso", "Torso", "LowerTorso",
			"LeftUpperArm", "RightUpperArm", "Left Arm", "Right Arm",
			"LeftLowerArm", "RightLowerArm", "LeftHand", "RightHand",
			"LeftUpperLeg", "RightUpperLeg", "Left Leg", "Right Leg",
			"LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot",
		}},
	}

	local HB_BOX_SWATCHES = {
		C3rgb(255, 50,  50),   -- red (default)
		C3rgb(255, 100, 0),    -- orange
		C3rgb(255, 220, 0),    -- yellow
		C3rgb(0,   255, 0),    -- green
		C3rgb(0,   180, 255),  -- blue
		C3rgb(200, 0,   255),  -- purple
		C3rgb(255, 255, 255),  -- white
		C3rgb(0,   0,   0),    -- black
	}

	local HB = {
		enabled    = false,
		size       = Axon.Settings.Data.hbSize or 8,
		teamCheck  = Axon.Settings.Data.hbTeamCheck ~= false,
		aliveCheck = Axon.Settings.Data.hbAliveCheck ~= false,
		visualize  = Axon.Settings.Data.hbVisualize == true,
		groupId    = Axon.Settings.Data.hbGroup or "Head",
		boxColor   = HB_BOX_SWATCHES[Axon.Settings.Data.hbBoxColorIdx or 1] or C3rgb(255, 50, 50),
	}

	-- hbOriginals[plr][partName] = { Size, Transparency, Material, CanCollide, Massless }
	local hbOriginals    = {}
	local hbChangedConns = {}   -- [plr][partName] = Changed connection
	local hbCharConns    = {}   -- [plr] = CharacterAdded connection
	local hbSelBoxes     = {}   -- [plr][partName] = SelectionBox
	local hbRenderConn   = nil
	local hbLastTick     = 0
	local HB_HZ          = 20   -- re-apply rate

	local function HBGetGroup()
		for _, g in ipairs(HB_GROUPS) do
			if g.id == HB.groupId then return g.parts end
		end
		return HB_GROUPS[1].parts
	end

	-- ── Per-part apply / restore ──────────────────────────────────────
	local function HBApplyPart(plr, part)
		if not hbOriginals[plr] then hbOriginals[plr] = {} end
		if not hbOriginals[plr][part.Name] then
			hbOriginals[plr][part.Name] = {
				Size         = part.Size,
				Transparency = part.Transparency,
				CanCollide   = part.CanCollide,
				Massless     = part.Massless,
			}
		end
		local sz = Vector3.new(HB.size, HB.size, HB.size)
		if part.Size ~= sz   then part.Size       = sz    end
		if part.CanCollide   then part.CanCollide  = false end
		if not part.Massless then part.Massless    = true  end
		-- Always keep fully invisible — SelectionBox handles the visual separately
		if part.Transparency ~= 1 then part.Transparency = 1 end
	end

	local function HBRestorePart(plr, partName, part)
		local orig = hbOriginals[plr] and hbOriginals[plr][partName]
		if not orig then return end
		if part then
			pcall(function()
				part.Size         = orig.Size
				part.Transparency = orig.Transparency
				part.CanCollide   = orig.CanCollide
				part.Massless     = orig.Massless
			end)
		end
		hbOriginals[plr][partName] = nil
	end

	-- ── Changed-watchers (catch mid-frame server resets) ──────────────
	local function HBClearChangedConns(plr)
		local tbl = hbChangedConns[plr]
		if not tbl then return end
		for _, conn in pairs(tbl) do pcall(function() conn:Disconnect() end) end
		hbChangedConns[plr] = nil
	end

	local function HBAddChangedConns(plr, char)
		HBClearChangedConns(plr)
		hbChangedConns[plr] = {}
		local groupParts = HBGetGroup()
		for _, partName in ipairs(groupParts) do
			local part = char:FindFirstChild(partName)
			if part then
				hbChangedConns[plr][partName] = part.Changed:Connect(function(prop)
					if not HB.enabled then return end
					if prop == "Size" or prop == "CanCollide" or prop == "Transparency" or prop == "Massless" then
						-- Snap back immediately if something tried to revert us
						if hbOriginals[plr] and hbOriginals[plr][partName] then
							pcall(function() HBApplyPart(plr, part) end)
						end
					end
				end)
			end
		end
	end

	-- ── SelectionBox visual helpers ───────────────────────────────────
	local function HBClearSelBoxes(plr)
		local tbl = hbSelBoxes[plr]
		if not tbl then return end
		for _, sb in pairs(tbl) do pcall(function() sb:Destroy() end) end
		hbSelBoxes[plr] = nil
	end

	local function HBMakeSelBoxes(plr, char)
		HBClearSelBoxes(plr)
		if not HB.visualize then return end
		hbSelBoxes[plr] = {}
		local groupParts = HBGetGroup()
		for _, partName in ipairs(groupParts) do
			local part = char:FindFirstChild(partName)
			if part then
				local sb = Instance.new("SelectionBox")
				sb.Adornee              = part
				sb.Color3               = HB.boxColor
				sb.LineThickness        = 0.05
				sb.SurfaceTransparency  = 0.85
				sb.SurfaceColor3        = HB.boxColor
				sb.Parent               = workspace
				hbSelBoxes[plr][partName] = sb
			end
		end
	end

	-- ── Apply / restore a whole player ───────────────────────────────
	local function HBApplyPlayer(plr)
		if HB.teamCheck and IsTeammate(plr) then return end
		if HB.aliveCheck and not IsAlive(plr) then return end
		local char = plr.Character
		if not char then return end
		local groupParts = HBGetGroup()
		for _, partName in ipairs(groupParts) do
			local part = char:FindFirstChild(partName)
			if part then pcall(function() HBApplyPart(plr, part) end) end
		end
	end

	local function HBRestorePlayer(plr)
		local char = plr.Character
		local orig = hbOriginals[plr]
		if not orig then return end
		for partName, _ in pairs(orig) do
			local part = char and char:FindFirstChild(partName)
			HBRestorePart(plr, partName, part)
		end
		hbOriginals[plr] = nil
	end

	-- ── Full scan / watcher setup per player ──────────────────────────
	local function HBSetupPlayer(plr)
		if plr == LocalPlayer then return end
		if hbCharConns[plr] then pcall(function() hbCharConns[plr]:Disconnect() end) end
		hbCharConns[plr] = plr.CharacterAdded:Connect(function(char)
			task.wait(0.12)   -- let character parts load
			hbOriginals[plr] = nil
			HBClearChangedConns(plr)
			HBClearSelBoxes(plr)
			HBApplyPlayer(plr)
			HBAddChangedConns(plr, char)
			HBMakeSelBoxes(plr, char)
		end)
		-- Apply to current character if already loaded
		local char = plr.Character
		if char then
			HBApplyPlayer(plr)
			HBAddChangedConns(plr, char)
			HBMakeSelBoxes(plr, char)
		end
	end

	local function HBTeardownPlayer(plr)
		if hbCharConns[plr] then
			pcall(function() hbCharConns[plr]:Disconnect() end)
			hbCharConns[plr] = nil
		end
		HBClearChangedConns(plr)
		HBClearSelBoxes(plr)
		HBRestorePlayer(plr)
	end

	-- ── Force update: manually re-scan all players ────────────────────
	local function HBForceUpdate()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer then
				hbOriginals[plr] = nil
				HBClearChangedConns(plr)
				HBClearSelBoxes(plr)
				local char = plr.Character
				if char then
					HBApplyPlayer(plr)
					HBAddChangedConns(plr, char)
					HBMakeSelBoxes(plr, char)
				end
			end
		end
	end

	-- ── RenderStepped loop (re-applies at HB_HZ) ─────────────────────
	local function HBStartLoop()
		if hbRenderConn then return end
		hbRenderConn = RunService.RenderStepped:Connect(function()
			local now = tick()
			if now - hbLastTick < 1 / HB_HZ then return end
			hbLastTick = now
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer then
					pcall(function() HBApplyPlayer(plr) end)
				end
			end
		end)
	end

	local function HBStopLoop()
		if hbRenderConn then
			hbRenderConn:Disconnect()
			hbRenderConn = nil
		end
	end

	-- ── HBStart / HBStop ─────────────────────────────────────────────
	local function HBStart()
		HBStartLoop()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer then HBSetupPlayer(plr) end
		end
	end

	local function HBStop()
		HBStopLoop()
		for _, plr in ipairs(Players:GetPlayers()) do
			HBTeardownPlayer(plr)
		end
	end

	local _hbPlayerAddedConn = Players.PlayerAdded:Connect(function(plr)
		if HB.enabled then HBSetupPlayer(plr) end
	end)
	local _hbPlayerRemovingConn = Players.PlayerRemoving:Connect(function(plr)
		HBTeardownPlayer(plr)
	end)

