		task.spawn(function()
			local h = MyHum(); local char = PLR.Character
			if h then
				h.PlatformStand = false; h.Sit = false; h.AutoRotate = true
				local animScript = char and char:FindFirstChild("Animate")
				if animScript then animScript.Disabled = true end
				for _, tr in ipairs(h:GetPlayingAnimationTracks()) do tr:Stop(0) end
				task.wait()
				if char then
					for _, m in ipairs(char:GetDescendants()) do
						if m:IsA("Motor6D") then m.Transform = CFrame.new() end
					end
				end
				local r = MyRoot()
				if r then
					local lv = r.CFrame.LookVector
					local flat = Vector3.new(lv.X, 0, lv.Z)
					if flat.Magnitude > 0.01 then r.CFrame = CFrame.new(r.Position, r.Position + flat) end
				end
				h.AutoRotate = false; h.PlatformStand = true
			end
			if char then
				local animScript = char:FindFirstChild("Animate")
				if animScript then animScript.Disabled = true end
			end
			T._orbitAngle = 0
			T._orbitConn = RS.Heartbeat:Connect(function(dt)
				local tRoot = GetRoot(T.Player); local r = MyRoot()
				if not tRoot or not r then return end
				T._orbitAngle = (T._orbitAngle + dt * GetOrbitSpeed()) % 360
				local rad    = math.rad(T._orbitAngle)
				local radius = GetOrbitRadius()
				local offset = Vector3.new(math.cos(rad) * radius, 0, math.sin(rad) * radius)
				r.CFrame = CFrame.new(tRoot.Position + offset, tRoot.Position)
			end)
		end)
	end)

