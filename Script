		local oldWarn = warn
		local oldPrint = print

		local function hookedWarn(reason, ...)
			if tostring(reason):find("Reanimate first!") then return end
			return oldWarn(reason, ...)
		end

		local function hookedPrint(reason, ...)
			if tostring(reason):find("AK Reanim loaded!") or tostring(reason):find("Deleted old animation cache") then return end
			return oldPrint(reason, ...)
		end

		-- Temporarily replace global functions
		getgenv().warn = hookedWarn
		getgenv().print = hookedPrint

		-- Execute reanimation
		pcall(function()
