	local function WorldToScreen(pos)
		local cam = workspace.CurrentCamera; if not cam then return V2new(0,0), false end
		local v, vis = cam:WorldToViewportPoint(pos)
		return V2new(v.X, v.Y), vis
	end

	local function GetWallBlacklist(plr, char)
		local now = tick(); local wc = wallBlCache[plr]
		if wc and (now - wc.t) < WALL_CACHE_TTL then return wc.bl end
		local bl = char:GetDescendants()
		local lc = LocalPlayer.Character
		if lc then local ld = lc:GetDescendants(); local b = #bl; for i=1,#ld do bl[b+i]=ld[i] end end
		wallBlCache[plr] = { bl=bl, t=now }; return bl
	end

	local function ScanForTarget()
		local cam = workspace.CurrentCamera; if not cam then return end
		local mousePos = UserInputService:GetMouseLocation()
		local bestDist = AB.fovRadius
		local bestPlr  = nil

		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer and not (AB.teamCheck and IsTeammate(plr)) then
				local char = plr.Character
				if char then
					local part = char:FindFirstChild(AB.lockPart)
					if not part then
						local fallback = (AB.lockPart == "UpperTorso" and "Torso")
							or (AB.lockPart == "Torso" and "UpperTorso")
						part = (fallback and char:FindFirstChild(fallback)) or char:FindFirstChild("HumanoidRootPart")
					end
					if part then
						local hum = char:FindFirstChildOfClass("Humanoid")
						if hum and (not AB.aliveCheck or IsAlive(plr)) then
							local canSee = true
							if AB.wallCheck then
								local bl = GetWallBlacklist(plr, char)
								if #cam:GetPartsObscuringTarget({part.Position}, bl) > 0 then canSee = false end
							end
							if canSee then
								local sp, vis = WorldToScreen(part.Position)
								if vis then
									local d = (mousePos - sp).Magnitude
									if d < bestDist then bestDist = d; bestPlr = plr end
								end
							end
						end
					end
				end
			end
		end

		if bestPlr then
			AB.locked     = bestPlr
			local char    = bestPlr.Character
			local lp = char and char:FindFirstChild(AB.lockPart)
			if char and not lp then
				local fallback = (AB.lockPart == "UpperTorso" and "Torso")
					or (AB.lockPart == "Torso" and "UpperTorso")
				lp = (fallback and char:FindFirstChild(fallback)) or char:FindFirstChild("HumanoidRootPart")
			end
			lockedPartRef = lp
			lockedHumRef  = char and char:FindFirstChildOfClass("Humanoid")
		end
	end

	local function DisconnectAimbot()
		for k, conn in pairs(abConns) do conn:Disconnect(); abConns[k] = nil end
	end

	local lastTweenPos   = nil
	local TWEEN_RETHRESH = 0.4

	local function StartAimbot()
		DisconnectAimbot()
		if not AB.enabled then
			CancelLock()
			if fovCircle then fovCircle.Visible = false end
			return
		end

		abConns.render = RunService.RenderStepped:Connect(function()
			if fovCircle then
				local mp = UserInputService:GetMouseLocation()
				fovCircle.Position  = mp
				fovCircle.Radius    = AB.fovRadius
				fovCircle.Thickness = AB.fovThickness
				fovCircle.Color     = AB.locked and AB.fovLockedBorderColor or AB.fovColor
				fovCircle.Visible   = true
			end

			if not AB.running then return end

			if AB.locked then
				if not lockedPartRef or not lockedPartRef.Parent then
					ScanForTarget()
				else
					local sp, vis = WorldToScreen(lockedPartRef.Position)
					if not vis or (UserInputService:GetMouseLocation() - sp).Magnitude > AB.fovRadius then
						CancelLock()
					end
				end
			else
				local now = tick()
				if now - abScanTick >= 1 / AB_SCAN_HZ then
					abScanTick = now
					ScanForTarget()
				end
			end

			if AB.locked and lockedPartRef then
				local offset = V3new(0,0,0)
				if AB.offsetToMove and lockedHumRef then
					offset = lockedHumRef.MoveDirection * clamp(AB.offsetIncr, 1, 30) / 10
				end
				local targetPos = lockedPartRef.Position + offset
				local cam = workspace.CurrentCamera; if not cam then return end

				if AB.lockMode == 2 then
					local sp = WorldToScreen(targetPos); local mp = UserInputService:GetMouseLocation()
					pcall(mousemoverel, (sp.X-mp.X)/AB.sensitivity2, (sp.Y-mp.Y)/AB.sensitivity2)
				else
					if AB.sensitivity > 0 then
						local needNew = not AB.animation or AB.animation.PlaybackState ~= Enum.PlaybackState.Playing
						if not needNew and lastTweenPos then
							local d = targetPos - lastTweenPos
							needNew = d.X*d.X + d.Y*d.Y + d.Z*d.Z > TWEEN_RETHRESH * TWEEN_RETHRESH
						end
						if needNew then
							if AB.animation then AB.animation:Cancel() end
							AB.animation = TweenService:Create(cam, TweenInfo.new(AB.sensitivity, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), { CFrame = CFrame.new(cam.CFrame.Position, targetPos) })
							AB.animation:Play(); lastTweenPos = targetPos
						end
					else
						cam.CFrame = CFrame.new(cam.CFrame.Position, targetPos)
					end
					UserInputService.MouseDeltaSensitivity = 0
				end
			end
		end)

		if AB.keyStyle ~= "Toggle" and AB.keyStyle ~= "Hold" then AB.running = true end

		abConns.inputBegan = UserInputService.InputBegan:Connect(function(input, gpe)
			if Axon._loading then return end
			if AB.typing or AB.capturing or gpe or not AB.triggerKey then return end
			local triggered = (AB.triggerIsKeyboard and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == AB.triggerKey)
				or (not AB.triggerIsKeyboard and input.UserInputType == AB.triggerKey)
			if not triggered then return end
			if AB.keyStyle == "Toggle" then
				AB.running = not AB.running
				if not AB.running then CancelLock() end
			elseif AB.keyStyle == "Hold" then
				AB.running = true
			end
		end)
		abConns.inputEnded = UserInputService.InputEnded:Connect(function(input)
			if AB.typing or AB.keyStyle ~= "Hold" or not AB.triggerKey then return end
			local triggered = (AB.triggerIsKeyboard and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == AB.triggerKey)
				or (not AB.triggerIsKeyboard and input.UserInputType == AB.triggerKey)
			if triggered then AB.running = false; CancelLock() end
		end)
		abConns.focusGained = UserInputService.TextBoxFocused:Connect(function()       AB.typing = true  end)
		abConns.focusLost   = UserInputService.TextBoxFocusReleased:Connect(function() AB.typing = false end)
	end

