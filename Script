	local function AddPlayerToList(plr)
		if plr == PLR then return end
		local uid = plr.UserId
		if playerBtns[uid] then return end

		playerCache[uid] = { player = plr, isFriend = nil }
		MakePlayerRow(plr)
		UpdateListSize()

		task.spawn(function()
			local ok, isFriend = pcall(function() return PLR:IsFriendsWith(uid) end)
			if playerCache[uid] then
				playerCache[uid].isFriend = ok and isFriend or false
				AssignLayoutOrders()
			end
		end)
	end

	local function RebuildPlayerList()
		if not listHolder then return end
		local savedScroll = listScroll.CanvasPosition
		for _, row in pairs(playerBtns) do
			if row and row.Parent then row:Destroy() end
		end
		playerBtns  = {}
		playerCache = {}
		for _, plr in ipairs(Players:GetPlayers()) do
			AddPlayerToList(plr)
		end
		listScroll.CanvasPosition = savedScroll
	end

	SetTarget = function(plr)
		if T.Player ~= plr then
			local anyActive = T.Viewing or T.Focusing or T.Headsitting or T.Backpacking
				or T.Orbiting or T.Flinging or T.FaceBanging or T.Standing
				or T.Dogging or T.Dragging or T.Banging
			if anyActive then StopAll(true) end
		end
		T.Player = plr
		if searchBox then searchBox.Text = "" end
		UpdateInfoCard(plr)
		BuildFriendsList(plr)
		BuildInventoryList(plr)
		-- Refresh mute button to reflect whether this target is muted
		if Axon._VoiceIsMuted then
			SetBtnActive("mutevoice", plr and Axon._VoiceIsMuted(plr.UserId) or false)
		end
		-- Refresh hide button to reflect whether this target is hidden;
		-- also force mutevoice on if the player is hidden (hide always mutes)
		if Axon._IsHidden then
			local hidden = plr and Axon._IsHidden(plr.UserId) or false
			SetBtnActive("hideplayer", hidden)
			if hidden then SetBtnActive("mutevoice", true) end
		end
		-- Notify hide hook if registered
		if Axon._SetTargetHook then Axon._SetTargetHook(plr) end
	end

