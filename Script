	local function SetChatSpam(val)
		chatSpamOn = val
		if Misc.chatSpamConn then Misc.chatSpamConn:Disconnect(); Misc.chatSpamConn = nil end
		if not val then chatSpamEchoes = {}; return end
		local TCS = game:GetService("TextChatService")
		if TCS.ChatVersion == Enum.ChatVersion.TextChatService then
			Misc.chatSpamConn = TCS.MessageReceived:Connect(function(msg)
				if not chatSpamOn or not msg.TextSource then return end
				local sender = Axon.Services.Players:GetPlayerByUserId(msg.TextSource.UserId)
				if sender ~= Axon.Services.Player then return end
				local text = msg.Text or ""; local channel = msg.TextChannel; if not channel then return end
				if chatSpamEchoes[text] and chatSpamEchoes[text] > 0 then
					chatSpamEchoes[text] = chatSpamEchoes[text] - 1
					if chatSpamEchoes[text] == 0 then chatSpamEchoes[text] = nil end; return
				end
				chatSpamEchoes[text] = 2
				task.spawn(function() task.wait(0.08); pcall(function() channel:SendAsync(text) end); task.wait(0.06); pcall(function() channel:SendAsync(text) end) end)
			end)
		else
			local events = Axon.Services.ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents")
			local sayRemote  = events and events:FindFirstChild("SayMessageRequest")
			local doneRemote = events and events:FindFirstChild("OnMessageDoneFiltering")
			if doneRemote and sayRemote then
				Misc.chatSpamConn = doneRemote.OnClientEvent:Connect(function(data)
					if not chatSpamOn or not data then return end
					local sender = Axon.Services.Players:FindFirstChild(tostring(data.FromSpeaker or ""))
					if sender ~= Axon.Services.Player then return end
					local text = tostring(data.Message or "")
					if chatSpamEchoes[text] and chatSpamEchoes[text] > 0 then
						chatSpamEchoes[text] = chatSpamEchoes[text] - 1
						if chatSpamEchoes[text] == 0 then chatSpamEchoes[text] = nil end; return
					end
					chatSpamEchoes[text] = 2
					task.spawn(function() task.wait(0.08); pcall(function() sayRemote:FireServer(text,"All") end); task.wait(0.06); pcall(function() sayRemote:FireServer(text,"All") end) end)
				end)
			else end
		end
	end

