		local invisHit = Axon.UI.New("TextButton", {
			Size = UDim2.new(0, 52, 1, 0), Position = UDim2.new(1, -56, 0, 0),
			BackgroundTransparency = 1, Text = "", Parent = invisRow,
		})

		local function SetInvisVisual(val)
			Axon.UI.Tween(invisPill, { BackgroundColor3 = val and Axon.UI.Colors.ToggleOn or Axon.UI.Colors.ToggleOff }, 0.15)
			Axon.UI.Tween(invisKnob, { Position = val and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8) }, 0.15)
		end
		Char.setInvisVisual = SetInvisVisual  -- expose so EndInvis can reset the pill

		local function UpdateInvisDesc()
			if Char.invisKey then
				invisDescLabel.Text = "Key: " .. Char.invisKey.Name .. " — press to toggle"
				invisBindBtn.Text = "Rebind"
			else
