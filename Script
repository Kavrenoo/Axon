		local function StartHamsterBall()
			local h, root = GetHR()
			if not root then return end
			local char = Axon.Services.Player.Character

			-- Save originals
			HB.origShape   = root.Shape
			HB.origSize    = root.Size
			HB.origTransp  = root.Transparency
			HB.origCollide = root.CanCollide
			local cam = workspace.CurrentCamera
			HB.origCamSubj = cam and cam.CameraSubject

			-- Mute footstep / movement sounds inside HumanoidRootPart
			HB.soundVols = {}
			pcall(function()
				for _, snd in ipairs(root:GetChildren()) do
					if snd:IsA("Sound") then
						HB.soundVols[snd] = snd.Volume
						snd.Volume = 0
					end
				end
			end)

			-- Disable collisions on every part except the root (ball itself)
			HB.partCollide = {}
			for _, part in ipairs(char:GetDescendants()) do
				if part:IsA("BasePart") and part ~= root then
					HB.partCollide[part] = part.CanCollide
					part.CanCollide = false
				end
			end

			-- Transform HumanoidRootPart INTO the hamster ball
			-- Semi-transparent so character is visible inside, FE so all players see it
			root.Shape        = Enum.PartType.Ball
			root.Size         = Vector3.new(HB.ballSize, HB.ballSize, HB.ballSize)
			root.Transparency = 1             -- fully invisible; character still shows inside
			root.CanCollide   = true

			-- Lock humanoid so it doesn't fight the physics
			if h then h.PlatformStand = true end

			-- Point camera at the ball
			if cam then cam.CameraSubject = root end

			-- Raycast params to detect ground (exclude self)
			local params = RaycastParams.new()
			params.FilterType                 = Enum.RaycastFilterType.Exclude
			params.FilterDescendantsInstances = {char}

			local UIS = Axon.Services.UserInputService

			-- RenderStepped: apply rolling torque via AssemblyAngularVelocity (authentic roll physics)
			HB.renderConn = Axon.Services.RunService.RenderStepped:Connect(function(delta)
				local _, r = GetHR()
				if not r then StopHamsterBall(); return end
				r.CanCollide = true
				if UIS:GetFocusedTextBox() then return end

				-- Scale speed from the Walk Speed slider (16 = normal = speed 30)
				local spd = ((Char.walkSpeed or 16) / 16) * 30

				local camCF = workspace.CurrentCamera.CFrame
				if UIS:IsKeyDown(Enum.KeyCode.W) then
					r.AssemblyAngularVelocity = r.AssemblyAngularVelocity - camCF.RightVector * delta * spd
				end
				if UIS:IsKeyDown(Enum.KeyCode.S) then
					r.AssemblyAngularVelocity = r.AssemblyAngularVelocity + camCF.RightVector * delta * spd
				end
				if UIS:IsKeyDown(Enum.KeyCode.A) then
					r.AssemblyAngularVelocity = r.AssemblyAngularVelocity - camCF.LookVector * delta * spd
				end
				if UIS:IsKeyDown(Enum.KeyCode.D) then
					r.AssemblyAngularVelocity = r.AssemblyAngularVelocity + camCF.LookVector * delta * spd
				end
			end)

			-- Jump: fire upward impulse when grounded (Space or jump button)
			HB.jumpConn = UIS.JumpRequest:Connect(function()
				if Axon._loading then return end
				local _, r = GetHR()
				if not r then return end
				local groundCheck = workspace:Raycast(
