		end
		if cfg.key then Axon.Settings.Data[cfg.key] = state; if not silent then Axon.Settings.Save() end end
		if cfg.onChange and not silent then cfg.onChange(state) end
	end
	hitbox.MouseButton1Click:Connect(function() SetState(not state) end)
	SetState(state, true)
	return row, function(v) SetState(v, false) end, function(v) SetState(v, true) end
end

Axon.Components.Slider = function(parent, cfg)
	local sMin = cfg.min or 0; local sMax = cfg.max or 100
	local decimals = cfg.decimals or 0; local suffix = cfg.suffix or ""
	local val = cfg.initial or cfg.default or sMin
	if cfg.key and Axon.Settings.Data[cfg.key] ~= nil then val = Axon.Settings.Data[cfg.key] end
	val = math.clamp(val, sMin, sMax)
	local row = Axon.UI.New("Frame", {
		Size = UDim2.new(1, 0, 0, 62), BackgroundColor3 = Axon.UI.Colors.Section,
		BorderSizePixel = 0, LayoutOrder = cfg.order or 0,
	}, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Border, 1) })
	row.Parent = parent
	Axon.UI.New("TextLabel", {
		Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 12, 0, 8),
		BackgroundTransparency = 1, Text = cfg.label or "Slider",
		TextColor3 = Axon.UI.Colors.TextPrimary, Font = Enum.Font.GothamSemibold,
		TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
	})
	local valLabel = Axon.UI.New("TextLabel", {
		Size = UDim2.new(0, 70, 0, 20), Position = UDim2.new(1, -82, 0, 8),
		BackgroundTransparency = 1, Text = tostring(val) .. suffix,
		TextColor3 = Axon.UI.Colors.Accent, Font = Enum.Font.GothamBold,
		TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right, Parent = row,
	})
	local track = Axon.UI.New("Frame", {
		Size = UDim2.new(1, -24, 0, 4), Position = UDim2.new(0, 12, 0, 40),
		BackgroundColor3 = Axon.UI.Colors.SliderTrack, BorderSizePixel = 0,
	}, { Axon.UI.Corner(2) })
	track.Parent = row
	local fill = Axon.UI.New("Frame", {
		Size = UDim2.new((val - sMin)/(sMax - sMin), 0, 1, 0),
		BackgroundColor3 = Axon.UI.Colors.SliderFill, BorderSizePixel = 0,
	}, { Axon.UI.Corner(2) })
	fill.Parent = track
	local knob = Axon.UI.New("Frame", {
		Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new((val - sMin)/(sMax - sMin), -6, 0.5, -6),
		BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0, ZIndex = 2,
	}, { Axon.UI.Corner(6) })
	knob.Parent = track
	local dragging = false; local lastClick = 0; local inputOpen = false
	local function SetValue(newVal, save, silent)
		newVal = tonumber(string.format("%." .. decimals .. "f", math.clamp(newVal, sMin, sMax)))
		if not newVal then return end; val = newVal
		local ratio = (val - sMin)/(sMax - sMin)
		fill.Size = UDim2.new(ratio, 0, 1, 0); knob.Position = UDim2.new(ratio, -6, 0.5, -6)
		valLabel.Text = tostring(val) .. suffix
		if not silent then
			if cfg.key then Axon.Settings.Data[cfg.key] = val end
			if cfg.onChange then cfg.onChange(val) end
			if save then Axon.Settings.Save() end
		end
	end
	local function UpdateSlider(inputX)
		local ratio = math.clamp((inputX - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
		SetValue(sMin + (sMax - sMin) * ratio, false)
	end
	local function OpenTextInput()
		if inputOpen then return end; inputOpen = true
		Axon.UI.Tween(row, { BackgroundColor3 = Axon.UI.Colors.ActiveItem }, 0.1)
		local overlay = Axon.UI.New("Frame", { Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = Axon.UI.Colors.Section, BorderSizePixel = 0, ZIndex = 20 }, { Axon.UI.Corner(6) })
		overlay.Parent = row
		Axon.UI.New("TextLabel", { Size = UDim2.new(1, -120, 1, 0), Position = UDim2.new(0, 12, 0, 0), BackgroundTransparency = 1, Text = cfg.label .. "  (" .. sMin .. " – " .. sMax .. ")", TextColor3 = Axon.UI.Colors.TextSecondary, Font = Enum.Font.Gotham, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 21, Parent = overlay })
		local box = Axon.UI.New("TextBox", { Size = UDim2.new(0, 90, 0, 26), Position = UDim2.new(1, -104, 0.5, -13), BackgroundColor3 = Axon.UI.Colors.SliderTrack, Text = tostring(val), TextColor3 = Axon.UI.Colors.TextPrimary, Font = Enum.Font.GothamBold, TextSize = 13, ClearTextOnFocus = true, BorderSizePixel = 0, ZIndex = 21 }, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Accent, 1) })
		box.Parent = overlay
		local confirmed = false; task.wait(); box:CaptureFocus()
		local function Confirm()
			if confirmed then return end; confirmed = true
			local num = tonumber(box.Text)
				if num then SetValue(num, true) else SetValue(cfg.default or sMin, true) end
			if overlay.Parent then overlay:Destroy() end
			Axon.UI.Tween(row, { BackgroundColor3 = Axon.UI.Colors.Section }, 0.1); inputOpen = false
		end
		box.FocusLost:Connect(Confirm); task.wait(); task.wait()
		local outsideConn
		outsideConn = Axon.Services.UserInputService.InputBegan:Connect(function(inp)
			if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
			local mouse = Axon.Services.UserInputService:GetMouseLocation()
			local abs = overlay.AbsolutePosition; local size = overlay.AbsoluteSize
			if not (mouse.X >= abs.X and mouse.X <= abs.X + size.X and mouse.Y >= abs.Y and mouse.Y <= abs.Y + size.Y) then
				outsideConn:Disconnect(); box:ReleaseFocus(); Confirm()
			end
		end)
	end
	local sliderHit = Axon.UI.New("TextButton", {
		Size = UDim2.new(1, -24, 0, 28), Position = UDim2.new(0, 12, 0, 28),
		BackgroundTransparency = 1, Text = "", ZIndex = 5, Parent = row,
	})
	sliderHit.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			local now = tick()
			if now - lastClick < 0.35 then
				local resetVal = cfg.default or sMin
				SetValue(resetVal, false)
				if cfg.key then Axon.Settings.Data[cfg.key] = resetVal end
				fill.BackgroundColor3 = Color3.new(1, 1, 1)
				task.delay(0.12, function() Axon.UI.Tween(fill, { BackgroundColor3 = Axon.UI.Colors.SliderFill }, 0.2) end)
				lastClick = 0; return
			end
			lastClick = now; dragging = true; UpdateSlider(inp.Position.X)
		elseif inp.UserInputType == Enum.UserInputType.MouseButton2 then OpenTextInput() end
	end)
	local _sliderChangedConn = Axon.Services.UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then UpdateSlider(inp.Position.X) end
	end)
	local _sliderEndedConn = Axon.Services.UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 and dragging then dragging = false end
	end)
	-- Register for unload cleanup
	table.insert(Axon._cleanupFns, function()
		if _sliderChangedConn then _sliderChangedConn:Disconnect(); _sliderChangedConn = nil end
		if _sliderEndedConn   then _sliderEndedConn:Disconnect();   _sliderEndedConn   = nil end
	end)
	return row, SetValue
end

