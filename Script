		Size = UDim2.new(0, 44, 0, 26), Position = UDim2.new(1, -54, 0.5, -13),
		BackgroundTransparency = 1, Text = "", ZIndex = 10, Parent = row,
	})
	local function SetState(val, silent)
		state = val
		local onCol = cfg.onColor or Axon.UI.Colors.ToggleOn
		local targetCol = state and onCol or Axon.UI.Colors.ToggleOff
		local targetPos = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
		if silent then
			pill.BackgroundColor3 = targetCol
