Axon.Settings.Data = {}

Axon.Settings._manualSaveOnly = true  -- only write to disk when Save button is pressed

Axon.Settings.Save = function()
	if Axon.Settings._manualSaveOnly then return end  -- skip auto-saves
	if not writefile then return end
	pcall(function()
		writefile(Axon.Config.SAVE_FILE,
			Axon.Services.HttpService:JSONEncode(Axon.Settings.Data))
	end)
end

Axon.Settings.ForceSave = function()
	if not writefile then return end
	pcall(function()
		writefile(Axon.Config.SAVE_FILE,
			Axon.Services.HttpService:JSONEncode(Axon.Settings.Data))
	end)
end

Axon.Settings.Load = function()
	for k, v in pairs(Axon.Settings.Defaults) do
		Axon.Settings.Data[k] = v
	end
	if not readfile then return end
	local ok, result = pcall(function()
		return Axon.Services.HttpService:JSONDecode(readfile(Axon.Config.SAVE_FILE))
	end)
	if ok and type(result) == "table" then
		for k, v in pairs(result) do
			if Axon.Settings.Defaults[k] ~= nil then
				Axon.Settings.Data[k] = v
			end
		end
		-- Migrate old hbGroup IDs from before the rename
		local hbGroupMigration = { Both = "Head", AllLimbs = "All Limbs", UpperTorso = "Upper Torso" }
