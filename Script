-- ── Result card builder ───────────────────────────────────

local _srchResultFrames = {}

local function _ClearSearchResults()
	for _, f in ipairs(_srchResultFrames) do
		pcall(function() f:Destroy() end)
	end
	_srchResultFrames = {}
end

local function _RunSearch(query)
	_ClearSearchResults()
	local UI  = Axon.UI
	local Col = UI.Colors

	query = (query or ""):lower():match("^%s*(.-)%s*$")

	if query == "" then
		UI.SearchCountLbl.Text = "Type to search across all sections…"
		UI.SearchResults.CanvasPosition = Vector2.new(0, 0)
		return
	end

	local matches = {}
	for _, entry in ipairs(Axon.Search._registry) do
		local hay = (entry.label .. " " .. entry.desc .. " " .. entry.page .. " " .. entry.section):lower()
		if hay:find(query, 1, true) then
			table.insert(matches, entry)
		end
	end

	if #matches == 0 then
		UI.SearchCountLbl.Text = 'No results for "' .. query .. '"'
		return
	end

	UI.SearchCountLbl.Text = (#matches == 1) and "1 result" or (#matches .. " results")

	for i, entry in ipairs(matches) do
		local card = UI.New("Frame", {
			Size             = UDim2.new(1, 0, 0, entry.desc ~= "" and 60 or 46),
			BackgroundColor3 = Col.Section,
			BorderSizePixel  = 0,
			LayoutOrder      = i,
			ZIndex           = 12,
			Parent           = UI.SearchResults,
		}, { UI.Corner(6), UI.Stroke(Col.Border, 1) })
		table.insert(_srchResultFrames, card)

		-- Breadcrumb: Page  ›  Section
		UI.New("TextLabel", {
			Size                   = UDim2.new(1, -16, 0, 14),
			Position               = UDim2.new(0, 12, 0, 6),
			BackgroundTransparency = 1,
			Text                   = entry.page .. "  ›  " .. entry.section,
			TextColor3             = Col.Accent,
			Font                   = Enum.Font.GothamBold,
			TextSize               = 9,
			TextXAlignment         = Enum.TextXAlignment.Left,
			TextTruncate           = Enum.TextTruncate.AtEnd,
			ZIndex                 = 13,
			Parent                 = card,
		})

		-- Label
		UI.New("TextLabel", {
			Size                   = UDim2.new(1, -16, 0, 18),
			Position               = UDim2.new(0, 12, 0, 20),
			BackgroundTransparency = 1,
			Text                   = entry.label,
			TextColor3             = Col.TextPrimary,
			Font                   = Enum.Font.GothamSemibold,
			TextSize               = 13,
			TextXAlignment         = Enum.TextXAlignment.Left,
			ZIndex                 = 13,
			Parent                 = card,
		})

		-- Description (if any)
		if entry.desc ~= "" then
			UI.New("TextLabel", {
				Size                   = UDim2.new(1, -16, 0, 14),
				Position               = UDim2.new(0, 12, 0, 40),
				BackgroundTransparency = 1,
				Text                   = entry.desc,
				TextColor3             = Col.TextDim,
				Font                   = Enum.Font.Gotham,
				TextSize               = 10,
				TextXAlignment         = Enum.TextXAlignment.Left,
				TextTruncate           = Enum.TextTruncate.AtEnd,
				ZIndex                 = 13,
				Parent                 = card,
			})
		end

		-- Invisible hit button (covers card)
		local hit = UI.New("TextButton", {
			Size                   = UDim2.new(1, 0, 1, 0),
			BackgroundTransparency = 1,
			Text                   = "",
			ZIndex                 = 14,
			Parent                 = card,
		})
		hit.MouseEnter:Connect(function()
			UI.Tween(card, { BackgroundColor3 = Col.HoverItem }, 0.1)
		end)
		hit.MouseLeave:Connect(function()
			UI.Tween(card, { BackgroundColor3 = Col.Section }, 0.1)
		end)
		hit.MouseButton1Click:Connect(function()
			-- Close overlay
			Axon.Search.Close()
			-- Activate the correct nav button
			local navEntry = Axon.UI.NavButtons[entry.page]
			if navEntry then
				if Axon.UI.ActiveButton and Axon.UI.ActiveButton ~= navEntry.btn then
					for _, nb in pairs(Axon.UI.NavButtons) do
						if nb.btn == Axon.UI.ActiveButton then nb.setActive(false); break end
					end
				end
				Axon.UI.ActiveButton = navEntry.btn
				navEntry.setActive(true)
			end
			Axon.Pages.Show(entry.page)
			-- Scroll to and flash-highlight the target row
			if entry.row and entry.row.Parent then
				task.spawn(function()
					task.wait(0.1)
					-- Scroll the row into view
					local scrollFrame = Axon.UI.ScrollFrame
					local rowAbsY     = entry.row.AbsolutePosition.Y
					local scrollAbsY  = scrollFrame.AbsolutePosition.Y
					local scrollH     = scrollFrame.AbsoluteSize.Y
					local canvasY     = scrollFrame.CanvasPosition.Y
					local rowRelY     = rowAbsY - scrollAbsY + canvasY
					-- Centre the row in the scroll frame, clamped to canvas bounds
					local targetY = rowRelY - (scrollH / 2) + (entry.row.AbsoluteSize.Y / 2)
					local maxY    = scrollFrame.AbsoluteCanvasSize.Y - scrollH
					targetY = math.clamp(targetY, 0, math.max(0, maxY))
					scrollFrame.CanvasPosition = Vector2.new(0, targetY)
					-- Flash highlight
					local orig = entry.row.BackgroundColor3
					UI.Tween(entry.row, { BackgroundColor3 = Col.Accent:Lerp(Col.Section, 0.45) }, 0.18)
					task.wait(0.5)
					UI.Tween(entry.row, { BackgroundColor3 = orig }, 0.4)
				end)
			end
		end)
	end

	-- Scroll back to top
	UI.SearchResults.CanvasPosition = Vector2.new(0, 0)
end

-- ── Open / Close ──────────────────────────────────────────

Axon.Search._savedNav = nil  -- stores the nav entry that was active when search opened

Axon.Search.Open = function()
	Axon.Search._open = true
	Axon.UI.SearchOverlay.Visible = true
	Axon.UI.SearchBox.Text = ""
	_ClearSearchResults()
	Axon.UI.SearchCountLbl.Text = "Type to search across all sections…"
	-- Deactivate whichever nav button is currently active
	Axon.Search._savedNav = nil
	if Axon.UI.ActiveButton then
		for _, nb in pairs(Axon.UI.NavButtons) do
			if nb.btn == Axon.UI.ActiveButton then
				Axon.Search._savedNav = nb
				nb.setActive(false)
				break
			end
		end
		Axon.UI.ActiveButton = nil
	end
	-- Accent the icon to show it's active
	Axon.UI.Tween(Axon.UI.SearchBtn,        { BackgroundColor3 = Axon.UI.Colors.ButtonHover }, 0.12)
	Axon.UI.Tween(Axon.UI.SearchLensStroke, { Color = Axon.UI.Colors.Accent }, 0.12)
	Axon.UI.Tween(Axon.UI.SearchHandle,     { BackgroundColor3 = Axon.UI.Colors.Accent }, 0.12)
	task.defer(function() Axon.UI.SearchBox:CaptureFocus() end)
end

Axon.Search.Close = function()
	Axon.Search._open = false
	Axon.UI.SearchOverlay.Visible = false
	-- Restore the nav button that was active before search opened
	if Axon.Search._savedNav then
		Axon.UI.ActiveButton = Axon.Search._savedNav.btn
		Axon.Search._savedNav.setActive(true)
		Axon.Search._savedNav = nil
	end
	-- Reset button fully — background and icon both back to dim state
	Axon.UI.Tween(Axon.UI.SearchBtn,        { BackgroundColor3 = Axon.UI.Colors.ButtonBg }, 0.12)
	Axon.UI.Tween(Axon.UI.SearchLensStroke, { Color = Axon.UI.Colors.TextSecondary }, 0.12)
	Axon.UI.Tween(Axon.UI.SearchHandle,     { BackgroundColor3 = Axon.UI.Colors.TextSecondary }, 0.12)
	pcall(function() Axon.UI.SearchBox:ReleaseFocus() end)
end

