	-- ══════════════════════════════════════════════════════════
	-- MISC PAGE: Restore Saved State on Load
	-- (queued into _postLoadFns so nothing fires before the loading screen dismisses)
	-- ══════════════════════════════════════════════════════════

	table.insert(Axon._postLoadFns, function()

		-- ── Time of Day ─────────────────────────────────────────
		local savedTod = Axon.Settings.Data.miscTod
		if type(savedTod) == "number" then
			SetTODSlider(savedTod, true)
		end

		-- ── Real Time ────────────────────────────────────────────
		if Axon.Settings.Data.miscRealTime then
			SetRealTime(true)
		end

		-- ── Infinite Baseplate ───────────────────────────────────
		-- C.Toggle handles the visual; re-apply the runtime effect here
		if Axon.Settings.Data.miscBaseplate then
			bpCustomFrame.Visible = true
			-- Apply saved material and color before starting the loop so the
			-- very first BPUpdate call uses the correct values.
			local mat = Enum.Material[Axon.Settings.Data.miscBpMaterial or "Grass"]
			if mat then Misc.bpMaterial = mat end
			local ci = Axon.Settings.Data.miscBpColorIdx or 1
			if BP_SWATCHES[ci] then Misc.bpColor = BP_SWATCHES[ci] end
			local char = Axon.Services.Player.Character
			local root = char and char:FindFirstChild("HumanoidRootPart")
			local hum  = char and char:FindFirstChildOfClass("Humanoid")
			local hipH = hum and hum.HipHeight or 2.3
			local isR6 = hum and hum.RigType == Enum.HumanoidRigType.R6
			-- R6 needs a larger offset than R15 due to rig geometry differences
			Misc.baseplateBaseY = root and (root.Position.Y - hipH - (isR6 and 3.01 or 1.01)) or 0
			Misc.baseplateEnabled = true
			if Misc.baseplateConn then Misc.baseplateConn:Disconnect() end
			Misc.baseplateConn = Axon.Services.RunService.Heartbeat:Connect(function()
				if Misc.baseplateEnabled then BPUpdate() end
			end)
		end

		-- ── Auto Clicker key binding + toggle ───────────────────
		if _miscRestoreAutoClick then _miscRestoreAutoClick() end

		-- ── Fake Out key binding ─────────────────────────────────
		if _miscRestoreFakeOutKey then _miscRestoreFakeOutKey() end

		-- ── Auto Fake Out ────────────────────────────────────────
		if Axon.Settings.Data.miscAutoFakeOut then
			SetAutoFakeOut(true)
		end

		-- ── Respawn to Last Location ─────────────────────────────
		-- C.Toggle visual restored via key; apply runtime flags here
		if Axon.Settings.Data.miscRespawn then
			Misc.respawnEnabled = true
			Axon._respawnEnabled = true
		end

		-- ── Anti AFK ─────────────────────────────────────────────
		if Axon.Settings.Data.miscAntiAfk and not Misc.antiAfkConn then
			local VU = game:GetService("VirtualUser")
			Misc.antiAfkConn = Axon.Services.Players.LocalPlayer.Idled:Connect(function()
				VU:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
				task.wait(1)
				VU:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
			end)
		end

		-- ── Anti Gameplay Paused ─────────────────────────────────
		if Axon.Settings.Data.miscAntiPaused and not Misc.antiGameplayPausedConn then
			local coreGui = game:GetService("CoreGui")
			local robloxGui = coreGui:FindFirstChild("RobloxGui")
			if robloxGui then
				local existing = robloxGui:FindFirstChild("CoreScripts/NetworkPause")
				if existing then existing:Destroy() end
				Misc.antiGameplayPausedConn = robloxGui.ChildAdded:Connect(function(obj)
					if obj.Name == "CoreScripts/NetworkPause" then obj:Destroy() end
				end)
			end
		end

		-- ── No Sit ───────────────────────────────────────────────
		if Axon.Settings.Data.miscNoSit then
			Misc.noSitEnabled = true
			ApplyNoSit(true)
		end

		-- ── Chat Spy ─────────────────────────────────────────────
		if Axon.Settings.Data.miscChatSpy then
			SetChatSpy(true)
		end

		-- ── Chat Spam ────────────────────────────────────────────
		if Axon.Settings.Data.miscChatSpam then
			SetChatSpam(true)
		end

		-- ── Crosshair ────────────────────────────────────────────
		-- Always restore CH property values so they're correct if crosshair is
		-- later enabled, even if it was disabled when the save was made.
		do
			local ci = Axon.Settings.Data.miscCrossColorIdx or 1
			if colorSwatches[ci] then CH.color = colorSwatches[ci] end
			CH.dot              = Axon.Settings.Data.miscCrossDot              or false
			CH.outline          = Axon.Settings.Data.miscCrossOutline          or false
			CH.replaceCursor    = Axon.Settings.Data.miscCrossReplaceCursor    or false
			CH.replaceShiftLock = Axon.Settings.Data.miscCrossReplaceShiftLock or false
			CH.shiftLockOnly    = Axon.Settings.Data.miscCrossShiftLockOnly    or false
			-- Sliders call onChange on init so CH.size/thickness/gap/opacity are
			-- already set; the color swatch and booleans above are the only ones
			-- that needed explicit restoration here.
		end

		-- Only activate the renderer if crosshair was enabled when saved.
		if Axon.Settings.Data.miscCrosshair then
			CH.enabled = true
			SetAllVisible(true)
			StartRender()
			ApplyCursor()
			crossCustomFrame.Visible = true
			if setCrosshairPill then setCrosshairPill(true, true) end
		end

		-- ── Free Cam ─────────────────────────────────────────────
		if Axon.Settings.Data.miscFreeCam and _setFreeCam then
			_setFreeCam(true)
		end

		-- ── Shaders ───────────────────────────────────────────────
		-- Sky preset
		if Axon.Settings.Data.miscSkyPreset and Axon.Settings.Data.miscSkyPreset ~= "Default" then
			ApplySkyPreset(Axon.Settings.Data.miscSkyPreset)
		end
		-- Atmosphere
		if Axon.Settings.Data.miscAtmosphere then
			atmoCustomFrame.Visible = true
			local a = GetOrCreate("Atmosphere", "AxonAtmosphere")
			a.Density = Axon.Settings.Data.miscAtmoDensity or 0.395
			a.Offset  = Axon.Settings.Data.miscAtmoOffset  or 0.25
			a.Glare   = Axon.Settings.Data.miscAtmoGlare   or 0
			a.Haze    = Axon.Settings.Data.miscAtmoHaze    or 0
		end
		-- Bloom
		if Axon.Settings.Data.miscBloom then
			bloomCustomFrame.Visible = true
			local b = GetOrCreate("BloomEffect", "AxonBloom")
			b.Intensity = Axon.Settings.Data.miscBloomIntensity or 0.9
			b.Size      = Axon.Settings.Data.miscBloomSize      or 24
			b.Threshold = Axon.Settings.Data.miscBloomThreshold or 0.95
		end
		-- Color Correction
		if Axon.Settings.Data.miscColorCorrection then
			ccCustomFrame.Visible = true
			local cc = GetOrCreate("ColorCorrectionEffect", "AxonColorCorrection")
			cc.Brightness = Axon.Settings.Data.miscCCBrightness or 0
			cc.Contrast   = Axon.Settings.Data.miscCCContrast   or 0
			cc.Saturation = Axon.Settings.Data.miscCCSaturation or 0
			local tint = Axon.Settings.Data.miscCCTint or "None"
			cc.TintColor = CC_TINTS[tint] or Color3.fromRGB(255, 255, 255)
		end
		-- Sun Rays
		if Axon.Settings.Data.miscSunRays then
			srCustomFrame.Visible = true
			local s = GetOrCreate("SunRaysEffect", "AxonSunRays")
			s.Intensity = Axon.Settings.Data.miscSunRaysIntensity or 0.25
			s.Spread    = Axon.Settings.Data.miscSunRaysSpread    or 0.5
		end
		-- Blur
		if Axon.Settings.Data.miscBlur then
			blurCustomFrame.Visible = true
			local b = GetOrCreate("BlurEffect", "AxonBlur")
			b.Size = Axon.Settings.Data.miscBlurSize or 10
		end
		-- Depth of Field
		if Axon.Settings.Data.miscDOF then
			dofCustomFrame.Visible = true
			local d = GetOrCreate("DepthOfFieldEffect", "AxonDOF")
			d.FarIntensity  = Axon.Settings.Data.miscDofFarIntensity  or 0.1
			d.FocusDistance = Axon.Settings.Data.miscDofFocusDist     or 25
			d.InFocusRadius = Axon.Settings.Data.miscDofInFocusRadius or 12
			d.NearIntensity = Axon.Settings.Data.miscDofNearIntensity or 0
		end
	end)

	-- Register Misc cleanup for unload
	table.insert(Axon._cleanupFns, function()
		-- Real time clock
		if rtConn then pcall(function() rtConn:Disconnect() end); rtConn = nil end
		-- Baseplate
		if Misc.baseplateConn then pcall(function() Misc.baseplateConn:Disconnect() end); Misc.baseplateConn = nil end
		Misc.baseplateEnabled = false
		local bpFolder = workspace:FindFirstChild("AxonBaseplateFolder")
		if bpFolder then pcall(function() bpFolder:Destroy() end) end
		Misc.baseplateChunks = {}; Misc.baseplateFolders = {}
		-- Auto fake out
		if afoConn then pcall(function() afoConn:Disconnect() end); afoConn = nil end
		afoOn = false
		pcall(DestroyRangeViz)
		-- Anti AFK / Anti Paused
		if Misc.antiAfkConn then pcall(function() Misc.antiAfkConn:Disconnect() end); Misc.antiAfkConn = nil end
		if Misc.antiGameplayPausedConn then pcall(function() Misc.antiGameplayPausedConn:Disconnect() end); Misc.antiGameplayPausedConn = nil end
		-- Anti Fling
		if Misc.antiFlingConn     then pcall(function() Misc.antiFlingConn:Disconnect()     end); Misc.antiFlingConn     = nil end
		if Misc.antiFlingCharConn then pcall(function() Misc.antiFlingCharConn:Disconnect() end); Misc.antiFlingCharConn = nil end
		-- Admin Check
		if Misc.adminCheckJoinConn  then pcall(function() Misc.adminCheckJoinConn:Disconnect()  end); Misc.adminCheckJoinConn  = nil end
		if Misc.adminCheckLeaveConn then pcall(function() Misc.adminCheckLeaveConn:Disconnect() end); Misc.adminCheckLeaveConn = nil end
		-- Reset auto-hop and auto-kick flags so they don't fire after unload
		Axon.Settings.Data.miscAdminAutoHop  = false
		Axon.Settings.Data.miscAdminAutoKick = false
		-- No Sit
		if Misc.noSitCharConn then pcall(function() Misc.noSitCharConn:Disconnect() end); Misc.noSitCharConn = nil end
		pcall(function()
			local char = Axon.Services.Player.Character
			if char then
				local h = char:FindFirstChildOfClass("Humanoid")
				if h then h:SetStateEnabled(Enum.HumanoidStateType.Seated, true) end
			end
		end)
		-- Full Bright
		if Misc.fullBrightOff then pcall(Misc.fullBrightOff) end
		-- Chat spy/spam
		if chatSpyConn then pcall(function() chatSpyConn:Disconnect() end); chatSpyConn = nil end
		chatSpyOn = false
		if Misc.chatSpamConn then pcall(function() Misc.chatSpamConn:Disconnect() end); Misc.chatSpamConn = nil end
		-- Free cam
		pcall(DisconnectFreeCam)
		pcall(function() Axon.Services.UserInputService.MouseBehavior = Enum.MouseBehavior.Default end)
		pcall(function()
			local char = Axon.Services.Player.Character
			if char then
				local h = char:FindFirstChildOfClass("Humanoid")
				local root = char:FindFirstChild("HumanoidRootPart")
				if h then
					h.WalkSpeed  = Misc.savedWalkSpeed or 16
					h.JumpPower  = Misc.savedJumpPower or 50
					h.AutoRotate = true
				end
				if root then
					local fc = root:FindFirstChild("AxonFCBV")
					local fg = root:FindFirstChild("AxonFCBG")
					if fc then fc:Destroy() end
					if fg then fg:Destroy() end
				end
			end
			-- Restore camera to Roblox-controlled mode
			local cam = workspace.CurrentCamera
			if cam then cam.CameraType = Enum.CameraType.Custom end
		end)
		-- Crosshair
		CH.enabled = false
		pcall(StopRender)
		pcall(SetAllVisible, false)
		pcall(function() Axon.Services.UserInputService.MouseIconEnabled = true end)
		if CH.shiftLockConn then pcall(function() CH.shiftLockConn:Disconnect() end); CH.shiftLockConn = nil end
		pcall(function() if crossGui and crossGui.Parent then crossGui:Destroy() end end)
		-- Shaders — remove all Axon lighting effects
		for _, name in ipairs({"AxonAtmosphere","AxonBloom","AxonColorCorrection","AxonSunRays","AxonBlur","AxonDOF"}) do
			pcall(RemoveShaderInst, name)
		end
		-- Restore original skybox
		pcall(function()
			local sky = Lighting:FindFirstChildOfClass("Sky")
			if sky and origSkybox then
				for k, v in pairs(origSkybox) do pcall(function() sky[k] = v end) end
			end
		end)
	end)
end

