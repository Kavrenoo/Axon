		local months = math.floor((age % 365) / 30)
		local ageStr = (years > 0 and years .. "y " or "") .. months .. "m old"
		if infoLabels.age then infoLabels.age.Text = "Age: " .. ageStr end

		task.spawn(function()
			local ok, isFriend = pcall(function() return PLR:IsFriendsWith(plr.UserId) end)
			if infoLabels.friend then
				infoLabels.friend.Text       = "Friend: " .. (ok and (isFriend and "Yes" or "No") or "?")
				infoLabels.friend.TextColor3 = Col.TextSecondary
			end
			local ok2, pages = pcall(function() return Players:GetFriendsAsync(plr.UserId) end)
			if ok2 and pages and infoLabels.friendcount then
				local count = 0
				pcall(function()
					while true do
						for _ in pairs(pages:GetCurrentPage()) do count = count + 1 end
						if pages.IsFinished then break end
						pages:AdvanceToNextPageAsync()
					end
				end)
				infoLabels.friendcount.Text = "Friends: " .. count
			elseif infoLabels.friendcount then
				infoLabels.friendcount.Text = "Friends: ?"
			end
		end)

		local mem    = plr.MembershipType
		local memStr = mem == Enum.MembershipType.Premium and "Premium" or "None"
		if infoLabels.mem  then infoLabels.mem.Text  = "Membership: " .. memStr end
		if infoLabels.team then
			infoLabels.team.Text = plr.Team and ("Team: " .. plr.Team.Name) or "Team: None"
		end

		-- Outfit price
		if infoLabels.outfitprice then
			infoLabels.outfitprice.Text = "Outfit: loading..."
		end
		task.spawn(function()
			local MPS = game:GetService("MarketplaceService")
			local ok, appearance = pcall(function()
				return Players:GetCharacterAppearanceInfoAsync(plr.UserId)
			end)
			if not ok or not appearance then
				if infoLabels.outfitprice then infoLabels.outfitprice.Text = "Outfit: ?" end
				return
			end
			local total = 0
			local assets = appearance.assets or {}
			for _, asset in ipairs(assets) do
				local aid = asset.id or asset.assetId
				if aid then
					local ok2, info = pcall(function()
						return MPS:GetProductInfo(aid, Enum.InfoType.Asset)
					end)
					if ok2 and info and info.PriceInRobux then
						total = total + info.PriceInRobux
					end
				end
			end
			if infoLabels.outfitprice then
				infoLabels.outfitprice.Text = "Outfit: R$" .. tostring(total)
			end
		end)
	end

