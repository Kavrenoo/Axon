	-- ── Rewind: global key listener (Toggle or Hold) ─────────
	local SetRunBtnStateRef  -- forward ref, set after UI is built
	local function DoRewindStart()
		if Char.rewindPlaying then return end
		if #Char.rewindBuffer < 2 then return end
		Char.rewindPlaying = true; Char.rewindStopRequest = false
		if SetRunBtnStateRef then SetRunBtnStateRef(true) end
		task.spawn(function()
			local buf = Char.rewindBuffer; local i = #buf
			while i >= 1 and not Char.rewindStopRequest do
				local _, root = GetHR(); if not root then break end
				root.CFrame = buf[i]
				local step = math.max(1, math.floor(Char.rewindSpeed))
				i = i - step; task.wait(1 / (60 * Char.rewindSpeed))
			end
			Char.rewindPlaying = false; Char.rewindStopRequest = false
			if SetRunBtnStateRef then SetRunBtnStateRef(false) end
			-- Zero velocity to prevent flinging after rewind ends / is toggled off
			local _, root2 = GetHR()
			if root2 then
				root2.AssemblyLinearVelocity  = Vector3.zero
				root2.AssemblyAngularVelocity = Vector3.zero
			end
			-- Unragdoll the character when rewind stops
			local h = GetHR()
			if h then
				h:ChangeState(Enum.HumanoidStateType.GettingUp)
			end
		end)
	end
	local function DoRewindStop()
		if Char.rewindPlaying then Char.rewindStopRequest = true end
	end
