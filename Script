		end
		local rowH = desc and 72 or 62
		local row  = Axon.UI.New("Frame", {
			Size = UDim2.new(1, 0, 0, rowH), BackgroundColor3 = Axon.UI.Colors.Section,
			BorderSizePixel = 0, LayoutOrder = order,
		}, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Border, 1) })
		row.Parent = sVis
		Axon.UI.New("TextLabel", {
			Size = UDim2.new(1, -80, 0, 20), Position = UDim2.new(0, 12, 0, 8),
			BackgroundTransparency = 1, Text = label,
			TextColor3 = Axon.UI.Colors.TextPrimary, Font = Enum.Font.GothamSemibold,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
		})
		if desc then
			Axon.UI.New("TextLabel", {
				Size = UDim2.new(1, -80, 0, 14), Position = UDim2.new(0, 12, 0, 28),
				BackgroundTransparency = 1, Text = desc,
				TextColor3 = Axon.UI.Colors.TextDim, Font = Enum.Font.Gotham,
				TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left, Parent = row,
			})
		end
		local sliderY = desc and 50 or 40
		local valLbl  = Axon.UI.New("TextLabel", {
			Size = UDim2.new(0, 70, 0, 20), Position = UDim2.new(1, -82, 0, 8),
			BackgroundTransparency = 1, Text = tostring(vDef),
			TextColor3 = Axon.UI.Colors.Accent, Font = Enum.Font.GothamBold,
			TextSize = 13, TextXAlignment = Enum.TextXAlignment.Right, Parent = row,
		})
		local track = Axon.UI.New("Frame", {
			Size = UDim2.new(1, -24, 0, 4), Position = UDim2.new(0, 12, 0, sliderY),
			BackgroundColor3 = Axon.UI.Colors.SliderTrack, BorderSizePixel = 0,
		}, { Axon.UI.Corner(2) })
		track.Parent = row
		local initR = (vDef - vMin) / (vMax - vMin)
		local fill  = Axon.UI.New("Frame", { Size = UDim2.new(initR, 0, 1, 0), BackgroundColor3 = Axon.UI.Colors.SliderFill, BorderSizePixel = 0 }, { Axon.UI.Corner(2) })
		fill.Parent = track
		local knob = Axon.UI.New("Frame", { Size = UDim2.new(0, 12, 0, 12), Position = UDim2.new(initR, -6, 0.5, -6), BackgroundColor3 = C3new(1,1,1), BorderSizePixel = 0, ZIndex = 2 }, { Axon.UI.Corner(6) })
		knob.Parent = track
		local currentVal = vDef
		local function SetVal(v, isReset, skipSave)
			v = clamp(math.round(v), vMin, vMax); currentVal = v
			local r = (v - vMin) / (vMax - vMin)
			fill.Size = UDim2.new(r, 0, 1, 0); knob.Position = UDim2.new(r, -6, 0.5, -6)
			valLbl.Text = tostring(v); onChange(v)
			if saveKey and not skipSave then Axon.Settings.Data[saveKey] = v; Axon.Settings.Save() end
			if isReset then fill.BackgroundColor3 = C3new(1,1,1); task.delay(0.12, function() Axon.UI.Tween(fill, { BackgroundColor3 = Axon.UI.Colors.SliderFill }, 0.2) end) end
		end
		SetVal(vDef, false, true)
		local dragging = false; local lastClick = 0
		local hitArea = Axon.UI.New("TextButton", { Size = UDim2.new(1, -24, 0, 28), Position = UDim2.new(0, 12, 0, sliderY-10), BackgroundTransparency=1, Text="", ZIndex=5, Parent=row })
		hitArea.InputBegan:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 then
				local now = tick()
				if now - lastClick < 0.35 then SetVal(vDefOrig, true); lastClick = 0; dragging = false; return end
				lastClick = now; dragging = true
				SetVal(vMin + (vMax-vMin) * clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1))
			end
		end)
		local _vsChangedConn = UserInputService.InputChanged:Connect(function(inp)
			if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
				SetVal(vMin + (vMax-vMin) * clamp((inp.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1), false, true)
			end
		end)
		local _vsEndedConn = UserInputService.InputEnded:Connect(function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
				dragging = false
				if saveKey then Axon.Settings.Data[saveKey] = currentVal; Axon.Settings.Save() end
			end
		end)
		table.insert(Axon._cleanupFns, function()
			if _vsChangedConn then _vsChangedConn:Disconnect(); _vsChangedConn = nil end
			if _vsEndedConn   then _vsEndedConn:Disconnect();   _vsEndedConn   = nil end
		end)
		local inputOpen = false
		local function OpenInput()
			if inputOpen then return end; inputOpen = true
			Axon.UI.Tween(row, { BackgroundColor3 = Axon.UI.Colors.ActiveItem }, 0.1)
			local overlay = Axon.UI.New("Frame", { Size=UDim2.new(1,0,1,0), BackgroundColor3=Axon.UI.Colors.Section, BorderSizePixel=0, ZIndex=20 }, { Axon.UI.Corner(6) })
			overlay.Parent = row
			Axon.UI.New("TextLabel", { Size=UDim2.new(1,-120,1,0), Position=UDim2.new(0,12,0,0), BackgroundTransparency=1, Text=label.."  ("..tostring(vMin).." – "..tostring(vMax)..")", TextColor3=Axon.UI.Colors.TextSecondary, Font=Enum.Font.Gotham, TextSize=11, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=21, Parent=overlay })
			local box = Axon.UI.New("TextBox", { Size=UDim2.new(0,90,0,26), Position=UDim2.new(1,-104,0.5,-13), BackgroundColor3=Axon.UI.Colors.SliderTrack, Text=tostring(currentVal), TextColor3=Axon.UI.Colors.TextPrimary, Font=Enum.Font.GothamBold, TextSize=13, ClearTextOnFocus=true, BorderSizePixel=0, ZIndex=21 }, { Axon.UI.Corner(6), Axon.UI.Stroke(Axon.UI.Colors.Accent,1) })
			box.Parent = overlay
			local confirmed = false; task.wait(); box:CaptureFocus()
			local function Confirm()
				if confirmed then return end; confirmed = true
				local num = tonumber(box.Text)
				if num then SetVal(num) else SetVal(vDefOrig, true) end
				if overlay.Parent then overlay:Destroy() end
				Axon.UI.Tween(row, { BackgroundColor3 = Axon.UI.Colors.Section }, 0.1); inputOpen = false
			end
			box.FocusLost:Connect(Confirm); task.wait(); task.wait()
			local oc; oc = UserInputService.InputBegan:Connect(function(inp)
				if inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
				local m = UserInputService:GetMouseLocation(); local ab = overlay.AbsolutePosition; local sz = overlay.AbsoluteSize
				if not (m.X >= ab.X and m.X <= ab.X+sz.X and m.Y >= ab.Y and m.Y <= ab.Y+sz.Y) then oc:Disconnect(); box:ReleaseFocus(); Confirm() end
			end)
		end
		hitArea.MouseButton2Click:Connect(OpenInput)
	end

