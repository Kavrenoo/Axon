	local function PlayAnimOnSelf(animId)
		local h = MyHum(); if not h then return end
		if T._animTrack then pcall(function() T._animTrack:Stop() end); T._animTrack = nil end
		local anim = Instance.new("Animation")
		anim.AnimationId = "rbxassetid://" .. tostring(animId)
		local ok, track = pcall(function() return h:LoadAnimation(anim) end)
		if ok and track then track:Play(); T._animTrack = track end
	end
	local function StopAnimOnSelf()
		if T._animTrack then pcall(function() T._animTrack:Stop() end); T._animTrack = nil end
	end

