	-- ══════════════════════════════════════════════════════════
	-- INVISIBILITY  (fake-clone under-map method)
	-- ══════════════════════════════════════════════════════════

	do
		-- ── Core logic ────────────────────────────────────────

		local invisPart = nil  -- anchored platform the fake character stands on

		local function EndInvis()
			if not Char.invisOn then return end
			Char.invisOn = false

			if Char.invisHoldConn then Char.invisHoldConn:Disconnect(); Char.invisHoldConn = nil end

			local player = Axon.Services.Player

			-- Restore Player.Character to the real character
			pcall(function()
				local realChar = Char.invisRealChar
				if realChar and realChar.Parent then
					local hrp = realChar:FindFirstChild("HumanoidRootPart")
					if hrp then
						-- Teleport real char to wherever the fake character ended up
						local fakeChar = Char.invisFakeModel
						local fakeHRP = fakeChar and fakeChar:FindFirstChild("HumanoidRootPart")
						if fakeHRP then
							hrp.CFrame = fakeHRP.CFrame
						elseif Char.invisSavedCF then
							hrp.CFrame = Char.invisSavedCF  -- fallback to original position
						end
					end
					-- Unequip tools from fake before swapping back
					local fakeChar = Char.invisFakeModel
					if fakeChar then
						local fakeHum = fakeChar:FindFirstChildOfClass("Humanoid")
						if fakeHum then pcall(function() fakeHum:UnequipTools() end) end
					end
					player.Character = realChar
				end
			end)

			-- Restore camera
			pcall(function()
				if Char.invisSavedSubject then
					workspace.CurrentCamera.CameraSubject = Char.invisSavedSubject
				end
			end)
			Char.invisSavedSubject = nil

			-- Destroy fake clone and platform
			if Char.invisFakeModel then
				pcall(function() Char.invisFakeModel:Destroy() end)
				Char.invisFakeModel = nil
			end
			if invisPart then
				pcall(function() invisPart:Destroy() end)
				invisPart = nil
			end

			Char.invisSavedCF   = nil
			Char.invisRealChar  = nil

			-- Restore void height
			if Char.invisSavedVoid then
				task.wait(0.05)
				workspace.FallenPartsDestroyHeight = Char.invisSavedVoid
				Char.invisSavedVoid = nil
			end
			Axon._intentionalBelowVoid = false

			-- Reset the pill so the UI reflects the off state
			if Char.setInvisVisual then Char.setInvisVisual(false) end
		end

		local function BeginInvis()
			if Char.invisOn then return end
			local _, myRoot = GetHR()
			local player    = Axon.Services.Player
			local realChar  = player.Character
			if not myRoot or not realChar then return end

			-- ── 0. Save real position FIRST, before anything moves ─
			local savedCF = myRoot.CFrame

			-- ── 1. Clone real character ──────────────────────────
			realChar.Archivable = true
			local fakeChar = realChar:Clone()
			if not fakeChar then return end
			fakeChar.Name = "AxonInvisClone"

			-- Disable LocalScripts inside the clone EXCEPT "Animate" — that script drives all animations.
			-- Destroying the Humanoid is also off-limits since it drives Motor6Ds.
			for _, obj in ipairs(fakeChar:GetDescendants()) do
				pcall(function()
					if obj:IsA("LocalScript") and obj.Name ~= "Animate" then
						obj.Disabled = true
					end
				end)
			end

			-- Make all visible parts semi-transparent (0.6) so the fake looks ghost-like.
			-- HumanoidRootPart stays fully invisible (it's never shown anyway).
			for _, obj in ipairs(fakeChar:GetDescendants()) do
				pcall(function()
					if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
						obj.Transparency = math.max(obj.Transparency, 0.6)
					end
				end)
			end

			-- ── 2. Create platform under map for real char to land on ─
			local platform = Instance.new("Part")
			platform.Name         = "AxonInvisPlatform"
			platform.Anchored     = true
			platform.CanCollide   = true
			platform.Size         = Vector3.new(3, 5, 3)
			platform.Transparency = 1
			platform.CFrame       = CFrame.new(myRoot.Position.X, -653, myRoot.Position.Z)
			platform.Parent       = workspace
			invisPart = platform

			-- ── 3. Parent fake, position it at the ORIGINAL surface position ─
			fakeChar.Parent = workspace
			local fakeHRP = fakeChar:FindFirstChild("HumanoidRootPart")
			if fakeHRP then
				fakeHRP.CFrame = savedCF  -- place fake where the real char was, not underground
			end

			-- ── 4. Save state, swap Player.Character to fake ─────
			Char.invisOn        = true
			Char.invisSavedCF   = savedCF
			Char.invisSavedVoid = workspace.FallenPartsDestroyHeight
			Char.invisRealChar  = realChar
			Char.invisFakeModel = fakeChar

			Char.invisSavedSubject = workspace.CurrentCamera.CameraSubject

			-- Move real char under the map, then let the platform hold it up
			workspace.FallenPartsDestroyHeight = -99999
			Axon._intentionalBelowVoid = true
			myRoot.AssemblyLinearVelocity  = Vector3.zero
			myRoot.AssemblyAngularVelocity = Vector3.zero
			myRoot.CFrame = CFrame.new(myRoot.Position.X, -648, myRoot.Position.Z)

			-- Wait a frame so the teleport replicates before the character swap
			task.wait()

			-- Freeze real char animations (same as fly does)
			local realAnimScript = realChar:FindFirstChild("Animate")
			if realAnimScript then realAnimScript.Disabled = true end
			local realHumForAnim = realChar:FindFirstChildOfClass("Humanoid")
			if realHumForAnim then
				for _, tr in ipairs(realHumForAnim:GetPlayingAnimationTracks()) do tr:Stop(0) end
			end
			task.wait()
			for _, m in ipairs(realChar:GetDescendants()) do
				if m:IsA("Motor6D") then m.Transform = CFrame.new() end
			end
			if realAnimScript then realAnimScript.Disabled = false end

			-- Swap: game now thinks fake IS the character
			player.Character = fakeChar
			workspace.CurrentCamera.CameraSubject = fakeChar:FindFirstChildOfClass("Humanoid") or fakeHRP

			-- Restart the Animate script so it re-binds to the fake humanoid's state events.
			-- It was already running before the character swap, so its connections point at the wrong context.
			task.defer(function()
				local animate = fakeChar:FindFirstChild("Animate")
				if animate and animate:IsA("LocalScript") then
					animate.Disabled = true
					task.wait()
					animate.Disabled = false
				end
			end)

			-- Real char is standing on the platform. Move the platform every frame
			-- to follow the fake's X/Z — the real char rides it naturally.
			Char.invisHoldConn = Axon.Services.RunService.RenderStepped:Connect(function()
				if not fakeHRP or not fakeHRP.Parent then return end
				if not platform or not platform.Parent then return end
				platform.CFrame = CFrame.new(fakeHRP.Position.X, -653, fakeHRP.Position.Z)
			end)

			-- On death, fully turn off invisibility
			local fakeHum = fakeChar:FindFirstChildOfClass("Humanoid")
			if fakeHum then
				fakeHum.Died:Connect(function()
					if Char.invisOn then EndInvis() end
				end)
			end
		end

		-- ── Key restore helper ────────────────────────────────

		local function EnableInvisKeyListener()
			if Char.invisKeyConn then return end
			Char.invisKeyConn = Axon.Services.UserInputService.InputBegan:Connect(function(input, gpe)
				if Axon._loading or gpe or Char.invisCapturing then return end
				if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Char.invisKey then
					if Char.invisOn then EndInvis() else BeginInvis() end
				end
			end)
		end

		do
			local saved = Axon.Settings.Data.charInvisKey
			if type(saved) == "string" and saved ~= "" then
				local ok, kc = pcall(function() return Enum.KeyCode[saved] end)
				if ok and kc then Char.invisKey = kc; EnableInvisKeyListener() end
			end
		end

		-- ── UI row  (mirrors fly row layout exactly) ──────────

		local invisRow = Axon.UI.New("Frame", {
