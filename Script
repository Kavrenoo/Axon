Axon.UI.MakeDraggable = function(win, handle)
	local drag, dragStart, startPos = false, nil, nil
	handle.InputBegan:Connect(function(inp)
		if Axon._loading then return end
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			drag = true; dragStart = inp.Position; startPos = win.Position
		end
	end)
	local _dragChangedConn = Axon.Services.UserInputService.InputChanged:Connect(function(inp)
		if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local d = inp.Position - dragStart
			win.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + d.X,
				startPos.Y.Scale, startPos.Y.Offset + d.Y)
		end
	end)
	local _dragEndedConn = Axon.Services.UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
	end)
	table.insert(Axon._cleanupFns, function()
		if _dragChangedConn then _dragChangedConn:Disconnect(); _dragChangedConn = nil end
		if _dragEndedConn   then _dragEndedConn:Disconnect();   _dragEndedConn   = nil end
	end)
end

