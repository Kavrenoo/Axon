				else -- Hold
					Char.rewindKeyHeld = true
					DoRewindStart()
				end
			end
		end)
		if Char.rewindKeyEndConn then Char.rewindKeyEndConn:Disconnect(); Char.rewindKeyEndConn = nil end
		Char.rewindKeyEndConn = Axon.Services.UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Char.rewindKey then
				Char.rewindKeyHeld = false
				if Char.rewindKeyStyle == "Hold" then DoRewindStop() end
			end
		end)
	end
	RewindEnableGlobal()

