			if enabled then
				CaptureOriginalLighting()
				game.Lighting.Ambient        = Color3.fromRGB(255, 255, 255)
				game.Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
				game.Lighting.Brightness     = 2
				game.Lighting.FogEnd         = 999999
				game.Lighting.FogStart       = 999999
			else
				if fbOrigAmbient        then game.Lighting.Ambient        = fbOrigAmbient        end
				if fbOrigOutdoorAmbient then game.Lighting.OutdoorAmbient = fbOrigOutdoorAmbient end
				if fbOrigBrightness     then game.Lighting.Brightness     = fbOrigBrightness     end
				if fbOrigFogEnd         then game.Lighting.FogEnd         = fbOrigFogEnd         end
				if fbOrigFogStart       then game.Lighting.FogStart       = fbOrigFogStart       end
			end
		end
