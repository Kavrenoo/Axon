		tracerTeamCheck   = true,
		tracerMaxDist     = 500,
		healthBarColor    = C3rgb(60, 220, 60),
		skeleton          = false,
		skeletonColor     = C3rgb(255, 255, 255),
		skeletonThickness = 1,
		skelTeamCheck     = true,
		skelMaxDist       = 500,
		teamCheck         = true,
		maxDistance       = 500,
		enemyColor        = C3rgb(255, 60, 60),
		teamColor         = C3rgb(60, 180, 255),
		tracerEnemyColor  = C3rgb(255, 60, 60),
		tracerTeamColor   = C3rgb(60, 180, 255),
		skelEnemyColor    = C3rgb(255, 60, 60),
		skelTeamColor     = C3rgb(60, 180, 255),
		-- ── Highlight ESP ──────────────────────────────────────────
		highlight              = false,
		highlightTeamCheck     = true,
		highlightMaxDist       = 500,
		highlightFillTransp    = 0.5,   -- 0 = opaque, 1 = invisible
		highlightOutlineTransp = 0,
		highlightEnemyFill     = C3rgb(255, 60, 60),
		highlightTeamFill      = C3rgb(60, 180, 255),
		highlightEnemyOutline  = C3rgb(255, 60, 60),
		highlightTeamOutline   = C3rgb(60, 180, 255),
	}
	local ESP_FPS           = 20
	local ESP_TRACER_FPS    = 20
	local ESP_SKEL_FPS      = 20
	local ESP_HIGHLIGHT_FPS = 20

	local espObjects = {}

	-- ── Character data cache ───────────────────────────────────────
	local charCache = {}  -- [plr] = { char, root, head, hum }
	local bbCache   = {}  -- [plr] = { char, hw, hh, hd, yOff }

	local function RefreshCharCache(plr)
		local char = plr.Character
		if not char then charCache[plr] = nil; bbCache[plr] = nil; return end
		local root = char:FindFirstChild("HumanoidRootPart")
		local head = char:FindFirstChild("Head")
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if root and head and hum then
			charCache[plr] = { char=char, root=root, head=head, hum=hum }
		else
			charCache[plr] = nil
		end
		if root then
			local ok, bbCF, bbSize = pcall(function() return char:GetBoundingBox() end)
			if ok and bbCF and bbSize then
				bbCache[plr] = {
					char = char,
					hw   = bbSize.X * 0.5,
					hh   = bbSize.Y * 0.5,
					hd   = bbSize.Z * 0.5,
					yOff = bbCF.Position.Y - root.Position.Y,
				}
			else
				bbCache[plr] = nil
			end
		else
			bbCache[plr] = nil
		end
	end

	local function NewDrawing(class, props)
		local d = Drawing.new(class)
		for k, v in pairs(props) do d[k] = v end
		return d
	end

	local function GetESPColor(plr)
		if ESP.teamCheck and IsTeammate(plr) then return ESP.teamColor end
		return ESP.enemyColor
	end

	local function CreateESPObjects(plr)
		if espObjects[plr] then return end
		local skel = {}
		for i = 1, 20 do
			skel[i] = NewDrawing("Line", { Visible = false, Color = ESP.skeletonColor, Thickness = 1 })
		end
		espObjects[plr] = {
			box        = NewDrawing("Square", { Visible=false, Filled=false, Color=ESP.enemyColor, Thickness=1 }),
			name       = NewDrawing("Text",   { Visible=false, Text="", Color=C3new(1,1,1), Size=ESP.nameSize, Font=Drawing.Fonts.UI, Outline=true, OutlineColor=C3new(0,0,0), Center=true }),
			dist       = NewDrawing("Text",   { Visible=false, Text="", Color=C3rgb(200,200,200), Size=ESP.distSize, Font=Drawing.Fonts.UI, Outline=true, OutlineColor=C3new(0,0,0), Center=true }),
			healthBg   = NewDrawing("Square", { Visible=false, Filled=true, Color=C3new(0,0,0), Transparency=0.5 }),
			healthFill = NewDrawing("Square", { Visible=false, Filled=true, Color=ESP.healthBarColor }),
			tracer     = NewDrawing("Line",   { Visible=false, Color=ESP.enemyColor, Thickness=1 }),
			skeleton   = skel,
		}
	end

	local function DestroyESPObjects(plr)
		local obj = espObjects[plr]; if not obj then return end
		for k, d in pairs(obj) do
			if k ~= "skeleton" then pcall(function() d:Remove() end) end
		end
		for _, line in ipairs(obj.skeleton) do pcall(function() line:Remove() end) end
		espObjects[plr] = nil
	end

	local function HideESPObjects(plr)
		local obj = espObjects[plr]; if not obj then return end
		obj.box.Visible = false
		obj.name.Visible = false; obj.dist.Visible = false
		obj.healthBg.Visible = false; obj.healthFill.Visible = false
		obj.tracer.Visible = false
		for i = 1, #obj.skeleton do obj.skeleton[i].Visible = false end
	end

	-- ═════════════════════════════════════════════════════════════════
	-- ── Highlight ESP ────────────────────────────────────────────────
	-- ═════════════════════════════════════════════════════════════════

	local hlObjects = {}   -- [plr] = Highlight instance
	local hlFolder  = Instance.new("Folder")
	hlFolder.Name   = "AxonHighlights"
	hlFolder.Parent = workspace

	local function CreateHighlightObject(plr)
		if hlObjects[plr] then return end
		local hl = Instance.new("Highlight")
		hl.FillTransparency    = ESP.highlightFillTransp
		hl.OutlineTransparency = ESP.highlightOutlineTransp
		hl.FillColor           = ESP.highlightEnemyFill
		hl.OutlineColor        = ESP.highlightEnemyOutline
		hl.Adornee             = nil
		hl.Enabled             = false
		hl.Parent              = hlFolder
		hlObjects[plr]         = hl
	end

	local function DestroyHighlightObject(plr)
		local hl = hlObjects[plr]
		if not hl then return end
		pcall(function() hl:Destroy() end)
		hlObjects[plr] = nil
	end

	local function HideHighlightObject(plr)
		local hl = hlObjects[plr]
		if not hl then return end
		hl.Enabled = false
		hl.Adornee = nil
	end

	-- ═════════════════════════════════════════════════════════════════

	local JOINTS = {
		{"Head","UpperTorso"},         {"Head","Torso"},
		{"UpperTorso","LowerTorso"},   {"Torso","HumanoidRootPart"},
		{"UpperTorso","LeftUpperArm"}, {"UpperTorso","RightUpperArm"},
		{"Torso","Left Arm"},          {"Torso","Right Arm"},
		{"LeftUpperArm","LeftLowerArm"},  {"RightUpperArm","RightLowerArm"},
		{"LeftLowerArm","LeftHand"},      {"RightLowerArm","RightHand"},
		{"LowerTorso","LeftUpperLeg"},    {"LowerTorso","RightUpperLeg"},
		{"HumanoidRootPart","Left Leg"},  {"HumanoidRootPart","Right Leg"},
		{"LeftUpperLeg","LeftLowerLeg"},  {"RightUpperLeg","RightLowerLeg"},
		{"LeftLowerLeg","LeftFoot"},      {"RightLowerLeg","RightFoot"},
	}

	local skelCache = {}

	local function GetBoneCache(plr, char)
		local c = skelCache[plr]
		if c and c.char == char then return c.parts end
		local parts = {}
		for _, j in ipairs(JOINTS) do
			parts[j[1]] = parts[j[1]] or char:FindFirstChild(j[1])
			parts[j[2]] = parts[j[2]] or char:FindFirstChild(j[2])
		end
		skelCache[plr] = { char = char, parts = parts }
		return parts
	end

	local function GetScreenBounds(plr, char, root, cam)
		local bc = bbCache[plr]
		if not bc or bc.char ~= char then return nil end

		local hw, hh, hd = bc.hw, bc.hh, bc.hd
		local rf  = root.CFrame
		local uv  = rf.UpVector
		local cpx = rf.X + uv.X * bc.yOff
		local cpy = rf.Y + uv.Y * bc.yOff
		local cpz = rf.Z + uv.Z * bc.yOff

		local camCF = cam.CFrame
		local clv   = camCF.LookVector
		local dx, dy, dz = cpx - camCF.X, cpy - camCF.Y, cpz - camCF.Z
		if dx*clv.X + dy*clv.Y + dz*clv.Z < 0 then return nil end

		local rv = rf.RightVector
		local fv = rf.LookVector
		local rx, ry, rz = rv.X*hw, rv.Y*hw, rv.Z*hw
		local ux, uy, uz = uv.X*hh, uv.Y*hh, uv.Z*hh
		local fx, fy, fz = fv.X*hd, fv.Y*hd, fv.Z*hd

		local minX, maxX =  math.huge, -math.huge
		local minY, maxY =  math.huge, -math.huge
		local any = false
		local sc

		sc = cam:WorldToViewportPoint(V3new(cpx+rx+ux+fx, cpy+ry+uy+fy, cpz+rz+uz+fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx-rx+ux+fx, cpy-ry+uy+fy, cpz-rz+uz+fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx+rx-ux+fx, cpy+ry-uy+fy, cpz+rz-uz+fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx-rx-ux+fx, cpy-ry-uy+fy, cpz-rz-uz+fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx+rx+ux-fx, cpy+ry+uy-fy, cpz+rz+uz-fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx-rx+ux-fx, cpy-ry+uy-fy, cpz-rz+uz-fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx+rx-ux-fx, cpy+ry-uy-fy, cpz+rz-uz-fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end
		sc = cam:WorldToViewportPoint(V3new(cpx-rx-ux-fx, cpy-ry-uy-fy, cpz-rz-uz-fz))
		if sc.Z>0 then any=true if sc.X<minX then minX=sc.X end if sc.X>maxX then maxX=sc.X end if sc.Y<minY then minY=sc.Y end if sc.Y>maxY then maxY=sc.Y end end

		if not any or maxX <= minX or maxY <= minY then return nil end
		return minX, minY, maxX - minX, maxY - minY
	end

	local espLastTick       = 0
	local tracerLastTick    = 0
	local skelLastTick      = 0
	local hlLastTick        = 0

	local function UpdateESP()
		local now = tick()
		local doESP       = ESP.enabled    and (now - espLastTick    >= 1 / ESP_FPS)
		local doTracer    = ESP.tracers    and (now - tracerLastTick >= 1 / ESP_TRACER_FPS)
		local doSkel      = ESP.skeleton   and (now - skelLastTick   >= 1 / ESP_SKEL_FPS)
		local doHighlight = ESP.highlight  and (now - hlLastTick     >= 1 / ESP_HIGHLIGHT_FPS)
		if not doESP and not doTracer and not doSkel and not doHighlight then return end
		if doESP       then espLastTick    = now end
		if doTracer    then tracerLastTick = now end
		if doSkel      then skelLastTick   = now end
		if doHighlight then hlLastTick     = now end

		local cam = workspace.CurrentCamera; if not cam then return end
		local vpX = cam.ViewportSize.X
		local vpY = cam.ViewportSize.Y
		local myChar = LocalPlayer.Character
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		local myPos  = myRoot and myRoot.Position
		local maxD2       = ESP.maxDistance      * ESP.maxDistance
		local tracerMaxD2 = ESP.tracerMaxDist    * ESP.tracerMaxDist
		local skelMaxD2   = ESP.skelMaxDist      * ESP.skelMaxDist
		local hlMaxD2     = ESP.highlightMaxDist * ESP.highlightMaxDist

		local show = {}
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer then
				local cd = charCache[plr]
				if cd then
					local char = cd.char
					local root = cd.root
					if char == plr.Character and root.Parent then
						local isTeam = IsTeammate(plr)
						local d2 = 0
						if myPos then
							local dv = root.Position - myPos
							d2 = dv.X*dv.X + dv.Y*dv.Y + dv.Z*dv.Z
						end
						local espVisible    = doESP       and not (ESP.teamCheck           and isTeam) and (not myPos or d2 <= maxD2)
						local tracerVisible = doTracer    and not (ESP.tracerTeamCheck     and isTeam) and (not myPos or d2 <= tracerMaxD2)
						local skelVisible   = doSkel      and not (ESP.skelTeamCheck       and isTeam) and (not myPos or d2 <= skelMaxD2)
						local hlVisible     = doHighlight and not (ESP.highlightTeamCheck  and isTeam) and (not myPos or d2 <= hlMaxD2)
						if espVisible or tracerVisible or skelVisible or hlVisible then
							show[plr] = { cd = cd, espV = espVisible, tracerV = tracerVisible, skelV = skelVisible, hlV = hlVisible, isTeam = isTeam }
						end
					end
				end
			end
		end

		-- Hide drawing objects for players no longer shown
		for plr in pairs(espObjects) do
			if not show[plr] then HideESPObjects(plr) end
		end
		-- Hide highlight objects for players no longer shown
		if doHighlight then
			for plr in pairs(hlObjects) do
				if not show[plr] or not show[plr].hlV then HideHighlightObject(plr) end
			end
		end

		for plr, info in pairs(show) do
			CreateESPObjects(plr)
			local obj = espObjects[plr]
			if obj then
				local cd   = info.cd
				local col  = GetESPColor(plr)
				local char = cd.char; local root = cd.root
				local head = cd.head; local hum  = cd.hum

				local bbX, bbY, bbW, bbH = GetScreenBounds(plr, char, root, cam)

				local onScreen
				local botSc
				if bbX then
					onScreen = true
				else
					local rsc, rvis = cam:WorldToViewportPoint(root.Position)
					onScreen = rvis
					botSc = rsc
				end

				local espOn    = info.espV    and onScreen
				local tracerOn = info.tracerV and onScreen

				if espOn and ESP.boxes then
					local screenH, screenW, boxX, boxY, cx
					if bbX then
						boxX    = bbX;  boxY    = bbY
						screenW = bbW;  screenH = bbH
						cx      = bbX + bbW * 0.5
					else
						local topSc = cam:WorldToViewportPoint(head.Position + V3new(0, head.Size.Y*0.5+0.1, 0))
						local bsc   = botSc or cam:WorldToViewportPoint(root.Position - V3new(0, 3.1, 0))
						screenH = abs(topSc.Y - bsc.Y)
						screenW = screenH * 0.6
						cx      = (topSc.X + bsc.X) * 0.5
						boxX    = cx - screenW * 0.5
						boxY    = min(topSc.Y, bsc.Y)
					end

					obj.box.Visible    = true; obj.box.Color     = col
					obj.box.Thickness  = ESP.boxThickness
					obj.box.Position   = V2new(boxX, boxY); obj.box.Size = V2new(screenW, screenH)

					obj.name.Visible  = ESP.names;   obj.name.Text  = plr.DisplayName
					obj.name.Size     = ESP.nameSize; obj.name.Color = col
					obj.name.Position = V2new(cx, boxY - ESP.nameSize - 2)

					if ESP.distance and myPos then
						local d = root.Position - myPos
						obj.dist.Visible  = true
						obj.dist.Text     = floor((d.X*d.X + d.Y*d.Y + d.Z*d.Z)^0.5) .. "m"
						obj.dist.Size     = ESP.distSize
						obj.dist.Color    = col
						obj.dist.Position = V2new(cx, boxY + screenH + 2)
					else
						obj.dist.Visible = false
					end

					local hp   = clamp(hum.Health / max(hum.MaxHealth, 1), 0, 1)
					local barH = screenH
					local barW = 3
					local barX = boxX - 5

					obj.healthBg.Visible   = ESP.healthBar
					obj.healthBg.Position  = V2new(barX - 1, boxY - 1)
					obj.healthBg.Size      = V2new(barW + 2, barH + 2)

					obj.healthFill.Visible   = ESP.healthBar
					obj.healthFill.Color     = ESP.healthBarColor
					obj.healthFill.Position  = V2new(barX, boxY + barH * (1 - hp))
					obj.healthFill.Size      = V2new(barW, max(barH * hp, 1))
				else
					obj.box.Visible = false
					obj.name.Visible = false; obj.dist.Visible = false
					obj.healthBg.Visible = false; obj.healthFill.Visible = false
				end

				if tracerOn then
					local bsc = botSc or cam:WorldToViewportPoint(root.Position - V3new(0, 3.1, 0))
					local tracerCol = IsTeammate(plr) and ESP.tracerTeamColor or ESP.tracerEnemyColor
					obj.tracer.Visible   = true; obj.tracer.Color = tracerCol
					obj.tracer.Thickness = ESP.tracerThickness
					obj.tracer.From      = V2new(vpX * 0.5, vpY)
					obj.tracer.To        = V2new(bsc.X, bsc.Y)
				else
					obj.tracer.Visible = false
				end

				if info.skelV then
					local boneCol = IsTeammate(plr) and ESP.skelTeamColor or ESP.skelEnemyColor
					local boneThk = ESP.skeletonThickness
					local parts = GetBoneCache(plr, char); local skel = obj.skeleton
					for j = 1, #JOINTS do
						local line = skel[j]
						if line then
							local jt = JOINTS[j]
							local pa = parts[jt[1]]; local pb = parts[jt[2]]
							if not pa or not pb then
								line.Visible = false
							else
								local sa, va = cam:WorldToViewportPoint(pa.Position)
								local sb, vb = cam:WorldToViewportPoint(pb.Position)
								if not va or not vb or sa.Z < 0 or sb.Z < 0 then
									line.Visible = false
								else
									line.From = V2new(sa.X, sa.Y); line.To = V2new(sb.X, sb.Y)
									line.Color = boneCol; line.Thickness = boneThk; line.Visible = true
								end
							end
						end
					end
				else
					local skel = obj.skeleton
					for j = 1, #skel do skel[j].Visible = false end
				end

				-- ── Highlight update ─────────────────────────────────
				if info.hlV then
					CreateHighlightObject(plr)
					local hl = hlObjects[plr]
					if hl then
						local isTeam = info.isTeam
						hl.FillColor           = isTeam and ESP.highlightTeamFill    or ESP.highlightEnemyFill
						hl.OutlineColor        = isTeam and ESP.highlightTeamOutline or ESP.highlightEnemyOutline
						hl.FillTransparency    = ESP.highlightFillTransp
						hl.OutlineTransparency = ESP.highlightOutlineTransp
						hl.Adornee             = char
						hl.Enabled             = true
					end
				elseif doHighlight then
					HideHighlightObject(plr)
				end
			end
		end
	end

	local espConn = nil
	local function StartESP()
		if espConn then return end
		espConn = RunService.Heartbeat:Connect(function()
			local anyActive = ESP.enabled or ESP.skeleton or ESP.tracers or ESP.highlight
			if anyActive then
				UpdateESP()
			else
				local now = tick()
				if now - espLastTick < 0.2 then return end
				espLastTick = now; tracerLastTick = now; skelLastTick = now; hlLastTick = now
				for _, plr in ipairs(Players:GetPlayers()) do
					HideESPObjects(plr)
					HideHighlightObject(plr)
				end
			end
		end)
	end

	local function SetupPlayer(plr)
		if plr == LocalPlayer then return end
		plr.CharacterAdded:Connect(function(char)
			local root = char:WaitForChild("HumanoidRootPart", 10)
			local head = char:WaitForChild("Head", 10)
			local hum  = char:WaitForChild("Humanoid", 10)
			if not root or not head or not hum then return end
			RefreshCharCache(plr)
			DestroyESPObjects(plr)
			CreateESPObjects(plr)
			DestroyHighlightObject(plr)
			CreateHighlightObject(plr)
			skelCache[plr] = nil
		end)
		plr.CharacterRemoving:Connect(function()
			charCache[plr] = nil
			bbCache[plr]   = nil
			HideESPObjects(plr)
			HideHighlightObject(plr)
		end)
		if plr.Character then
			RefreshCharCache(plr)
			CreateESPObjects(plr)
			CreateHighlightObject(plr)
		end
	end

	local _espPlayerAddedConn   = Players.PlayerAdded:Connect(SetupPlayer)

	local _espPlayerRemovingConn = Players.PlayerRemoving:Connect(function(plr)
		DestroyESPObjects(plr)
		DestroyHighlightObject(plr)
		skelCache[plr] = nil
		charCache[plr] = nil
		bbCache[plr]   = nil
	end)

	for _, plr in ipairs(Players:GetPlayers()) do
		SetupPlayer(plr)
	end

