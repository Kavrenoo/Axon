		WOA_Destroy(); WOA.enabled = true; WOA.baseY = root.Position.Y - hipH - (isR6 and 3.5 or 1.5)
		local part = Instance.new("Part"); part.Name = "AxonWalkAirPlatform"; part.Size = Vector3.new(3, 5, 3)
		part.Anchored = true; part.CanCollide = true; part.Material = Enum.Material.SmoothPlastic
		part.Transparency = 1; part.CastShadow = false
		part.CFrame = CFrame.new(root.Position.X, WOA.baseY - 2, root.Position.Z); part.Parent = workspace
		WOA.platform = part
		WOA.renderConn = Axon.Services.RunService.RenderStepped:Connect(function()
			if not WOA.enabled then return end
			local _, r = GetHR(); if not r or not WOA.platform then return end
			if WOA.up   then WOA.baseY = WOA.baseY + 0.2 end
			if WOA.down then WOA.baseY = WOA.baseY - 0.2 end
			WOA.platform.CFrame = CFrame.new(r.Position.X, WOA.baseY - 2, r.Position.Z)
		end)
	end

	-- ── Shared teleport action ────────────────────────────────
	-- Matches Infinite Yield's clicktp behaviour: teleport directly to
	-- Mouse.Hit.p (no distance cap, works at any range).
	-- If the mouse is aimed at void and Walk On Air is active, land on the
	-- WOA platform instead (same as before).
	local function DoTeleportAt()
		local h, root = GetHR(); if not root then return end
		local mouse = Axon.Services.Mouse
		local hipH  = h and h.HipHeight or 2.3
		local hrpHalfHeight = root.Size.Y * 0.5  -- actual half-height of the root part (fixes small avatars)
		local sinkBuffer = math.max(0.5, hipH * 0.15) + hrpHalfHeight * 0.25
		local hit   = mouse.Hit.Position  -- world-space point the cursor is aimed at

		local targetPos
		if mouse.Target then
			-- Mouse is hitting real geometry — stand on top of it (IY style)
			if WOA.enabled then
				-- With Walk On Air active, raycast 10000 studs downward from the
				-- hit point to confirm there is real ground beneath it.
				local rcParams = RaycastParams.new()
				local char     = Axon.Services.Player.Character
				local excludes = char and { char } or {}
				if WOA.platform then table.insert(excludes, WOA.platform) end
				rcParams.FilterDescendantsInstances = excludes
				rcParams.FilterType                 = Enum.RaycastFilterType.Exclude
				local groundCheck = workspace:Raycast(
					Vector3.new(hit.X, hit.Y + 0.5, hit.Z),
					Vector3.new(0, -15000, 0),
					rcParams
				)
				if groundCheck then
					-- Ground confirmed below — teleport normally onto the surface
					targetPos = Vector3.new(hit.X, hit.Y + hipH + sinkBuffer, hit.Z)
				else
					-- No ground — land on WOA platform: top = WOA.baseY + 0.5, HRP = top + hipH
					targetPos = Vector3.new(hit.X, WOA.baseY + hipH + 0.5, hit.Z)
				end
			else
				targetPos = Vector3.new(hit.X, hit.Y + hipH + sinkBuffer, hit.Z)
			end
		elseif WOA.enabled then
			-- Aimed at void with WOA on — project the camera ray onto the WOA
			-- platform's Y plane so X,Z are accurate instead of shooting to the
			-- end of the ray.
			local cam     = workspace.CurrentCamera
			local mousePos = Axon.Services.UserInputService:GetMouseLocation()
			local unitRay  = cam:ScreenPointToRay(mousePos.X, mousePos.Y)
			local planeY   = WOA.baseY
			local dirY     = unitRay.Direction.Y
			local projX, projZ
			if math.abs(dirY) > 0.0001 then
				local t = (planeY - unitRay.Origin.Y) / dirY
				local p = unitRay.Origin + unitRay.Direction * math.max(t, 0)
				projX, projZ = p.X, p.Z
			else
				projX, projZ = hit.X, hit.Z
			end
			-- WOA platform top = WOA.baseY + 0.5, HRP stands at top + hipH
			targetPos = Vector3.new(projX, WOA.baseY + hipH + 0.5, projZ)
		else
			-- Aimed at void, no WOA — teleport to wherever the cursor points
			targetPos = Vector3.new(hit.X, hit.Y + hipH + sinkBuffer, hit.Z)
		end

		local lookDir = (Vector3.new(targetPos.X, root.Position.Y, targetPos.Z) - root.Position)
		lookDir = lookDir.Magnitude > 0.01 and lookDir.Unit or root.CFrame.LookVector
		root.CFrame = CFrame.new(targetPos, targetPos + lookDir)
		if h then h.Sit = false; h.AutoRotate = true end

		-- ── Post-teleport ground correction (fixes small R15 avatars sinking into terrain) ──
		task.defer(function()
			local _, r2 = GetHR()
			if not r2 then return end
			local rcP = RaycastParams.new()
			local ch2 = Axon.Services.Player.Character
			rcP.FilterDescendantsInstances = ch2 and { ch2 } or {}
			rcP.FilterType = Enum.RaycastFilterType.Exclude
			local downHit = workspace:Raycast(
				r2.Position + Vector3.new(0, 1, 0),
				Vector3.new(0, -(hipH + 4), 0),
				rcP
			)
			if downHit then
				local minY = downHit.Position.Y + hipH + 0.1
				if r2.Position.Y < minY then
					r2.CFrame = CFrame.new(
						Vector3.new(r2.Position.X, minY, r2.Position.Z),
						Vector3.new(r2.Position.X, minY, r2.Position.Z) + lookDir
					)
				end
			end
		end)
	end

