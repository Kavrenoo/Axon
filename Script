	local function TriggerStop()
		if TB.conn then TB.conn:Disconnect(); TB.conn = nil end
		if TB._holding then pcall(mouse1release); TB._holding = false end
		TB._firing = false
	end

	local function IsEnemy(hit)
		if not hit or not hit.Parent then return false end
		local char = hit.Parent
		local hum  = char:FindFirstChildOfClass("Humanoid")
		if not hum then return false end
		local plr = Players:GetPlayerFromCharacter(char)
		if not plr or plr == LocalPlayer then return false end
		if TB.aliveCheck and not IsAlive(plr) then return false end
		if TB.teamCheck and IsTeammate(plr) then return false end
		return true
	end

	local function Raycast()
		local cam = workspace.CurrentCamera; if not cam then return nil end
		local mousePos = UserInputService:GetMouseLocation()
		local ray = cam:ViewportPointToRay(mousePos.X, mousePos.Y)
		local lc = LocalPlayer.Character
		local bl = {}
		if lc then bl[1] = lc; for _, v in ipairs(lc:GetDescendants()) do bl[#bl+1] = v end end
		local rp = RaycastParams.new()
		rp.FilterDescendantsInstances = bl
		rp.FilterType = Enum.RaycastFilterType.Exclude
		return workspace:Raycast(ray.Origin, ray.Direction * 1000, rp)
	end

	local function TriggerStart()
		TriggerStop()
		TB.conn = RunService.Heartbeat:Connect(function()
			if not TB.enabled then TriggerStop(); return end

			local result  = Raycast()
			local onEnemy = result and IsEnemy(result.Instance)

			if TB.mode == "Auto" then
				-- ── Hold mode: press while on enemy, release when off ──────
				if onEnemy and not TB._holding then
					TB._holding = true
					pcall(mouse1press)
				elseif not onEnemy and TB._holding then
					TB._holding = false
					pcall(mouse1release)
				end

			else
				-- ── Single mode: one discrete click per detection ──────────
				-- Guard: don't start a new shot while one is in-flight
				if not onEnemy or TB._firing then return end
				-- Cooldown: enforce minimum gap between shots
				if TB.cooldown > 0 and (tick() - TB._lastShot) < TB.cooldown then return end

				TB._firing = true
				TB._lastShot = tick()
				task.spawn(function()
					-- Optional pre-fire delay (e.g. lead time on snipers)
					if TB.preFire > 0 then task.wait(TB.preFire) end
					if not TB.enabled then TB._firing = false; return end
					pcall(mouse1press)
					task.wait(math.max(TB.clickDur, 0.016))  -- minimum 1 frame
					pcall(mouse1release)
					TB._holding = false
					TB._firing  = false
				end)
			end
		end)
	end

