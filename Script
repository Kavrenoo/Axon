	-- ── CFrame walk loop ──────────────────────────────────────
	local function StopCFrameWalk()
		if Char.walkCFrameConn then Char.walkCFrameConn:Disconnect(); Char.walkCFrameConn = nil end
		local h, root = GetHR()
		if h then
			h.WalkSpeed = Char.walkSpeed
			h.AutoRotate = true
			h:Move(Vector3.zero, false)
		end
	end

	StartCFrameWalk = function()
		StopCFrameWalk()
		local UIS = Axon.Services.UserInputService
		local lastLook = nil
		Char.walkCFrameConn = Axon.Services.RunService.RenderStepped:Connect(function(dt)
			local h, root = GetHR(); if not root or not h then return end
			h.WalkSpeed = 16
			h.AutoRotate = false

			if UIS:GetFocusedTextBox() then
				h:Move(Vector3.zero, false)
				return
			end

			local cam = workspace.CurrentCamera; if not cam then return end
			local dir = Vector3.zero
			if UIS:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
			if UIS:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
			if UIS:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end

			local flat = Vector3.new(dir.X, 0, dir.Z)
			local shiftLockActive = UIS.MouseBehavior == Enum.MouseBehavior.LockCenter
			if flat.Magnitude > 0 then
				local unit = flat.Unit
				lastLook = unit
				h:Move(unit, false)
				local newPos = root.Position + unit * Char.walkSpeed * dt
				if shiftLockActive then
					-- shift lock: move freely but keep character facing the camera
					local camFlat = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
					if camFlat.Magnitude > 0.01 then
						root.CFrame = CFrame.new(newPos, newPos + camFlat.Unit)
					else
						root.CFrame = CFrame.new(newPos, newPos + unit)
					end
				else
					root.CFrame = CFrame.new(newPos, newPos + unit)
				end
			else
				h:Move(Vector3.zero, false)
				-- if shift lock is active, follow the camera while standing still
				if shiftLockActive then
					local camFlat = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
					if camFlat.Magnitude > 0.01 then
						local camUnit = camFlat.Unit
						lastLook = camUnit
						root.CFrame = CFrame.new(root.Position, root.Position + camUnit)
					end
				elseif lastLook then
					root.CFrame = CFrame.new(root.Position, root.Position + lastLook)
				end
			end
		end)
	end

