	-- UNIVERSAL TEAM DETECTION
	-- ═════════════════════════════════════════════════════════════════
	--
	-- Mode "Auto":        Try all methods in priority order
	-- Mode "TeamObject":  Roblox Teams service only (player.Team)
	-- Mode "TeamColor":   BrickColor TeamColor match (good for many FPS games)
	-- Mode "Attribute":   Custom game attributes / Value objects inside Player
	-- Mode "Off":         Everyone is an enemy (true FFA)
	-- ─────────────────────────────────────────────────────────────────

	-- Common attribute/value names games use for custom team systems
	local TEAM_ATTR_NAMES = {
		"Team", "team", "TeamID", "teamId", "Side", "side",
		"Faction", "faction", "Alliance", "alliance",
	}
	local TEAM_VALUE_NAMES = {
		"Team", "TeamValue", "TeamID", "Side", "Faction",
	}

	-- Global combat settings (shared across ESP, Aimbot, Triggerbot, HBE)
	local CombatSettings = {
		teamMode  = Axon.Settings.Data.combatTeamMode or "Auto",
		ffCheck   = Axon.Settings.Data.combatFfCheck ~= false,  -- skip ForceField players
	}

	-- ── Attribute/value team lookup (returns comparable value or nil) ──
	local function GetCustomTeam(plr)
		for _, name in ipairs(TEAM_ATTR_NAMES) do
			local v = plr:GetAttribute(name)
			if v ~= nil then return v end
		end
		for _, name in ipairs(TEAM_VALUE_NAMES) do
			local obj = plr:FindFirstChild(name)
			if obj and obj:IsA("ValueBase") then return obj.Value end
		end
		return nil
	end

	-- ── Core IsTeammate — all features call this ──────────────────────
	local function IsTeammate(plr)
		local mode = CombatSettings.teamMode

		if mode == "Off" then return false end

		if mode == "TeamObject" then
			local t = LocalPlayer.Team
			return t ~= nil and plr.Team == t
		end

		if mode == "TeamColor" then
			-- White (RGB 255,255,255) = Neutral/no team in Roblox — treat as FFA
			local myColor = LocalPlayer.TeamColor
			if myColor == BrickColor.new("White") then return false end
			return plr.TeamColor == myColor
		end

		if mode == "Attribute" then
			local myVal  = GetCustomTeam(LocalPlayer)
			local plrVal = GetCustomTeam(plr)
			if myVal ~= nil and plrVal ~= nil then return myVal == plrVal end
			return false
		end

		-- ── Auto: cascade through all methods ────────────────────────
		-- 1. Standard Roblox Teams
		local myTeam = LocalPlayer.Team
		if myTeam ~= nil then
			return plr.Team == myTeam
		end

		-- 2. Both neutral (no teams) → FFA, everyone is enemy
		if plr.Team == nil then
			-- Still try fallbacks before giving up
		end

		-- 3. TeamColor (skip if local player is white/neutral)
		local myColor = LocalPlayer.TeamColor
		if myColor ~= BrickColor.new("White") and plr.TeamColor == myColor then
			return true
		end

		-- 4. Custom attribute / Value object
		local myVal  = GetCustomTeam(LocalPlayer)
		local plrVal = GetCustomTeam(plr)
		if myVal ~= nil and plrVal ~= nil then
			return myVal == plrVal
		end

		return false
	end

	-- ── IsAlive — used by ESP, aimbot, triggerbot, HBE ───────────────
	local function IsAlive(plr)
		local char = plr.Character
		if not char then return false end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum or hum.Health <= 0 then return false end
		-- ForceField = player is spawn-protected, functionally dead for targeting
		if CombatSettings.ffCheck and char:FindFirstChildOfClass("ForceField") then
			return false
		end
		return true
	end

	local function GetEnemies(checkAlive)
		local out = {}
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= LocalPlayer then
				local char = plr.Character
				if char then
					local root = char:FindFirstChild("HumanoidRootPart")
					if root then
						if not checkAlive or IsAlive(plr) then
							out[#out + 1] = plr
						end
					end
				end
			end
		end
		return out
	end

