	local originalSensitivity = UserInputService.MouseDeltaSensitivity

	local function CancelLock()
		AB.locked = nil; lockedPartRef = nil; lockedHumRef = nil
		if AB.animation then AB.animation:Cancel(); AB.animation = nil end
		UserInputService.MouseDeltaSensitivity = originalSensitivity
		if fovCircle then fovCircle.Color = AB.fovColor end
