	local BP_TILE=256; local BP_CHUNK=8; local BP_RENDER=2; local BP_UNLOAD=3
	local function BPGetFolder() local f=workspace:FindFirstChild("AxonBaseplateFolder"); if not f then f=Instance.new("Folder"); f.Name="AxonBaseplateFolder"; f.Parent=workspace end; return f end
	local function BPGenChunk(cx,cz,baseY)
		local key=cx..","..cz; if Misc.baseplateChunks[key] then return end
		Misc.baseplateChunks[key]=true
		local folder=Instance.new("Folder"); folder.Name="AxonChunk_"..key; folder.Parent=BPGetFolder(); Misc.baseplateFolders[key]=folder
		for x=0,BP_CHUNK-1 do for z=0,BP_CHUNK-1 do
			local part=Instance.new("Part"); part.Name="AxonTile"; part.Anchored=true; part.Locked=true
			part.Size=Vector3.new(BP_TILE,5,BP_TILE)
			part.Position=Vector3.new((cx*BP_CHUNK+x)*BP_TILE, baseY-2.5, (cz*BP_CHUNK+z)*BP_TILE)
			part.Material=Misc.bpMaterial; part.Color=Misc.bpColor
			part.Transparency=0; part.CanCollide=true
			part.TopSurface=Enum.SurfaceType.Smooth; part.BottomSurface=Enum.SurfaceType.Smooth
			part.Parent=folder
		end end
	end
	local function BPUnloadFar(cx,cz) for key in pairs(Misc.baseplateChunks) do local x,z=key:match("([^,]+),([^,]+)"); x,z=tonumber(x),tonumber(z); if math.abs(x-cx)>BP_UNLOAD or math.abs(z-cz)>BP_UNLOAD then if Misc.baseplateFolders[key] then Misc.baseplateFolders[key]:Destroy(); Misc.baseplateFolders[key]=nil end; Misc.baseplateChunks[key]=nil end end end
	local function BPUpdate() local char=Axon.Services.Player.Character; local root=char and char:FindFirstChild("HumanoidRootPart"); if not root then return end; local pos=root.Position; local cx=math.floor(pos.X/(BP_TILE*BP_CHUNK)); local cz=math.floor(pos.Z/(BP_TILE*BP_CHUNK)); for x=-BP_RENDER,BP_RENDER do for z=-BP_RENDER,BP_RENDER do BPGenChunk(cx+x,cz+z,Misc.baseplateBaseY) end end; BPUnloadFar(cx,cz) end
	local function BPRefreshAll()
		local folder = workspace:FindFirstChild("AxonBaseplateFolder"); if not folder then return end
		for _, chunk in ipairs(folder:GetChildren()) do
			for _, part in ipairs(chunk:GetChildren()) do
				if part.Name == "AxonTile" then
					part.Material    = Misc.bpMaterial
					part.Color       = Misc.bpColor
					part.Transparency = 0
