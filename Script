    for _, c in pairs(Axon.Pages.Containers) do
        c.Visible = false
    end

    if Axon.Pages.Containers[name] then
        Axon.Pages.Containers[name].Visible = true
    end

    Axon.Pages.Current = name

    Axon.UI.PageTitle.Text = Axon.Pages.Titles[name] or name

    Axon.UI.ScrollFrame.CanvasPosition = Vector2.new(0, 0)
end

